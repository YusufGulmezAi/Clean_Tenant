    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <!-- bUnit Blazor render testleri için root namespace -->
    <RootNamespace>CleanTenant.ManagementApp.bUnitTests</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
