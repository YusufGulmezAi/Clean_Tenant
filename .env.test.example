# CleanTenant — Test Ortamı (CI / QA) Sır ve Konfigürasyon Şablonu
#
# CI ortamında bu değerler GitHub Actions Encrypted Secrets üzerinden gelir.
# Yerel test koşumu için bu dosyayı .env.test olarak kopyalayın.

COMPOSE_PROJECT_NAME=cleantenant-test
ASPNETCORE_ENVIRONMENT=Test

# PostgreSQL — Dev'den farklı port (paralel calisabilsin)
POSTGRES_PORT=5532
POSTGRES_USER=cleantenant
POSTGRES_PASSWORD=__DEGISTIR_TEST_SIFRE__

ConnectionStrings__Catalog=Host=localhost;Port=5532;Database=cleantenant_catalog;Username=cleantenant;Password=__DEGISTIR_TEST_SIFRE__
ConnectionStrings__Main=Host=localhost;Port=5532;Database=cleantenant_main;Username=cleantenant;Password=__DEGISTIR_TEST_SIFRE__
ConnectionStrings__Log=Host=localhost;Port=5532;Database=cleantenant_log;Username=cleantenant;Password=__DEGISTIR_TEST_SIFRE__
ConnectionStrings__Audit=Host=localhost;Port=5532;Database=cleantenant_audit;Username=cleantenant;Password=__DEGISTIR_TEST_SIFRE__

# Redis
REDIS_PORT=6479
REDIS_PASSWORD=__DEGISTIR_TEST_SIFRE__
ConnectionStrings__Redis=localhost:6479,password=__DEGISTIR_TEST_SIFRE__,abortConnect=false

# JWT — test ortamı için kısa süreli, test-spesifik key
JWT_ISSUER=cleantenant.test
JWT_AUDIENCE=cleantenant.test.clients
JWT_SIGNING_KEY=__DEGISTIR_256BIT_RASGELE_ANAHTAR__
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=1
