@page "/"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject AuthenticationStateProvider AuthProvider

<PageTitle>Anasayfa — Site Portalı</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Hoş geldiniz@(_fullName is not null ? $", {_fullName}" : "")!</MudText>

<MudGrid>
    <MudItem xs="12" sm="6" md="4">
        <MudPaper Elevation="2" Class="pa-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Apartment" Color="Color.Primary" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Siteniz</MudText>
                    <MudText Typo="Typo.h6">@(_companyName ?? "—")</MudText>
                </div>
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudPaper Elevation="2" Class="pa-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Domain" Color="Color.Primary" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Yönetim</MudText>
                    <MudText Typo="Typo.h6">@(_tenantName ?? "—")</MudText>
                </div>
            </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private string? _fullName;
    private string? _tenantName;
    private string? _companyName;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        var user = state.User;
        if (user?.Identity?.IsAuthenticated == true)
        {
            _fullName = user.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
                ?? user.FindFirst("user_id")?.Value?[..8];
            _tenantName = user.FindFirst("tenant_name")?.Value;
            _companyName = user.FindFirst("company_name")?.Value;
        }
    }
}
