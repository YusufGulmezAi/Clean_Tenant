@inherits LayoutComponentBase
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@inject IJSRuntime JS
@using System.Globalization

@*
    v0.2.10.f — RTL desteği eklendi. Aktif kültür AR ise MudRTLProvider
    RightToLeft=true ve <body dir="rtl"> aktif. Cookie-driven culture
    değişimi tam reload tetiklediği için her load'da OnAfterRenderAsync
    firstRender'da JS interop ile dir attribute yeniden set edilir.
*@

<MudRTLProvider RightToLeft="@_isRtl">
    <MudThemeProvider />
    <MudPopoverProvider />
    <MudDialogProvider />
    <MudSnackbarProvider />
</MudRTLProvider>

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIcon Icon="@Icons.Material.Filled.HomeWork" Class="mr-2" />
        <MudText Typo="Typo.h6">Toplu Yapı Portalı</MudText>
        <MudSpacer />
        @if (!string.IsNullOrEmpty(_tenantName))
        {
            <MudChip T="string" Color="Color.Secondary" Size="Size.Small" Class="mr-2">@_tenantName</MudChip>
        }
        @if (!string.IsNullOrEmpty(_companyName))
        {
            <MudChip T="string" Color="Color.Dark" Size="Size.Small" Class="mr-2">@_companyName</MudChip>
        }
        <MudTooltip Text="Çıkış">
            <MudIconButton Icon="@Icons.Material.Filled.Logout"
                           Color="Color.Inherit"
                           Href="/auth/sign-out" />
        </MudTooltip>
    </MudAppBar>

    <MudDrawer Open="true" Variant="DrawerVariant.Mini" Elevation="2" ClipMode="DrawerClipMode.Always">
        <MudNavMenu Color="Color.Primary" Bordered="true">
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
                Anasayfa
            </MudNavLink>
            <MudNavLink Href="/profile" Icon="@Icons.Material.Filled.Person">
                Profilim
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pa-4">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private string? _tenantName;
    private string? _companyName;
    private bool _isRtl;

    protected override void OnInitialized()
    {
        // v0.2.10.f — Aktif kültür AR ise RTL. ManagementApp LanguageService'i
        // PortalApp referansında yok; inline kontrol yeterli (tek RTL dil ar-*).
        _isRtl = CultureInfo.CurrentUICulture.Name
            .StartsWith("ar", StringComparison.OrdinalIgnoreCase);
    }

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        var user = state.User;
        if (user?.Identity?.IsAuthenticated == true)
        {
            _tenantName = user.FindFirst("tenant_name")?.Value;
            _companyName = user.FindFirst("company_name")?.Value;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("cleantenant.setBodyDirection", _isRtl ? "rtl" : "ltr");
        }
    }
}
