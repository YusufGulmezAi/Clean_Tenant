@page "/change-password"
@layout EmptyLayout
@implements IDisposable
@inject PersistentComponentState ApplicationState
@inject IStringLocalizer Loc
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@*
    İlk giriş zorunlu şifre değiştirme sayfası. Login akışında
    "PasswordChangeRequired" sonucu sonrası yönlendirilir.
    Challenge token HttpOnly cookie'de (__ct_pwd_chg); form /auth/change-password'a POST eder.
*@

<PageTitle>@Loc["ChangePassword.PageTitle"]</PageTitle>

<MudPaper Elevation="3" Class="pa-8 mx-auto mt-16" MaxWidth="MaxWidth.Small" Style="max-width: 460px;">
    <div class="d-flex align-center mb-6">
        <MudIcon Icon="@Icons.Material.Filled.LockReset" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h4" Class="ml-2">@Loc["ChangePassword.Title"]</MudText>
    </div>

    @if (!_hasChallenge)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">
            @Loc["ChangePassword.NoSession"]
            <MudLink Href="/login">@Loc["ChangePassword.BackToLogin"]</MudLink>.
        </MudAlert>
    }
    else
    {
        <MudAlert Severity="Severity.Info" Class="mb-4">
            @Loc["ChangePassword.Subtitle"]
        </MudAlert>

        @if (!string.IsNullOrEmpty(ErrorCode))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">
                @MessageFor(ErrorCode)
            </MudAlert>
        }

        <form method="post" action="/auth/change-password" id="pwd-change-form">
            <div class="mb-4">
                <label for="new-password" class="d-block mb-1" style="font-weight: 500;">
                    @Loc["ChangePassword.NewPassword"]
                </label>
                <input id="new-password" name="newPassword" type="password"
                       autocomplete="new-password" required minlength="8"
                       oninput="window.pwdChangeValidate && window.pwdChangeValidate()"
                       style="width: 100%; padding: 10px; border: 1px solid rgba(0,0,0,0.23); border-radius: 4px; font-size: 1rem;" />
            </div>

            <div class="mb-4">
                <label for="confirm-password" class="d-block mb-1" style="font-weight: 500;">
                    @Loc["ChangePassword.ConfirmPassword"]
                </label>
                <input id="confirm-password" type="password"
                       autocomplete="new-password" required minlength="8"
                       oninput="window.pwdChangeValidate && window.pwdChangeValidate()"
                       style="width: 100%; padding: 10px; border: 1px solid rgba(0,0,0,0.23); border-radius: 4px; font-size: 1rem;" />
                <span id="pwd-mismatch" style="display:none; color:#d32f2f; font-size:0.8rem;">
                    @Loc["ChangePassword.Mismatch"]
                </span>
            </div>

            <button type="submit" id="pwd-change-submit" disabled
                    style="width: 100%; padding: 12px; background-color: var(--mud-palette-primary); color: white; border: none; border-radius: 4px; font-size: 1rem; font-weight: 500; cursor: pointer; opacity: 0.5;">
                @Loc["ChangePassword.Submit"]
            </button>
        </form>

        <script>
            (function () {
                window.pwdChangeValidate = function () {
                    var newPwd = document.getElementById('new-password').value || '';
                    var confirmPwd = document.getElementById('confirm-password').value || '';
                    var mismatch = document.getElementById('pwd-mismatch');
                    var btn = document.getElementById('pwd-change-submit');
                    var match = newPwd === confirmPwd;
                    var valid = newPwd.length >= 8 && confirmPwd.length >= 8 && match;
                    mismatch.style.display = (confirmPwd.length > 0 && !match) ? 'block' : 'none';
                    btn.disabled = !valid;
                    btn.style.opacity = valid ? '1' : '0.5';
                };
            })();
        </script>

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.caption" Color="Color.Default" Class="d-block mt-2">
            <MudLink Href="/login">@Loc["ChangePassword.BackToLogin"]</MudLink>
        </MudText>
    }
</MudPaper>

@code {
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorCode { get; set; }

    private const string PersistStateKey = "pwd-chg-present";
    private bool _hasChallenge;
    private PersistingComponentStateSubscription _persistingSubscription;

    protected override void OnInitialized()
    {
        _persistingSubscription = ApplicationState.RegisterOnPersisting(PersistFlagAsync);

        if (ApplicationState.TryTakeFromJson<bool>(PersistStateKey, out var saved))
        {
            _hasChallenge = saved;
        }
        else
        {
            var raw = HttpContext?.Request.Cookies[AuthEndpoints.PasswordChangeCookieName];
            _hasChallenge = !string.IsNullOrEmpty(raw);
        }
    }

    private Task PersistFlagAsync()
    {
        ApplicationState.PersistAsJson(PersistStateKey, _hasChallenge);
        return Task.CompletedTask;
    }

    public void Dispose() => _persistingSubscription.Dispose();

    private string MessageFor(string code) => code switch
    {
        "AUTH-020" => Loc["ChangePassword.Error.InvalidSession"].Value,
        "AUTH-021" => Loc["ChangePassword.Error.UserNotFound"].Value,
        "AUTH-022" => Loc["ChangePassword.Error.WeakPassword"].Value,
        _ => Loc["ChangePassword.Error.Unknown", code].Value,
    };
}
