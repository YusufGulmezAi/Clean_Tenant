@page "/system/roles"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IAuthorizationCatalogReader RoleReader
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthProvider
@implements IDisposable
@using CleanTenant.Application.Features.Catalog.Permissions
@using CleanTenant.Application.Features.Catalog.Readers
@using CleanTenant.Application.Features.Catalog.Roles
@using CleanTenant.ManagementApp.Components.Shared
@using MediatR

<PageTitle>Roller — Sistem</PageTitle>

@if (_unauthorized)
{
    <MudAlert Severity="Severity.Warning" Class="my-3">
        Bu sayfa yalnız Sistem kullanıcıları için. Aktif bağlamınız Sistem değil.
    </MudAlert>
}
else if (!_initialized)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <div class="d-flex justify-between align-center mb-3">
        <div style="min-width: 200px;">
            <MudSelect T="int"
                       @bind-Value="_scopeLevel"
                       @bind-Value:after="LoadRolesAsync"
                       Label="Kapsam Seviyesi"
                       Variant="Variant.Outlined"
                       Size="Size.Small">
                <MudSelectItem Value="0">Sistem</MudSelectItem>
                <MudSelectItem Value="1">Yönetim</MudSelectItem>
                <MudSelectItem Value="2">Site</MudSelectItem>
                <MudSelectItem Value="3">Birim</MudSelectItem>
            </MudSelect>
        </div>
        <MudButton StartIcon="@Icons.Material.Filled.Add"
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   Href="/system/roles/new">
            Yeni Rol
        </MudButton>
    </div>

    <DataTable TItem="RoleListItem"
               Items="@_items"
               SearchPlaceholder="Rol ara…"
               SearchableFields="@(row => new[] { row.Name, row.Description ?? "" })"
               Filterable="true">
        <Columns>
            <PropertyColumn T="RoleListItem" TProperty="string" Property="@(r => r.Name)" Title="Rol Adı" />
            <PropertyColumn T="RoleListItem" TProperty="string" Property="@(r => r.Description)" Title="Açıklama" />
            <PropertyColumn T="RoleListItem" TProperty="int" Property="@(r => (int)r.Scope)" Title="Kapsam">
                <CellTemplate>
                    <MudText Typo="Typo.body2">
                        @(context.Item.Scope switch
                        {
                            SharedKernel.Context.ScopeLevel.System => "Sistem",
                            SharedKernel.Context.ScopeLevel.Tenant => "Yönetim",
                            SharedKernel.Context.ScopeLevel.Company => "Site",
                            SharedKernel.Context.ScopeLevel.Unit => "Birim",
                            _ => "—"
                        })
                    </MudText>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn T="RoleListItem" TProperty="int" Property="@(r => r.PermissionCount)" Title="İzin Sayısı" />
            <PropertyColumn T="RoleListItem" TProperty="bool" Property="@(r => r.IsBuiltIn)" Title="Built-in">
                <CellTemplate>
                    @if (context.Item.IsBuiltIn)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Info" Size="Size.Small" />
                    }
                </CellTemplate>
            </PropertyColumn>
            <TemplateColumn T="RoleListItem" CellClass="d-flex justify-end" Filterable="false" Sortable="false">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   title="Düzenle"
                                   OnClick="@(() => GoToEdit(context.Item.Id))"
                                   Disabled="@context.Item.IsBuiltIn" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   title="Sil"
                                   OnClick="@(() => DeleteAsync(context.Item))"
                                   Disabled="@context.Item.IsBuiltIn" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </DataTable>
}

@code {
    private bool _unauthorized;
    private bool _initialized;
    private int _scopeLevel = 0;
    private IReadOnlyList<RoleListItem>? _items;
    private IMediator? _mediator;

    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true
            || !string.Equals(user.FindFirst("scope")?.Value, "System", StringComparison.OrdinalIgnoreCase))
        {
            _unauthorized = true;
            _initialized = true;
            return;
        }

        _mediator = HttpContext?.RequestServices.GetService<IMediator>();

        await LoadRolesAsync();
        _initialized = true;
    }

    private async Task LoadRolesAsync()
    {
        try
        {
            _items = await RoleReader.GetRolesByScopeAsync(_scopeLevel);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Roller yüklenirken hata: {ex.Message}", Severity.Error);
        }
    }

    private void GoToEdit(Guid id)
    {
        Nav.NavigateTo($"/system/roles/{id}/edit");
    }

    private async Task DeleteAsync(RoleListItem role)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"'{role.Name}' rolü silinecek. Devam etmek istiyor musunuz?");
        if (!confirmed) return;

        try
        {
            if (_mediator is null) return;
            var command = new DeleteRoleCommand(role.Id);
            await _mediator.Send(command);

            Snackbar.Add("Rol başarıyla silindi.", Severity.Success);
            await LoadRolesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Hata: {ex.Message}", Severity.Error);
        }
    }

    public void Dispose()
    {
    }
}
