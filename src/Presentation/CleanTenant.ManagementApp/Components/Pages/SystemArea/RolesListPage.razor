@page "/system/roles"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject NavigationManager Nav

@*
    v0.2.13.b — Rol yönetimi birleşik "Erişim Yönetimi" (/access) sayfasının
    "Roller & İzinler" sekmesine taşındı. Bu eski route (/system/roles) artık
    /access'e yönlendirir.
*@

@code {
    protected override void OnInitialized()
    {
        Nav.NavigateTo("/access", forceLoad: false, replace: true);
    }
}
