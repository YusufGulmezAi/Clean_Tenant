@page "/system/roles"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IAuthorizationCatalogReader RoleReader
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthProvider
@inject IStringLocalizer Loc
@implements IDisposable
@using CleanTenant.Application.Features.Catalog.Permissions
@using CleanTenant.Application.Features.Catalog.Readers
@using CleanTenant.Application.Features.Catalog.Roles
@using CleanTenant.ManagementApp.Components.Shared
@using MediatR

<PageTitle>@Loc["Roles.List.PageTitle"]</PageTitle>

@*
    v0.2.10.e.4 — Roles.List.* + Scope.* + Common.* anahtarlarıyla lokalize edildi.
*@

@if (_unauthorized)
{
    <MudAlert Severity="Severity.Warning" Class="my-3">
        @Loc["Roles.List.UnauthorizedSystem"]
    </MudAlert>
}
else if (!_initialized)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    @* v0.2.11.c — Scope dropdown kaldırıldı (System operatörü sadece System scope
       rolleri yönetiyor; dropdown her zaman System default'undaydı). "+ YENİ ROL"
       butonu tablo üstünde sağda. *@
    <div class="d-flex justify-end mb-3">
        <MudButton StartIcon="@Icons.Material.Filled.Add"
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   Href="/system/roles/new">
            @Loc["Roles.List.NewButton"]
        </MudButton>
    </div>

    <DataTable TItem="RoleListItem"
               Items="@_items"
               SearchPlaceholder="@Loc["Roles.List.Search"]"
               SearchableFields="@(row => new[] { row.Name, row.Description ?? "" })"
               Filterable="true">
        <Columns>
            <PropertyColumn T="RoleListItem" TProperty="string" Property="@(r => r.Name)" Title="@Loc["Roles.List.Col.Name"].Value" />
            <PropertyColumn T="RoleListItem" TProperty="string" Property="@(r => r.Description)" Title="@Loc["Roles.List.Col.Description"].Value" />
            <PropertyColumn T="RoleListItem" TProperty="int" Property="@(r => r.PermissionCount)" Title="@Loc["Roles.List.Col.PermCount"].Value" />
            <PropertyColumn T="RoleListItem" TProperty="bool" Property="@(r => r.IsBuiltIn)" Title="@Loc["Roles.List.Col.BuiltIn"].Value">
                <CellTemplate>
                    @if (context.Item.IsBuiltIn)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Info" Size="Size.Small" />
                    }
                </CellTemplate>
            </PropertyColumn>
            <TemplateColumn T="RoleListItem" CellClass="d-flex justify-end" Filterable="false" Sortable="false">
                <CellTemplate>
                    @* Built-in rol için Edit aktif kalır — System kullanıcısı *izinleri*
                       düzenleyebilir; ama isim/açıklama UpdateRoleCommandHandler tarafından
                       reddedilir (RoleEditPage'de bilgilendirme banner'ı görünür). *@
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   title="@(context.Item.IsBuiltIn ? Loc["Roles.List.BuiltInEditTooltip"].Value : Loc["Common.Edit"].Value)"
                                   OnClick="@(() => GoToEdit(context.Item.UrlCode))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   title="@Loc["Common.Delete"]"
                                   OnClick="@(() => DeleteAsync(context.Item))"
                                   Disabled="@context.Item.IsBuiltIn" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </DataTable>
}

@code {
    private bool _unauthorized;
    private bool _initialized;
    private int _scopeLevel = 1;
    private IReadOnlyList<RoleListItem>? _items;
    private IMediator? _mediator;

    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true
            || !string.Equals(user.FindFirst("scope")?.Value, "System", StringComparison.OrdinalIgnoreCase))
        {
            _unauthorized = true;
            _initialized = true;
            return;
        }

        _mediator = HttpContext?.RequestServices.GetService<IMediator>();

        await LoadRolesAsync();
        _initialized = true;
    }

    private async Task LoadRolesAsync()
    {
        try
        {
            _items = await RoleReader.GetRolesByScopeAsync(_scopeLevel);
        }
        catch (Exception ex)
        {
            Snackbar.Add(Loc["Roles.List.LoadError", ex.Message].Value, Severity.Error);
        }
    }

    private void GoToEdit(string urlCode)
    {
        Nav.NavigateTo($"/system/roles/{urlCode}/edit");
    }

    private async Task DeleteAsync(RoleListItem role)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", Loc["Roles.List.DeleteConfirm", role.Name].Value);
        if (!confirmed) return;

        try
        {
            if (_mediator is null) return;
            var command = new DeleteRoleCommand(role.Id);
            await _mediator.Send(command);

            Snackbar.Add(Loc["Roles.List.DeleteSuccess"].Value, Severity.Success);
            await LoadRolesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(Loc["Lookup.ErrorPrefix", ex.Message].Value, Severity.Error);
        }
    }

    public void Dispose()
    {
    }
}
