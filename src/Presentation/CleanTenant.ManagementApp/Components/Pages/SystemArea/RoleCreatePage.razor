@page "/system/roles/new"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject MediatR.IMediator Mediator
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IStringLocalizer Loc
@using CleanTenant.Application.Features.Catalog.Roles
@using CleanTenant.ManagementApp.Components.Shared

<PageTitle>@Loc["Roles.New.PageTitle"]</PageTitle>

@*
    v0.2.10.e.4 — Roles.New.* anahtarlarıyla lokalize edildi.
*@

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

    @if (_unauthorized)
    {
        <MudAlert Severity="Severity.Warning">
            @Loc["Roles.List.UnauthorizedSystem"]
        </MudAlert>
    }
    else
    {
        <MudText Typo="Typo.h5" Class="mb-4">@Loc["Roles.New.Title"]</MudText>

        <RoleForm Model="_model"
                  OnSubmit="@SubmitAsync"
                  IsSubmitting="@_busy"
                  SubmitButtonText="@Loc["Roles.New.SubmitButton"]"
                  CancelHref="/system/roles" />
    }
</MudContainer>

@code {
    private readonly RoleFormModel _model = new();
    private bool _busy;
    private bool _unauthorized;

    private List<BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs =
        [
            new(Loc["Roles.List.Title"].Value, "/system/roles"),
            new(Loc["Roles.New.Title"].Value, null, disabled: true),
        ];

        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _unauthorized = user?.Identity?.IsAuthenticated != true
            || !string.Equals(user.FindFirst("scope")?.Value, "System", StringComparison.OrdinalIgnoreCase);
    }

    private async Task SubmitAsync(RoleFormModel model)
    {
        _busy = true;

        try
        {
            var command = new CreateRoleCommand(model.Name, model.Scope, model.Description);
            var roleId = await Mediator.Send(command);

            Snackbar.Add(Loc["Roles.New.Success"].Value, Severity.Success);
            Nav.NavigateTo("/system/roles");
        }
        catch (Exception ex)
        {
            Snackbar.Add(Loc["Lookup.ErrorPrefix", ex.Message].Value, Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }
}
