@page "/system/roles/new"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject MediatR.IMediator Mediator
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@using CleanTenant.Application.Features.Catalog.Roles
@using CleanTenant.ManagementApp.Components.Shared

<PageTitle>Yeni Rol — Sistem</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

    @if (_unauthorized)
    {
        <MudAlert Severity="Severity.Warning">
            Bu sayfa yalnız Sistem kullanıcıları için. Aktif bağlamınız Sistem değil.
        </MudAlert>
    }
    else
    {
        <MudText Typo="Typo.h5" Class="mb-4">Yeni Rol</MudText>

        <RoleForm Model="_model"
                  OnSubmit="@SubmitAsync"
                  IsSubmitting="@_busy"
                  SubmitButtonText="Rol Oluştur"
                  CancelHref="/system/roles" />
    }
</MudContainer>

@code {
    private readonly RoleFormModel _model = new();
    private bool _busy;
    private bool _unauthorized;

    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Roller", "/system/roles"),
        new("Yeni Rol", null, disabled: true),
    ];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        _unauthorized = !authState.User.IsInRole("SystemUser");
    }

    private async Task SubmitAsync(RoleFormModel model)
    {
        _busy = true;

        try
        {
            var command = new CreateRoleCommand(model.Name, model.Scope, model.Description);
            var roleId = await Mediator.Send(command);

            Snackbar.Add("Rol başarıyla oluşturuldu.", Severity.Success);
            Nav.NavigateTo("/system/roles");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Hata: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }
}
