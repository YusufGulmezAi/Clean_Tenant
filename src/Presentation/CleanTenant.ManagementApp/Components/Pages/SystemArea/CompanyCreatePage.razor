@page "/system/companies/new"

@using CleanTenant.Application.Features.Main.Companies
@using CleanTenant.Application.Features.Catalog.Readers
@using CleanTenant.ManagementApp.Components.Shared
@using MediatR
@using Microsoft.AspNetCore.Components

@inject IMediator Mediator
@inject ITenantCatalogReader TenantReader
@inject NavigationManager Nav
@inject IStringLocalizer Loc

<PageTitle>@Loc["Companies.New.PageTitle"]</PageTitle>

@*
    v0.2.10.e.4 — Companies.New.* anahtarlarıyla lokalize edildi.
*@

<MudContainer MaxWidth="MaxWidth.Small" Class="py-8">
    <MudBreadcrumbs Items="@_breadcrumbs" Class="px-0 mb-4"></MudBreadcrumbs>

    @if (_initialized)
    {
        <MudSelect T="Guid"
                   @bind-Value="_selectedTenantId"
                   Label="@Loc["Companies.New.TenantPicker"]"
                   Variant="Variant.Outlined"
                   Class="mb-4"
                   Required="true"
                   HelperText="@Loc["Companies.New.TenantPicker.Help"].Value">
            @foreach (var tenant in _tenants)
            {
                <MudSelectItem Value="@tenant.Id">@tenant.Name</MudSelectItem>
            }
        </MudSelect>

        <CompanyForm Model="@_model"
                     Mode="@CompanyFormMode.Create"
                     OnValidSubmit="@CreateAsync"
                     IsSubmitting="@_isSubmitting"
                     SubmitButtonText="@Loc["Companies.New.SubmitButton"]"
                     CancelHref="/system/companies" />

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mt-4">@_errorMessage</MudAlert>
        }
    }
    else
    {
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" Class="mb-4" />
        <MudSkeleton SkeletonType="SkeletonType.Text" />
    }
</MudContainer>

@code {
    private List<BreadcrumbItem> _breadcrumbs = [];
    private CompanyFormModel _model = new();
    private IReadOnlyList<TenantListItem> _tenants = [];
    private Guid _selectedTenantId;
    private bool _initialized = false;
    private bool _isSubmitting = false;
    private string _errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs =
        [
            new BreadcrumbItem(Loc["Breadcrumb.Management"].Value, href: "/system"),
            new BreadcrumbItem(Loc["Companies.List.Title"].Value, href: "/system/companies"),
            new BreadcrumbItem(Loc["Companies.New.Title"].Value, href: null, disabled: true),
        ];

        _tenants = await TenantReader.GetAllActiveAsync();
        _model = new CompanyFormModel();
        _initialized = true;
    }

    private async Task CreateAsync()
    {
        _isSubmitting = true;
        _errorMessage = string.Empty;

        try
        {
            if (_selectedTenantId == Guid.Empty)
            {
                _errorMessage = Loc["Companies.New.SelectTenant"].Value;
                _isSubmitting = false;
                return;
            }

            var command = new CreateCompanyCommand(
                TenantId: _selectedTenantId,
                Name: _model.Name,
                LegalName: _model.LegalName,
                Vkn: _model.Vkn,
                Email: _model.Email,
                Phone: _model.Phone);

            var result = await Mediator.Send(command);

            if (result.IsSuccess && result.Value is not null)
            {
                Nav.NavigateTo($"/system/companies/{result.Value.UrlCode}/edit");
            }
            else
            {
                _errorMessage = result.FirstError.Message;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = Loc["Common.UnexpectedError", ex.Message].Value;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
