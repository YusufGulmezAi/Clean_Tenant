@page "/system/tenants"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject ITenantCatalogReader TenantReader
@inject MediatR.IMediator Mediator
@inject AuthenticationStateProvider AuthProvider
@inject PersistentComponentState PersistentState
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject IStringLocalizer Loc
@implements IDisposable
@using CleanTenant.Application.Common.Export
@using CleanTenant.Application.Features.Catalog.Readers
@using CleanTenant.Application.Features.Catalog.Tenants
@using CleanTenant.Domain.Identity.Tenants
@using CleanTenant.ManagementApp.Components.Shared

<PageTitle>@Loc["Tenants.List.PageTitle"]</PageTitle>

@*
    v0.2.4.b.4 — Özet widget'lar (Yönetim / Site / Bağımsız Bölüm sayısı) DataTable
    üstüne eklendi. "Yeni Yönetim" butonu DataTable toolbar'ından çıkarılıp tablonun
    hemen üst satırına sağa taşındı. DataTable Title/Toplam satırı kaldırıldı.

    v0.2.10.e.4 — Tenants.List.* + Common.* anahtarlarıyla lokalize edildi.
    _exportColumns OnInitialized'da Loc ile inşa edilir (artık static değil).
*@

@if (_unauthorized)
{
    <MudAlert Severity="Severity.Warning" Class="my-3">
        @Loc["Tenants.List.UnauthorizedSystem"]
    </MudAlert>
}
else if (!_initialized)
{
    @* ── Yükleme durumu: skeleton widget'lar ──────────────────────────── *@
    <MudGrid Spacing="2" Class="mb-3">
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="3" Class="pa-4" Style="background: var(--mud-palette-primary); border-radius: 8px; height: 100px;">
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="40%" />
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="3" Class="pa-4" Style="background: var(--mud-palette-success); border-radius: 8px; height: 100px;">
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="40%" />
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="3" Class="pa-4" Style="background: var(--mud-palette-info); border-radius: 8px; height: 100px;">
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="40%" />
            </MudPaper>
        </MudItem>
    </MudGrid>
}
else
{
    @* ── Özet widget'lar ──────────────────────────────────────────────── *@
    <MudGrid Spacing="2" Class="mb-3">
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="3" Class="pa-4 d-flex align-center"
                      Style="background: var(--mud-palette-primary); border-radius: 8px;">
                <MudIcon Icon="@Icons.Material.Filled.Domain"
                         Style="font-size: 2.5rem; color: rgba(255,255,255,0.85);" Class="mr-3" />
                <div>
                    <MudText Typo="Typo.h4" Style="color: #fff; font-weight: 700; line-height: 1.2;">
                        @(_items?.Count.ToString() ?? "—")
                    </MudText>
                    <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.8);">
                        @Loc["Tenants.List.Widget.TenantCount"]
                    </MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="3" Class="pa-4 d-flex align-center"
                      Style="background: var(--mud-palette-success); border-radius: 8px;">
                <MudIcon Icon="@Icons.Material.Filled.Apartment"
                         Style="font-size: 2.5rem; color: rgba(255,255,255,0.85);" Class="mr-3" />
                <div>
                    <MudText Typo="Typo.h4" Style="color: #fff; font-weight: 700; line-height: 1.2;">—</MudText>
                    <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.8);">
                        @Loc["Tenants.List.Widget.CompanyCount"]
                    </MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="3" Class="pa-4 d-flex align-center"
                      Style="background: var(--mud-palette-info); border-radius: 8px;">
                <MudIcon Icon="@Icons.Material.Filled.HomeWork"
                         Style="font-size: 2.5rem; color: rgba(255,255,255,0.85);" Class="mr-3" />
                <div>
                    <MudText Typo="Typo.h4" Style="color: #fff; font-weight: 700; line-height: 1.2;">—</MudText>
                    <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.8);">
                        @Loc["Tenants.List.Widget.UnitCount"]
                    </MudText>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* ── Tablo üstü aksiyon satırı ───────────────────────────────────── *@
    <div class="d-flex justify-end mb-2">
        <MudButton StartIcon="@Icons.Material.Filled.Add"
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   Href="/system/tenants/new">
            @Loc["Tenants.List.NewButton"]
        </MudButton>
    </div>

    @* ── Veri tablosu ─────────────────────────────────────────────────── *@
    <DataTable TItem="TenantListItem"
               Items="@_items"
               SearchPlaceholder="@Loc["Tenants.List.Search"]"
               SearchableFields="@(row => new[] { row.Name, row.UrlCode, row.LegalName })"
               ExportColumns="@_exportColumns"
               RowClick="@OnRowClick">
        <Columns>
            <PropertyColumn T="TenantListItem" TProperty="string" Property="@(t => t.Name)" Title="@Loc["Tenants.List.Col.Name"].Value" />
            <PropertyColumn T="TenantListItem" TProperty="string" Property="@(t => t.UrlCode)" Title="@Loc["Tenants.List.Col.UrlCode"].Value" />
            <PropertyColumn T="TenantListItem" TProperty="string" Property="@(t => t.LegalName)" Title="@Loc["Tenants.List.Col.LegalName"].Value" />
            <PropertyColumn T="TenantListItem" TProperty="TenantStatus" Property="@(t => t.Status)" Title="@Loc["Tenants.List.Col.Status"].Value">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small"
                             Color="@(context.Item.Status == TenantStatus.Active ? Color.Success : Color.Default)">
                        @context.Item.Status
                    </MudChip>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn T="TenantListItem" TProperty="BillingTier" Property="@(t => t.BillingTier)" Title="@Loc["Tenants.List.Col.Tier"].Value" />
            <PropertyColumn T="TenantListItem" TProperty="string" Property="@(t => t.LegalIdentityNumber)" Title="@Loc["Tenants.List.Col.Identity"].Value">
                <CellTemplate>
                    <MudText Typo="Typo.body2" Style="font-family:monospace">
                        @context.Item.LegalIdentityType.ToString().ToUpperInvariant(): @context.Item.LegalIdentityNumber
                    </MudText>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn T="TenantListItem" TProperty="string" Property="@(t => t.ProvinceName ?? "")" Title="@Loc["Tenants.List.Col.Province"].Value">
                <CellTemplate>
                    <MudText Typo="Typo.body2">@(context.Item.ProvinceName ?? "—")</MudText>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn T="TenantListItem" TProperty="string" Property="@(t => t.DistrictName ?? "")" Title="@Loc["Tenants.List.Col.District"].Value">
                <CellTemplate>
                    <MudText Typo="Typo.body2">@(context.Item.DistrictName ?? "—")</MudText>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn T="TenantListItem" TProperty="string" Property="@(t => t.NeighborhoodName ?? "")" Title="@Loc["Tenants.List.Col.Neighborhood"].Value">
                <CellTemplate>
                    <MudText Typo="Typo.body2">@(context.Item.NeighborhoodName ?? "—")</MudText>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn T="TenantListItem" TProperty="bool" Property="@(t => t.AllowSystemWriteAccess)" Title="@Loc["Tenants.List.Col.SystemWrite"].Value">
                <CellTemplate>
                    <MudIcon Icon="@(context.Item.AllowSystemWriteAccess ? Icons.Material.Filled.LockOpen : Icons.Material.Filled.Lock)"
                             Color="@(context.Item.AllowSystemWriteAccess ? Color.Success : Color.Warning)"
                             Size="Size.Small" />
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn T="TenantListItem" TProperty="DateOnly?" Property="@(t => t.ContractStartDate)" Title="@Loc["Tenants.List.Col.ContractStart"].Value" Hideable="true">
                <CellTemplate>
                    <MudText Typo="Typo.body2">@(context.Item.ContractStartDate?.ToString("dd.MM.yyyy") ?? "—")</MudText>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn T="TenantListItem" TProperty="DateOnly?" Property="@(t => t.ContractEndDate)" Title="@Loc["Tenants.List.Col.ContractEnd"].Value" Hideable="true">
                <CellTemplate>
                    <MudText Typo="Typo.body2">@(context.Item.ContractEndDate?.ToString("dd.MM.yyyy") ?? "—")</MudText>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn T="TenantListItem" TProperty="int?" Property="@(t => t.TransitionGraceDays)" Title="@Loc["Tenants.List.Col.GraceDays"].Value" Hideable="true">
                <CellTemplate>
                    <MudText Typo="Typo.body2">
                        @(context.Item.TransitionGraceDays.HasValue
                            ? Loc["Tenants.List.Col.GraceDaysFormat", context.Item.TransitionGraceDays.Value].Value
                            : "—")
                    </MudText>
                </CellTemplate>
            </PropertyColumn>
            <TemplateColumn T="TenantListItem" CellClass="d-flex justify-end" Filterable="false" Sortable="false">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Login"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   title="@Loc["Tenants.List.Action.Switch"]"
                                   OnClick="@(() => SwitchToTenantAsync(context.Item.Id))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   title="@Loc["Common.Edit"]"
                                   OnClick="@(() => GoToEdit(context.Item.UrlCode))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   title="@Loc["Common.Delete"]"
                                   OnClick="@(() => DeleteAsync(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </DataTable>
}

@code {
    private const string PersistKey = "systemarea.tenants.list";
    private bool _unauthorized;
    private bool _initialized;
    private IReadOnlyList<TenantListItem>? _items;
    private PersistingComponentStateSubscription _persistSubscription;

    private IReadOnlyList<ExportColumn<TenantListItem>> _exportColumns = [];

    protected override async Task OnInitializedAsync()
    {
        // Export columns'u localize edilmiş başlıklarla inşa et.
        _exportColumns =
        [
            new() { Header = Loc["Tenants.List.Col.Name"].Value, Selector = r => r.Name },
            new() { Header = Loc["Tenants.List.Col.UrlCode"].Value, Selector = r => r.UrlCode },
            new() { Header = Loc["Tenants.List.Col.LegalName"].Value, Selector = r => r.LegalName },
            new() { Header = Loc["Tenants.List.Col.Status"].Value, Selector = r => r.Status.ToString() },
            new() { Header = Loc["Tenants.List.Col.Tier"].Value, Selector = r => r.BillingTier.ToString() },
            new() { Header = Loc["Tenants.List.Col.SystemWrite"].Value, Selector = r =>
                r.AllowSystemWriteAccess ? Loc["Common.SystemWrite.On"].Value : Loc["Common.SystemWrite.Off"].Value },
        ];

        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true
            || !string.Equals(user.FindFirst("scope")?.Value, "System", StringComparison.OrdinalIgnoreCase))
        {
            _unauthorized = true;
            _initialized = true;
            return;
        }

        if (PersistentState.TryTakeFromJson<List<TenantListItem>>(PersistKey, out var cached) && cached is not null)
        {
            _items = cached;
            _initialized = true;
            return;
        }

        _items = await TenantReader.GetAllActiveAsync();
        _initialized = true;

        _persistSubscription = PersistentState.RegisterOnPersisting(() =>
        {
            PersistentState.PersistAsJson(PersistKey, _items);
            return Task.CompletedTask;
        });
    }

    private Task OnRowClick(DataGridRowClickEventArgs<TenantListItem> args)
        => SwitchToTenantAsync(args.Item.Id);

    private async Task SwitchToTenantAsync(Guid tenantId)
    {
        var returnUrl = "/" + Nav.ToBaseRelativePath(Nav.Uri);
        await JS.InvokeVoidAsync(
            "cleantenant.submitTenantSwitch",
            tenantId.ToString(),
            returnUrl,
            string.Empty);
    }

    private void GoToEdit(string urlCode)
        => Nav.NavigateTo($"/system/tenants/{urlCode}/edit");

    private async Task DeleteAsync(TenantListItem tenant)
    {
        var confirm = await DialogService.ShowMessageBox(
            title: Loc["Tenants.List.Delete.Title"].Value,
            markupMessage: new MarkupString(
                Loc["Tenants.List.Delete.Confirm", $"<b>{tenant.Name}</b>"].Value),
            yesText: Loc["Common.Delete"].Value,
            cancelText: Loc["Tenants.List.Delete.Cancel"].Value);

        if (confirm != true) return;

        var result = await Mediator.Send(new DeleteTenantCommand(tenant.Id));
        if (result.IsFailure)
        {
            Snackbar.Add(Loc["Tenants.List.Delete.Failed", result.FirstError.Message].Value, Severity.Error);
            return;
        }

        Snackbar.Add(Loc["Tenants.List.Delete.Success", tenant.Name].Value, Severity.Success);
        _items = await TenantReader.GetAllActiveAsync();
    }

    public void Dispose() => _persistSubscription.Dispose();
}
