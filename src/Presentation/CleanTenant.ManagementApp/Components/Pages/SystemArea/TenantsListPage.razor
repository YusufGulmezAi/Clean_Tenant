@page "/system/tenants"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject ITenantCatalogReader TenantReader
@inject MediatR.IMediator Mediator
@inject AuthenticationStateProvider AuthProvider
@inject PersistentComponentState PersistentState
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@implements IDisposable
@using CleanTenant.Application.Common.Export
@using CleanTenant.Application.Features.Catalog.Readers
@using CleanTenant.Application.Features.Catalog.Tenants
@using CleanTenant.Domain.Identity.Tenants
@using CleanTenant.ManagementApp.Components.Shared

<PageTitle>Yönetimler — Sistem</PageTitle>

@*
    v0.2.4.b.4 — Özet widget'lar (Yönetim / Site / Bağımsız Bölüm sayısı) DataTable
    üstüne eklendi. "Yeni Yönetim" butonu DataTable toolbar'ından çıkarılıp tablonun
    hemen üst satırına sağa taşındı. DataTable Title/Toplam satırı kaldırıldı.
*@

@if (_unauthorized)
{
    <MudAlert Severity="Severity.Warning" Class="my-3">
        Bu sayfa yalnız Sistem kullanıcıları için. Aktif bağlamınız Sistem değil.
    </MudAlert>
}
else if (!_initialized)
{
    @* ── Yükleme durumu: skeleton widget'lar ──────────────────────────── *@
    <MudGrid Spacing="2" Class="mb-3">
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="3" Class="pa-4" Style="background: var(--mud-palette-primary); border-radius: 8px; height: 100px;">
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="40%" />
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="3" Class="pa-4" Style="background: var(--mud-palette-success); border-radius: 8px; height: 100px;">
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="40%" />
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="3" Class="pa-4" Style="background: var(--mud-palette-info); border-radius: 8px; height: 100px;">
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="40%" />
            </MudPaper>
        </MudItem>
    </MudGrid>
}
else
{
    @* ── Özet widget'lar ──────────────────────────────────────────────── *@
    <MudGrid Spacing="2" Class="mb-3">
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="3" Class="pa-4 d-flex align-center"
                      Style="background: var(--mud-palette-primary); border-radius: 8px;">
                <MudIcon Icon="@Icons.Material.Filled.Domain"
                         Style="font-size: 2.5rem; color: rgba(255,255,255,0.85);" Class="mr-3" />
                <div>
                    <MudText Typo="Typo.h4" Style="color: #fff; font-weight: 700; line-height: 1.2;">
                        @(_items?.Count.ToString() ?? "—")
                    </MudText>
                    <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.8);">
                        Mevcut Yönetim Sayısı
                    </MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="3" Class="pa-4 d-flex align-center"
                      Style="background: var(--mud-palette-success); border-radius: 8px;">
                <MudIcon Icon="@Icons.Material.Filled.Apartment"
                         Style="font-size: 2.5rem; color: rgba(255,255,255,0.85);" Class="mr-3" />
                <div>
                    <MudText Typo="Typo.h4" Style="color: #fff; font-weight: 700; line-height: 1.2;">—</MudText>
                    <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.8);">
                        Mevcut Site Sayısı
                    </MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="3" Class="pa-4 d-flex align-center"
                      Style="background: var(--mud-palette-info); border-radius: 8px;">
                <MudIcon Icon="@Icons.Material.Filled.HomeWork"
                         Style="font-size: 2.5rem; color: rgba(255,255,255,0.85);" Class="mr-3" />
                <div>
                    <MudText Typo="Typo.h4" Style="color: #fff; font-weight: 700; line-height: 1.2;">—</MudText>
                    <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.8);">
                        Mevcut Bağımsız Bölüm Sayısı
                    </MudText>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* ── Tablo üstü aksiyon satırı ───────────────────────────────────── *@
    <div class="d-flex justify-end mb-2">
        <MudButton StartIcon="@Icons.Material.Filled.Add"
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   Href="/system/tenants/new">
            Yeni Yönetim
        </MudButton>
    </div>

    @* ── Veri tablosu ─────────────────────────────────────────────────── *@
    <DataTable TItem="TenantListItem"
               Items="@_items"
               SearchPlaceholder="Yönetim ara…"
               SearchableFields="@(row => new[] { row.Name, row.UrlCode, row.LegalName })"
               ExportColumns="@_exportColumns"
               RowClick="@OnRowClick">
        <Columns>
            <PropertyColumn T="TenantListItem" TProperty="string" Property="@(t => t.Name)" Title="Yönetim Adı" />
            <PropertyColumn T="TenantListItem" TProperty="string" Property="@(t => t.UrlCode)" Title="URL Kodu" />
            <PropertyColumn T="TenantListItem" TProperty="string" Property="@(t => t.LegalName)" Title="Yasal Ad" />
            <PropertyColumn T="TenantListItem" TProperty="TenantStatus" Property="@(t => t.Status)" Title="Durum">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small"
                             Color="@(context.Item.Status == TenantStatus.Active ? Color.Success : Color.Default)">
                        @context.Item.Status
                    </MudChip>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn T="TenantListItem" TProperty="BillingTier" Property="@(t => t.BillingTier)" Title="Katman" />
            <PropertyColumn T="TenantListItem" TProperty="bool" Property="@(t => t.AllowSystemWriteAccess)" Title="Sistem Yazma">
                <CellTemplate>
                    <MudIcon Icon="@(context.Item.AllowSystemWriteAccess ? Icons.Material.Filled.LockOpen : Icons.Material.Filled.Lock)"
                             Color="@(context.Item.AllowSystemWriteAccess ? Color.Success : Color.Warning)"
                             Size="Size.Small" />
                </CellTemplate>
            </PropertyColumn>
            <TemplateColumn T="TenantListItem" CellClass="d-flex justify-end" Filterable="false" Sortable="false">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Login"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   title="Bu Yönetim bağlamına geç"
                                   OnClick="@(() => SwitchToTenantAsync(context.Item.Id))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   title="Düzenle"
                                   OnClick="@(() => GoToEdit(context.Item.Id))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   title="Sil"
                                   OnClick="@(() => DeleteAsync(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </DataTable>
}

@code {
    private const string PersistKey = "systemarea.tenants.list";
    private bool _unauthorized;
    private bool _initialized;
    private IReadOnlyList<TenantListItem>? _items;
    private PersistingComponentStateSubscription _persistSubscription;

    private static readonly IReadOnlyList<ExportColumn<TenantListItem>> _exportColumns =
    [
        new() { Header = "Yönetim Adı", Selector = r => r.Name },
        new() { Header = "URL Kodu", Selector = r => r.UrlCode },
        new() { Header = "Yasal Ad", Selector = r => r.LegalName },
        new() { Header = "Durum", Selector = r => r.Status.ToString() },
        new() { Header = "Katman", Selector = r => r.BillingTier.ToString() },
        new() { Header = "Sistem Yazma", Selector = r => r.AllowSystemWriteAccess ? "Açık" : "Kapalı" },
    ];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true
            || !string.Equals(user.FindFirst("scope")?.Value, "System", StringComparison.OrdinalIgnoreCase))
        {
            _unauthorized = true;
            _initialized = true;
            return;
        }

        if (PersistentState.TryTakeFromJson<List<TenantListItem>>(PersistKey, out var cached) && cached is not null)
        {
            _items = cached;
            _initialized = true;
            return;
        }

        _items = await TenantReader.GetAllActiveAsync();
        _initialized = true;

        _persistSubscription = PersistentState.RegisterOnPersisting(() =>
        {
            PersistentState.PersistAsJson(PersistKey, _items);
            return Task.CompletedTask;
        });
    }

    private Task OnRowClick(DataGridRowClickEventArgs<TenantListItem> args)
        => SwitchToTenantAsync(args.Item.Id);

    private async Task SwitchToTenantAsync(Guid tenantId)
    {
        var returnUrl = "/" + Nav.ToBaseRelativePath(Nav.Uri);
        await JS.InvokeVoidAsync(
            "cleantenant.submitTenantSwitch",
            tenantId.ToString(),
            returnUrl,
            string.Empty);
    }

    private void GoToEdit(Guid tenantId)
        => Nav.NavigateTo($"/system/tenants/{tenantId}/edit");

    private async Task DeleteAsync(TenantListItem tenant)
    {
        var confirm = await DialogService.ShowMessageBox(
            title: "Yönetim Sil",
            markupMessage: new MarkupString(
                $"<b>{tenant.Name}</b> Yönetim'i silinecek (soft delete). " +
                "Tüm kullanıcı rol atamaları pasif olur. Devam edilsin mi?"),
            yesText: "Sil",
            cancelText: "Vazgeç");

        if (confirm != true) return;

        var result = await Mediator.Send(new DeleteTenantCommand(tenant.Id));
        if (result.IsFailure)
        {
            Snackbar.Add($"Silme başarısız: {result.FirstError.Message}", Severity.Error);
            return;
        }

        Snackbar.Add($"Yönetim silindi: {tenant.Name}", Severity.Success);
        _items = await TenantReader.GetAllActiveAsync();
    }

    public void Dispose() => _persistSubscription.Dispose();
}
