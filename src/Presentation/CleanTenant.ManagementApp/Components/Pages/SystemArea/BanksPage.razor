@page "/system/banks"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject ILookUpCatalogReader LookUpReader
@inject MediatR.IMediator Mediator
@inject AuthenticationStateProvider AuthProvider
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IStringLocalizer Loc
@using CleanTenant.Application.Features.Catalog.Readers
@using CleanTenant.Application.Features.Catalog.LookUp.Banks

<PageTitle>@Loc["Banks.PageTitle"]</PageTitle>

@*
    v0.2.10.e.4 — Banks.* anahtarlarıyla lokalize edildi.
*@

@if (_unauthorized)
{
    <MudAlert Severity="Severity.Warning" Class="my-3">
        @Loc["Banks.UnauthorizedSystem"]
    </MudAlert>
}
else if (!_initialized)
{
    <MudText Typo="Typo.h6" Class="my-3">@Loc["Banks.Loading"]</MudText>
}
else
{
    <div class="d-flex justify-end mb-2">
        <MudButton StartIcon="@(_showForm ? Icons.Material.Filled.Close : Icons.Material.Filled.Add)"
                   Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="@(() => ToggleFormAsync())">
            @(_showForm ? Loc["Common.Cancel"].Value : Loc["Banks.NewButton"].Value)
        </MudButton>
    </div>

    @if (_showForm)
    {
        <MudPaper Class="pa-4 mb-4" Elevation="1">
            <MudForm @ref="_bankForm" Model="@_formModel" Validate="true">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_formModel.FullName"
                                      Label="@Loc["Banks.FullName"]"
                                      For="@(() => _formModel.FullName)"
                                      MaxLength="200"
                                      Required="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_formModel.ShortName"
                                      Label="@Loc["Banks.ShortName"]"
                                      For="@(() => _formModel.ShortName)"
                                      MaxLength="30"
                                      Required="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_formModel.EftCode"
                                      Label="@Loc["Banks.EftCode"]"
                                      For="@(() => _formModel.EftCode)"
                                      MaxLength="10" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudSwitch T="bool" @bind-Checked="_formModel.HasVirtualPosIntegration"
                                   Label="@Loc["Banks.VirtualPos"]"
                                   Color="Color.Primary" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudSwitch T="bool" @bind-Checked="_formModel.HasCorporateCollectionIntegration"
                                   Label="@Loc["Banks.CorporateCollection"]"
                                   Color="Color.Primary" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudSwitch T="bool" @bind-Checked="_formModel.IsActive"
                                   Label="@Loc["Banks.IsActive"]"
                                   Color="Color.Success" />
                    </MudItem>
                </MudGrid>
                <div class="d-flex gap-2 mt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@SubmitBankAsync">
                        @(_editingId.HasValue ? Loc["Banks.Update"].Value : Loc["Banks.Add"].Value)
                    </MudButton>
                    <MudButton Variant="Variant.Text" OnClick="@(() => ToggleFormAsync())">
                        @Loc["Common.Cancel"]
                    </MudButton>
                </div>
            </MudForm>
        </MudPaper>
    }

    <MudDataGrid Items="@_banks" Hover="true" Striped="true" Bordered="true">
        <Columns>
            <PropertyColumn Property="@(x => x.FullName)" Title="@Loc["Banks.FullName"].Value" />
            <PropertyColumn Property="@(x => x.ShortName)" Title="@Loc["Banks.ShortName"].Value" />
            <PropertyColumn Property="@(x => x.EftCode)" Title="@Loc["Banks.EftCode"].Value">
                <CellTemplate>
                    <MudText Typo="Typo.body2" Style="font-family:monospace">@(context.Item.EftCode ?? "—")</MudText>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="@(x => x.HasVirtualPosIntegration)" Title="@Loc["Banks.VirtualPos"].Value">
                <CellTemplate>
                    @if (context.Item.HasVirtualPosIntegration)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info">@Loc["Banks.VirtualPos"]</MudChip>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Tertiary">—</MudText>
                    }
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="@(x => x.HasCorporateCollectionIntegration)" Title="@Loc["Banks.CorporateCollection"].Value">
                <CellTemplate>
                    @if (context.Item.HasCorporateCollectionIntegration)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info">@Loc["Banks.CorporateCollection"]</MudChip>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Tertiary">—</MudText>
                    }
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="@(x => x.IsActive)" Title="@Loc["Banks.Col.IsActive"].Value">
                <CellTemplate>
                    @if (context.Item.IsActive)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">@Loc["Banks.Active"]</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default">@Loc["Banks.Passive"]</MudChip>
                    }
                </CellTemplate>
            </PropertyColumn>
            <TemplateColumn CellClass="d-flex justify-end" Filterable="false" Sortable="false">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Default"
                                   OnClick="@(() => EditBankAsync(context.Item.Id))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => DeleteBankAsync(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>
}

@code {
    private class BankFormModel
    {
        public string FullName { get; set; } = string.Empty;
        public string ShortName { get; set; } = string.Empty;
        public string? EftCode { get; set; }
        public bool HasVirtualPosIntegration { get; set; }
        public bool HasCorporateCollectionIntegration { get; set; }
        public bool IsActive { get; set; } = true;
    }

    private bool _unauthorized;
    private bool _initialized;
    private bool _showForm;
    private Guid? _editingId;
    private IReadOnlyList<BankListItem> _banks = [];
    private MudForm? _bankForm;
    private BankFormModel _formModel = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true
            || !string.Equals(user.FindFirst("scope")?.Value, "System", StringComparison.OrdinalIgnoreCase))
        {
            _unauthorized = true;
            _initialized = true;
            return;
        }

        await LoadBanksAsync();
        _initialized = true;
    }

    private async Task LoadBanksAsync()
    {
        _banks = await LookUpReader.GetBanksAsync();
    }

    private void ToggleFormAsync()
    {
        _showForm = !_showForm;
        if (!_showForm)
        {
            ResetForm();
        }
    }

    private void ResetForm()
    {
        _formModel = new();
        _editingId = null;
    }

    private async Task EditBankAsync(Guid bankId)
    {
        var bank = await LookUpReader.GetBankDetailAsync(bankId);
        if (bank is null)
        {
            Snackbar.Add(Loc["Banks.NotFound"].Value, Severity.Error);
            return;
        }

        _editingId = bankId;
        _formModel = new()
        {
            FullName = bank.FullName,
            ShortName = bank.ShortName,
            EftCode = bank.EftCode,
            HasVirtualPosIntegration = bank.HasVirtualPosIntegration,
            HasCorporateCollectionIntegration = bank.HasCorporateCollectionIntegration,
            IsActive = bank.IsActive,
        };
        _showForm = true;
        StateHasChanged();
    }

    private async Task SubmitBankAsync()
    {
        if (_bankForm is null) return;
        await _bankForm.Validate();
        if (!_bankForm.IsValid) return;

        if (_editingId.HasValue)
        {
            var result = await Mediator.Send(new UpdateBankCommand(
                _editingId.Value,
                _formModel.FullName,
                _formModel.ShortName,
                _formModel.EftCode,
                _formModel.HasVirtualPosIntegration,
                _formModel.HasCorporateCollectionIntegration,
                _formModel.IsActive
            ));

            if (result.IsFailure)
            {
                Snackbar.Add(Loc["Banks.Update.Failed", result.FirstError.Message].Value, Severity.Error);
                return;
            }

            Snackbar.Add(Loc["Banks.UpdateSuccess"].Value, Severity.Success);
        }
        else
        {
            var result = await Mediator.Send(new CreateBankCommand(
                _formModel.FullName,
                _formModel.ShortName,
                _formModel.EftCode,
                _formModel.HasVirtualPosIntegration,
                _formModel.HasCorporateCollectionIntegration,
                _formModel.IsActive
            ));

            if (result.IsFailure)
            {
                Snackbar.Add(Loc["Banks.Add.Failed", result.FirstError.Message].Value, Severity.Error);
                return;
            }

            Snackbar.Add(Loc["Banks.AddSuccess"].Value, Severity.Success);
        }

        ResetForm();
        _showForm = false;
        await LoadBanksAsync();
    }

    private async Task DeleteBankAsync(BankListItem bank)
    {
        var confirm = await DialogService.ShowMessageBox(
            Loc["Banks.Delete.Title"].Value,
            Loc["Banks.Delete.Confirm", $"<b>{bank.FullName}</b>"].Value,
            yesText: Loc["Common.Delete"].Value,
            cancelText: Loc["Common.Discard"].Value);
        if (confirm != true) return;

        var result = await Mediator.Send(new DeleteBankCommand(bank.Id));
        if (result.IsFailure)
        {
            Snackbar.Add(Loc["Banks.Delete.Failed", result.FirstError.Message].Value, Severity.Error);
            return;
        }

        Snackbar.Add(Loc["Banks.DeleteSuccess"].Value, Severity.Success);
        await LoadBanksAsync();
    }
}
