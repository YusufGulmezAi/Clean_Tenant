@page "/users"
@page "/system/users"
@page "/tenant/users"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject NavigationManager Nav

@*
    v0.2.13.b — Kullanıcı yönetimi birleşik "Erişim Yönetimi" (/access) sayfasına
    taşındı. Bu eski route'lar (/users, /system/users, /tenant/users) artık /access'e
    yönlendirir. /access ayrı bir sayfadır; sonsuz döngü oluşmaz.
*@

@code {
    protected override void OnInitialized()
    {
        Nav.NavigateTo("/access", forceLoad: false, replace: true);
    }
}
