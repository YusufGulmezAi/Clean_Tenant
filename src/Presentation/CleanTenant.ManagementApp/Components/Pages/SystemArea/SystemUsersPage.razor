@page "/users"
@page "/system/users"
@page "/tenant/users"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject AuthenticationStateProvider AuthProvider
@inject IStringLocalizer Loc
@using CleanTenant.ManagementApp.Components.Shared
@using CleanTenant.SharedKernel.Context

@*
    Kullanıcı yönetim sayfası — System, Tenant ve Company scope için ortak.
    Oturum claim'lerinden scope + tenantId + companyId okunur; UserListPanel
    doğru parametrelerle çağrılır.

    v0.2.12 — System + Tenant scope.
    v0.2.13 — /users birleşik route + Company scope desteği.
*@

<PageTitle>@Loc["SystemUsers.PageTitle"]</PageTitle>

@if (_unauthorized)
{
    <MudAlert Severity="Severity.Warning" Class="my-3">
        @Loc["SystemUsers.Unauthorized"]
    </MudAlert>
}
else if (_scope == ScopeLevel.System)
{
    <MudText Typo="Typo.h5" Class="mb-4">@Loc["SystemUsers.PageTitle"]</MudText>
    <UserListPanel Scope="ScopeLevel.System" />
}
else if (_scope == ScopeLevel.Tenant && _tenantId.HasValue)
{
    <MudText Typo="Typo.h5" Class="mb-4">@Loc["TenantUsers.PageTitle"]</MudText>
    <UserListPanel Scope="ScopeLevel.Tenant" TenantId="@_tenantId" />
}
else if (_scope == ScopeLevel.Company && _tenantId.HasValue && _companyId.HasValue)
{
    <MudText Typo="Typo.h5" Class="mb-4">@Loc["CompanyUsers.PageTitle"]</MudText>
    <UserListPanel Scope="ScopeLevel.Company" TenantId="@_tenantId" CompanyId="@_companyId" />
}

@code {
    private ScopeLevel? _scope;
    private Guid? _tenantId;
    private Guid? _companyId;
    private bool _unauthorized;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user?.Identity?.IsAuthenticated != true)
        {
            _unauthorized = true;
            return;
        }

        var scopeClaim = user.FindFirst("scope")?.Value;
        _scope = scopeClaim switch
        {
            "System"  => ScopeLevel.System,
            "Tenant"  => ScopeLevel.Tenant,
            "Company" => ScopeLevel.Company,
            _         => null,
        };

        if (_scope is null)
        {
            _unauthorized = true;
            return;
        }

        if (_scope is ScopeLevel.Tenant or ScopeLevel.Company)
        {
            if (user.FindFirst("tenant_id") is { Value: var tid }
                && Guid.TryParseExact(tid, "N", out var tenantGuid))
            {
                _tenantId = tenantGuid;
            }
            else
            {
                _unauthorized = true;
                return;
            }
        }

        if (_scope == ScopeLevel.Company)
        {
            if (user.FindFirst("company_id") is { Value: var cid }
                && Guid.TryParseExact(cid, "N", out var companyGuid))
            {
                _companyId = companyGuid;
            }
            else
            {
                _unauthorized = true;
            }
        }
    }
}
