@page "/system/audit"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject MediatR.IMediator Mediator
@inject AuthenticationStateProvider AuthProvider
@inject ISnackbar Snackbar
@inject IMainCatalogReader CompanyReader
@inject IStringLocalizer Loc
@using CleanTenant.Application.Features.System.Audit
@using CleanTenant.Application.Features.Main.Readers
@using CleanTenant.Domain.Auditing
@using MudBlazor
@using System.Text.Json
@using System.Globalization

<PageTitle>@Loc["Audit.PageTitle"]</PageTitle>

@*
    v0.2.10.e.4 — Audit.* anahtarlarıyla lokalize edildi. ActionLabel switch
    metodu Loc kullanır; bu yüzden artık static değil — instance method.
*@

@if (_unauthorized)
{
    <MudAlert Severity="Severity.Warning" Class="my-3">
        @Loc["Audit.UnauthorizedSystem"]
    </MudAlert>
}
else
{
    <MudText Typo="Typo.h5" Class="mb-3">@Loc["Audit.Title"]</MudText>

    @* ── Filtre Paneli ────────────────────────────────────────────── *@
    <MudExpansionPanels Class="mb-3">
        <MudExpansionPanel Text="@Loc["Audit.Filter.Title"].Value" Icon="@Icons.Material.Filled.FilterList" Expanded="true">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6" md="3">
                    <MudTextField @bind-Value="_filterDateFromStr"
                                  Label="@Loc["Audit.Filter.DateFrom"]"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Placeholder="@Loc["Audit.Filter.DateFormat"].Value" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudTextField @bind-Value="_filterDateToStr"
                                  Label="@Loc["Audit.Filter.DateTo"]"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Placeholder="@Loc["Audit.Filter.DateFormat"].Value" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudAutocomplete T="string"
                                     @bind-Value="_filterUserFullName"
                                     SearchFunc="SearchUserNames"
                                     Label="@Loc["Audit.Filter.User"]"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Clearable="true"
                                     ResetValueOnEmptyText="true"
                                     Immediate="true"
                                     CoerceText="true"
                                     CoerceValue="false" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudAutocomplete T="string"
                                     @bind-Value="_filterEntityType"
                                     SearchFunc="SearchEntityTypes"
                                     Label="@Loc["Audit.Filter.EntityType"]"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Clearable="true"
                                     ResetValueOnEmptyText="true"
                                     Immediate="true"
                                     CoerceText="true"
                                     CoerceValue="false" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="AuditAction?" @bind-Value="_filterAction"
                               Label="@Loc["Audit.Filter.Action"]"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true">
                        <MudSelectItem T="AuditAction?" Value="null">@Loc["Audit.Action.All"]</MudSelectItem>
                        <MudSelectItem T="AuditAction?" Value="AuditAction.Create">@Loc["Audit.Action.Insert"]</MudSelectItem>
                        <MudSelectItem T="AuditAction?" Value="AuditAction.Update">@Loc["Audit.Action.Update"]</MudSelectItem>
                        <MudSelectItem T="AuditAction?" Value="AuditAction.Delete">@Loc["Audit.Action.Delete"]</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudAutocomplete T="string"
                                     @bind-Value="_filterTenantName"
                                     SearchFunc="SearchTenantNames"
                                     Label="@Loc["Audit.Filter.Tenant"]"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Clearable="true"
                                     ResetValueOnEmptyText="true"
                                     Immediate="true"
                                     CoerceText="true"
                                     CoerceValue="false" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudAutocomplete T="string"
                                     @bind-Value="_filterCompanyName"
                                     SearchFunc="SearchCompanyNames"
                                     Label="@Loc["Audit.Filter.Company"]"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Clearable="true"
                                     ResetValueOnEmptyText="true"
                                     Immediate="true"
                                     CoerceText="true"
                                     CoerceValue="false" />
                </MudItem>
                <MudItem xs="12" Class="d-flex gap-2 justify-end">
                    <MudButton Variant="Variant.Outlined" OnClick="ResetFilters">@Loc["Audit.Filter.Clear"]</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Search"
                               OnClick="@(() => LoadPageAsync(0))">
                        @Loc["Audit.Filter.Search"]
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudExpansionPanel>
    </MudExpansionPanels>

    @* ── Tablo ────────────────────────────────────────────────────── *@
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" />
    }

    <MudDataGrid T="AuditListItem"
                 Items="@_items"
                 Filterable="false"
                 SortMode="SortMode.None"
                 Hover="true"
                 Dense="true"
                 ShowColumnOptions="true"
                 RowClick="@OnRowClick">
        <Columns>
            <PropertyColumn T="AuditListItem" TProperty="DateTimeOffset" Property="@(e => e.Timestamp)" Title="@Loc["Audit.Col.DateTime"].Value">
                <CellTemplate>
                    <MudText Typo="Typo.body2">@context.Item.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</MudText>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn T="AuditListItem" TProperty="string" Property="@(e => e.EntityType)" Title="@Loc["Audit.Col.EntityType"].Value" Hideable="true" />
            <PropertyColumn T="AuditListItem" TProperty="Guid" Property="@(e => e.EntityId)" Title="@Loc["Audit.Col.EntityId"].Value" Hideable="true">
                <CellTemplate>
                    <MudText Typo="Typo.caption" Style="font-family:monospace">@context.Item.EntityId.ToString("D")[..8]…</MudText>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn T="AuditListItem" TProperty="AuditAction" Property="@(e => e.Action)" Title="@Loc["Audit.Col.Action"].Value" Hideable="true">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small" Color="@ActionColor(context.Item.Action)">
                        @ActionLabel(context.Item.Action)
                    </MudChip>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn T="AuditListItem" TProperty="string" Property="@(e => e.UserFullName ?? "")" Title="@Loc["Audit.Col.User"].Value" Hideable="true">
                <CellTemplate>
                    <MudText Typo="Typo.body2">@(context.Item.UserFullName ?? context.Item.UserEmail ?? "—")</MudText>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn T="AuditListItem" TProperty="string" Property="@(e => e.TenantName ?? "")" Title="@Loc["Audit.Col.Tenant"].Value" Hideable="true">
                <CellTemplate>
                    <MudText Typo="Typo.body2">@(context.Item.TenantName ?? "—")</MudText>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn T="AuditListItem" TProperty="Guid?" Property="@(e => e.CompanyId)" Title="@Loc["Audit.Filter.Company"].Value" Hideable="true" Hidden="false">
                <CellTemplate>
                    <MudText Typo="Typo.caption" Style="font-family:monospace">
                        @(context.Item.CompanyId.HasValue
                            ? (_companyNameMap.TryGetValue(context.Item.CompanyId.Value, out var cname) ? cname : context.Item.CompanyId.Value.ToString("D")[..8] + "…")
                            : "—")
                    </MudText>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn T="AuditListItem" TProperty="string" Property="@(e => e.ChangesJson)" Title="@Loc["Audit.Col.Changes"].Value" Hideable="true" Hidden="false">
                <CellTemplate>
                    <MudText Typo="Typo.caption" Style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                        @context.Item.ChangesJson
                    </MudText>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn T="AuditListItem" TProperty="string" Property="@(e => e.IpAddress ?? "")" Title="@Loc["Audit.Col.IpAddress"].Value" Hideable="true" Hidden="true" />
            <PropertyColumn T="AuditListItem" TProperty="string" Property="@(e => e.BrowserName ?? "")" Title="@Loc["Audit.Col.Browser"].Value" Hideable="true" Hidden="true" />
            <PropertyColumn T="AuditListItem" TProperty="string" Property="@(e => e.OperatingSystem ?? "")" Title="@Loc["Audit.Col.Os"].Value" Hideable="true" Hidden="true" />
            <PropertyColumn T="AuditListItem" TProperty="string" Property="@(e => e.RequestPath ?? "")" Title="@Loc["Audit.Col.Endpoint"].Value" Hideable="true" Hidden="true" />
        </Columns>
    </MudDataGrid>

    @* ── Sayfalama ────────────────────────────────────────────────── *@
    <div class="d-flex justify-center align-center mt-3 gap-3">
        <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                       Disabled="@(_currentPage == 0 || _loading)"
                       OnClick="@(() => LoadPageAsync(_currentPage - 1))" />
        <MudText Typo="Typo.body2">
            @Loc["Audit.Pagination", _currentPage + 1, TotalPages, _totalCount]
        </MudText>
        <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                       Disabled="@(_currentPage >= TotalPages - 1 || _loading)"
                       OnClick="@(() => LoadPageAsync(_currentPage + 1))" />
    </div>

    @* ── Detay Drawer — Temporary: içeriği kaydırmaz, üstte açılır ── *@
    <MudDrawer @bind-Open="_drawerOpen"
               Anchor="Anchor.Right"
               Variant="DrawerVariant.Temporary"
               Width="540px"
               Elevation="4">
        @if (_selected is not null)
        {
            <MudDrawerHeader Style="border-bottom:1px solid rgba(0,0,0,0.12)">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="width:100%">
                    <MudText Typo="Typo.h6">@Loc["Audit.Detail.Title"]</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _drawerOpen = false)" />
                </MudStack>
            </MudDrawerHeader>
            <MudContainer Class="pa-4" Style="overflow-y:auto">
                <MudGrid Spacing="2">
                    <MudItem xs="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc["Audit.Detail.Date"]</MudText>
                        <MudText>@_selected.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</MudText>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc["Audit.Col.Action"]</MudText>
                        <MudChip T="string" Size="Size.Small" Color="@ActionColor(_selected.Action)">@ActionLabel(_selected.Action)</MudChip>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc["Audit.Col.EntityType"]</MudText>
                        <MudText>@_selected.EntityType</MudText>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc["Audit.Col.EntityId"]</MudText>
                        <MudText Style="font-family:monospace;font-size:0.75rem">@_selected.EntityId</MudText>
                    </MudItem>
                    <MudItem xs="12"><MudDivider /></MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc["Audit.Col.User"]</MudText>
                        <MudText>@(_selected.UserFullName ?? "—")</MudText>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc["Audit.Detail.Email"]</MudText>
                        <MudText>@(_selected.UserEmail ?? "—")</MudText>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc["Audit.Col.Tenant"]</MudText>
                        <MudText>@(_selected.TenantName ?? "—")</MudText>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc["Audit.Detail.Scope"]</MudText>
                        <MudText>@(_selected.ScopeLevel ?? "—")</MudText>
                    </MudItem>
                    <MudItem xs="12">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc["Audit.Filter.Company"]</MudText>
                        <MudText Style="font-family:monospace;font-size:0.75rem">
                            @if (_selected.CompanyId.HasValue)
                            {
                                if (_companyNameMap.TryGetValue(_selected.CompanyId.Value, out var cn))
                                {
                                    @($"{cn}  ({_selected.CompanyId.Value})")
                                }
                                else
                                {
                                    @(_selected.CompanyId.Value.ToString())
                                }
                            }
                            else
                            {
                                @("—")
                            }
                        </MudText>
                    </MudItem>
                    <MudItem xs="12"><MudDivider /></MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc["Audit.Detail.Ip"]</MudText>
                        <MudText>@(_selected.IpAddress ?? "—")</MudText>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc["Audit.Col.Browser"]</MudText>
                        <MudText>@(_selected.BrowserName ?? "—")</MudText>
                    </MudItem>
                    <MudItem xs="12">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc["Audit.Col.Endpoint"]</MudText>
                        <MudText Style="font-family:monospace;font-size:0.75rem">@(_selected.RequestPath ?? "—")</MudText>
                    </MudItem>
                    <MudItem xs="12"><MudDivider /></MudItem>
                    <MudItem xs="12">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc["Audit.Detail.Changes"]</MudText>
                        <MudPaper Elevation="0" Class="pa-2 mt-1" Style="background:#f5f5f5;border-radius:4px;overflow-x:auto;max-height:400px;overflow-y:auto">
                            <pre style="font-size:0.75rem;margin:0;white-space:pre-wrap;word-break:break-all">@FormatJson(_selected.ChangesJson)</pre>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudContainer>
        }
    </MudDrawer>
}

@code {
    private bool _unauthorized;
    private bool _loading;
    private bool _drawerOpen;
    private int _currentPage;
    private int _totalCount;
    private IReadOnlyList<AuditListItem> _items = [];
    private AuditListItem? _selected;

    // Filtre state
    private string? _filterDateFromStr;
    private string? _filterDateToStr;
    private string? _filterUserFullName;
    private string? _filterEntityType;
    private AuditAction? _filterAction;
    private string? _filterTenantName;
    private string? _filterCompanyName;

    // AutoComplete kaynakları — sayfa ilk yüklendiğinde DB'den distinct çekilir
    // (v0.2.11.f); kullanıcının görmediği kayıtlardaki değerleri de aratabilir.
    private AuditFilterOptions? _filterOptions;

    // Katalog'dan yüklenen site listesi (Id → Name)
    private IReadOnlyList<CompanyListItem> _allCompanies = [];
    private Dictionary<Guid, string> _companyNameMap = [];

    private int PageSize => 50;
    private int TotalPages => (int)Math.Ceiling(_totalCount / (double)PageSize);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true
            || !string.Equals(user.FindFirst("scope")?.Value, "System", StringComparison.OrdinalIgnoreCase))
        {
            _unauthorized = true;
            return;
        }

        _allCompanies = await CompanyReader.GetAllGlobalAsync();
        _companyNameMap = _allCompanies.ToDictionary(c => c.Id, c => c.Name);

        // v0.2.11.f — Autocomplete kaynaklarını DB'den distinct çek (tek seferlik).
        _filterOptions = await Mediator.Send(new GetAuditFilterOptionsQuery());

        // v0.2.11.f — Tablo ilk açılışta BOŞ kalır; kullanıcı filtre seçip
        // "Ara" butonuna basınca LoadPageAsync(0) tetiklenir.
    }

    private async Task LoadPageAsync(int page)
    {
        _loading = true;
        _currentPage = page;

        try
        {
            var selectedCompanyId = !string.IsNullOrEmpty(_filterCompanyName)
                ? _allCompanies.FirstOrDefault(c => c.Name == _filterCompanyName)?.Id
                : (Guid?)null;

            var filter = new AuditFilter(
                ParseDateFilter(_filterDateFromStr),
                ParseDateFilter(_filterDateToStr, endOfDay: true),
                _filterUserFullName,
                _filterEntityType,
                _filterAction,
                _filterTenantName,
                selectedCompanyId,
                page,
                PageSize);

            var result = await Mediator.Send(new GetAuditEntriesQuery(filter));
            _items = result.Items;
            _totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            Snackbar.Add(Loc["Audit.LoadError", ex.Message].Value, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnRowClick(DataGridRowClickEventArgs<AuditListItem> args)
    {
        _selected = args.Item;
        _drawerOpen = true;
    }

    private void ResetFilters()
    {
        _filterDateFromStr = null;
        _filterDateToStr = null;
        _filterUserFullName = null;
        _filterEntityType = null;
        _filterAction = null;
        _filterTenantName = null;
        _filterCompanyName = null;
    }

    // ── AutoComplete arama fonksiyonları ───────────────────────────

    private Task<IEnumerable<string>> SearchUserNames(string value, CancellationToken ct)
    {
        var list = _filterOptions?.UserFullNames ?? Array.Empty<string>();
        if (!string.IsNullOrEmpty(value))
            return Task.FromResult<IEnumerable<string>>(
                list.Where(n => n.Contains(value, StringComparison.OrdinalIgnoreCase)).ToList());
        return Task.FromResult<IEnumerable<string>>(list);
    }

    private Task<IEnumerable<string>> SearchEntityTypes(string value, CancellationToken ct)
    {
        var list = _filterOptions?.EntityTypes ?? Array.Empty<string>();
        if (!string.IsNullOrEmpty(value))
            return Task.FromResult<IEnumerable<string>>(
                list.Where(n => n.Contains(value, StringComparison.OrdinalIgnoreCase)).ToList());
        return Task.FromResult<IEnumerable<string>>(list);
    }

    private Task<IEnumerable<string>> SearchTenantNames(string value, CancellationToken ct)
    {
        var list = _filterOptions?.TenantNames ?? Array.Empty<string>();
        if (!string.IsNullOrEmpty(value))
            return Task.FromResult<IEnumerable<string>>(
                list.Where(n => n.Contains(value, StringComparison.OrdinalIgnoreCase)).ToList());
        return Task.FromResult<IEnumerable<string>>(list);
    }

    private Task<IEnumerable<string>> SearchCompanyNames(string value, CancellationToken ct)
    {
        var list = _allCompanies.Select(c => c.Name);
        if (!string.IsNullOrEmpty(value))
            list = list.Where(n => n.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult<IEnumerable<string>>(list.OrderBy(n => n).ToList());
    }

    // ── Yardımcı metodlar ─────────────────────────────────────────

    private static DateTimeOffset? ParseDateFilter(string? input, bool endOfDay = false)
    {
        if (string.IsNullOrWhiteSpace(input)) return null;
        var normalized = input.Trim().Replace('.', '/').Replace('-', '/');
        string[] formats = ["d/M/yyyy", "dd/MM/yyyy", "d/M/yy", "dd/MM/yy", "M/d/yyyy"];
        if (DateTime.TryParseExact(normalized, formats,
            CultureInfo.InvariantCulture, DateTimeStyles.None, out var dt))
        {
            return new DateTimeOffset(endOfDay ? dt.AddDays(1) : dt, TimeSpan.Zero);
        }
        if (DateTime.TryParse(input, CultureInfo.CurrentCulture, DateTimeStyles.None, out var dt2))
        {
            return new DateTimeOffset(endOfDay ? dt2.AddDays(1) : dt2, TimeSpan.Zero);
        }
        return null;
    }

    private static Color ActionColor(AuditAction action) => action switch
    {
        AuditAction.Create => Color.Success,
        AuditAction.Delete => Color.Error,
        _ => Color.Warning
    };

    private string ActionLabel(AuditAction action) => action switch
    {
        AuditAction.Create => Loc["Audit.Action.Insert"].Value,
        AuditAction.Update => Loc["Audit.Action.Update"].Value,
        AuditAction.Delete => Loc["Audit.Action.Delete"].Value,
        _ => action.ToString()
    };

    private static string FormatJson(string json)
    {
        try
        {
            var doc = JsonDocument.Parse(json);
            return JsonSerializer.Serialize(doc, new JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return json;
        }
    }
}
