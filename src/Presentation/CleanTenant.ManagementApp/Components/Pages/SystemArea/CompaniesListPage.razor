@page "/system/companies"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IMainCatalogReader CompanyReader
@inject AuthenticationStateProvider AuthProvider
@inject PersistentComponentState PersistentState
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IStringLocalizer Loc
@implements IDisposable
@using CleanTenant.Application.Common.Export
@using CleanTenant.Application.Features.Main.Companies
@using CleanTenant.Application.Features.Main.Readers
@using CleanTenant.Domain.Tenant.Companies
@using CleanTenant.ManagementApp.Components.Shared
@using MediatR

@inject IMediator Mediator

<PageTitle>@Loc["Companies.List.PageTitle"]</PageTitle>

@*
    v0.2.4.a — DataTable<TItem> migration. Sistem operatör için tüm Site'leri
    parent Yönetim adıyla birlikte listeler.

    v0.2.10.e.4 — Companies.List.* + Common.* anahtarlarıyla lokalize edildi.
    _exportColumns OnInitialized'da Loc ile inşa edilir.
*@

@if (_unauthorized)
{
    <MudAlert Severity="Severity.Warning" Class="my-3">
        @Loc["Companies.List.UnauthorizedSystem"]
    </MudAlert>
}
else
{
    <div Class="d-flex justify-between align-center mb-4">
        <div></div>
        <MudButton Href="/system/companies/new"
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Add">
            @Loc["Companies.List.NewButton"]
        </MudButton>
    </div>

    <DataTable TItem="CompanyListItem"
               Items="@_items"
               Title="@Loc["Companies.List.Title"].Value"
               SearchPlaceholder="@Loc["Companies.List.Search"]"
               SearchableFields="@(row => new[] { row.Name, row.UrlCode, row.TenantName, row.LegalName })"
               ExportColumns="@_exportColumns">
        <Columns>
            <PropertyColumn T="CompanyListItem" TProperty="string" Property="@(c => c.Name)" Title="@Loc["Companies.List.Col.Name"].Value" />
            <PropertyColumn T="CompanyListItem" TProperty="string" Property="@(c => c.UrlCode)" Title="@Loc["Companies.List.Col.UrlCode"].Value" />
            <PropertyColumn T="CompanyListItem" TProperty="string" Property="@(c => c.TenantName)" Title="@Loc["Companies.List.Col.Tenant"].Value" Grouping="true" />
            <PropertyColumn T="CompanyListItem" TProperty="string" Property="@(c => c.LegalName)" Title="@Loc["Companies.List.Col.LegalName"].Value" />
            <PropertyColumn T="CompanyListItem" TProperty="CompanyStatus" Property="@(c => c.Status)" Title="@Loc["Companies.List.Col.Status"].Value">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small"
                             Color="@(context.Item.Status == CompanyStatus.Active ? Color.Success : Color.Default)">
                        @context.Item.Status
                    </MudChip>
                </CellTemplate>
            </PropertyColumn>
            <TemplateColumn T="CompanyListItem" CellClass="d-flex justify-end gap-1" Filterable="false" Sortable="false">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   Color="Color.Info"
                                   Title="@Loc["Common.Edit"]"
                                   Href="@($"/system/companies/{context.Item.UrlCode}/edit")" />
                    <MudIconButton Icon="@Icons.Material.Filled.Login"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   Title="@Loc["Companies.List.Action.Switch"]"
                                   OnClick="@(() => SwitchAsync(context.Item.TenantId, context.Item.Id))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   Title="@Loc["Common.Delete"]"
                                   OnClick="@(() => DeleteAsync(context.Item.Id))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </DataTable>
}

@code {
    private const string PersistKey = "systemarea.companies.list";
    private bool _unauthorized;
    private IReadOnlyList<CompanyListItem>? _items;
    private PersistingComponentStateSubscription _persistSubscription;

    private IReadOnlyList<ExportColumn<CompanyListItem>> _exportColumns = [];

    protected override async Task OnInitializedAsync()
    {
        _exportColumns =
        [
            new() { Header = Loc["Companies.List.Col.Name"].Value, Selector = r => r.Name },
            new() { Header = Loc["Companies.List.Col.UrlCode"].Value, Selector = r => r.UrlCode },
            new() { Header = Loc["Companies.List.Col.Tenant"].Value, Selector = r => r.TenantName },
            new() { Header = Loc["Companies.List.Col.LegalName"].Value, Selector = r => r.LegalName },
            new() { Header = Loc["CompanyForm.Vkn"].Value, Selector = r => r.Vkn },
            new() { Header = Loc["Companies.List.Col.Status"].Value, Selector = r => r.Status.ToString() },
        ];

        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true
            || !string.Equals(user.FindFirst("scope")?.Value, "System", StringComparison.OrdinalIgnoreCase))
        {
            _unauthorized = true;
            return;
        }

        if (PersistentState.TryTakeFromJson<List<CompanyListItem>>(PersistKey, out var cached) && cached is not null)
        {
            _items = cached;
            return;
        }

        _items = await CompanyReader.GetAllGlobalAsync();

        _persistSubscription = PersistentState.RegisterOnPersisting(() =>
        {
            PersistentState.PersistAsJson(PersistKey, _items);
            return Task.CompletedTask;
        });
    }

    private async Task SwitchAsync(Guid tenantId, Guid companyId)
    {
        var returnUrl = "/" + Nav.ToBaseRelativePath(Nav.Uri);
        await JS.InvokeVoidAsync(
            "cleantenant.submitTenantSwitch",
            tenantId.ToString(),
            returnUrl,
            companyId.ToString());
    }

    private async Task DeleteAsync(Guid companyId)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", Loc["Companies.List.Delete.Confirm"].Value);
        if (!confirmed) return;

        var command = new DeleteCompanyCommand(companyId);
        var result = await Mediator.Send(command);

        if (result.IsSuccess)
        {
            // Refresh list
            _items = await CompanyReader.GetAllGlobalAsync();
        }
    }

    public void Dispose() => _persistSubscription.Dispose();
}
