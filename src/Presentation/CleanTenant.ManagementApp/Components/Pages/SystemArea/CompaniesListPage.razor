@page "/system/companies"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IMainCatalogReader CompanyReader
@inject AuthenticationStateProvider AuthProvider
@inject PersistentComponentState PersistentState
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable
@using CleanTenant.Application.Features.Main.Readers
@using CleanTenant.Domain.Tenant.Companies

<PageTitle>Siteler — Sistem</PageTitle>

@*
    v0.2.3.d — Hybrid cache reader + PersistentComponentState. Sistem operatörü
    için tüm Site'leri parent Yönetim adıyla birlikte listeler (CompanyListItem
    DTO'da TenantName denormalize). Reader cascade cache: ITenantCatalogReader
    + IMainCatalogReader birlikte → tek bir Redis L2 round-trip ile döner.
*@

<MudText Typo="Typo.h5" Class="mb-3">
    <MudIcon Icon="@Icons.Material.Filled.Apartment" Class="mr-2" />
    Siteler
</MudText>

@if (_unauthorized)
{
    <MudAlert Severity="Severity.Warning" Class="my-3">
        Bu sayfa yalnız Sistem kullanıcıları için.
    </MudAlert>
}
else if (_items is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudDataGrid T="CompanyListItem"
                 Items="@_items"
                 Filterable="true"
                 SortMode="@SortMode.Multiple"
                 QuickFilter="@QuickFilter"
                 Hover="true"
                 Dense="true"
                 RowClick="@OnRowClick"
                 RowClass="cursor-pointer">
        <ToolBarContent>
            <MudText Typo="Typo.subtitle1">Toplam: @_items.Count</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="_searchText"
                          Placeholder="Site / Yönetim ara…"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium"
                          Immediate="true"
                          DebounceInterval="200"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Clearable="true"
                          Class="mt-0" Style="max-width: 300px;" />
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="@(c => c.Name)" Title="Site Adı" />
            <PropertyColumn Property="@(c => c.UrlCode)" Title="URL Kodu" />
            <PropertyColumn Property="@(c => c.TenantName)" Title="Yönetim" Grouping="true" />
            <PropertyColumn Property="@(c => c.LegalName)" Title="Yasal Ad" />
            <PropertyColumn Property="@(c => c.Status)" Title="Durum">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small"
                             Color="@(context.Item.Status == CompanyStatus.Active ? Color.Success : Color.Default)">
                        @context.Item.Status
                    </MudChip>
                </CellTemplate>
            </PropertyColumn>
            <TemplateColumn CellClass="d-flex justify-end" Filterable="false" Sortable="false">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Login"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   title="Bu Site bağlamına geç"
                                   OnClick="@(() => SwitchAsync(context.Item.TenantId, context.Item.Id))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>
}

@code {
    private const string PersistKey = "systemarea.companies.list";
    private string _searchText = string.Empty;
    private bool _unauthorized;
    private IReadOnlyList<CompanyListItem>? _items;
    private PersistingComponentStateSubscription _persistSubscription;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true
            || !string.Equals(user.FindFirst("scope")?.Value, "System", StringComparison.OrdinalIgnoreCase))
        {
            _unauthorized = true;
            return;
        }

        if (PersistentState.TryTakeFromJson<List<CompanyListItem>>(PersistKey, out var cached) && cached is not null)
        {
            _items = cached;
            return;
        }

        _items = await CompanyReader.GetAllGlobalAsync();

        _persistSubscription = PersistentState.RegisterOnPersisting(() =>
        {
            PersistentState.PersistAsJson(PersistKey, _items);
            return Task.CompletedTask;
        });
    }

    private Func<CompanyListItem, bool> QuickFilter => row =>
    {
        if (string.IsNullOrWhiteSpace(_searchText)) return true;
        return row.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || row.UrlCode.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || (row.TenantName?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)
            || (row.LegalName?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false);
    };

    private Task OnRowClick(DataGridRowClickEventArgs<CompanyListItem> args)
        => SwitchAsync(args.Item.TenantId, args.Item.Id);

    private async Task SwitchAsync(Guid tenantId, Guid companyId)
    {
        var returnUrl = "/" + Nav.ToBaseRelativePath(Nav.Uri);
        await JS.InvokeVoidAsync(
            "cleantenant.submitTenantSwitch",
            tenantId.ToString(),
            returnUrl,
            companyId.ToString());
    }

    public void Dispose() => _persistSubscription.Dispose();
}
