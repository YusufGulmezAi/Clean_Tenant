@page "/system/tenants/new"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject MediatR.IMediator Mediator
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IStringLocalizer Loc
@using CleanTenant.Application.Features.Catalog.Tenants
@using CleanTenant.ManagementApp.Components.Shared

<PageTitle>@Loc["Tenants.New.PageTitle"]</PageTitle>

@*
    v0.2.4.b.3 — Yeni Yönetim oluşturma sayfası (Sistem operatör için).
    TenantForm bileşenini Create modunda kullanır; submit'te CreateTenantCommand
    Mediator'a gönderilir.

    v0.2.10.e.4 — Tenants.New.* anahtarlarıyla lokalize edildi.
*@

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

    @if (_unauthorized)
    {
        <MudAlert Severity="Severity.Warning">
            @Loc["Tenants.List.UnauthorizedSystem"]
        </MudAlert>
    }
    else
    {
        <MudText Typo="Typo.h5" Class="mb-4">@Loc["Tenants.New.Title"]</MudText>

        <TenantForm Model="_model"
                    Mode="TenantFormMode.Create"
                    OnValidSubmit="@SubmitAsync"
                    IsSubmitting="@_busy"
                    SubmitButtonText="@Loc["Tenants.New.SubmitButton"]"
                    CancelHref="/system/tenants" />
    }
</MudContainer>

@code {
    private readonly TenantFormModel _model = new();
    private bool _busy;
    private bool _unauthorized;

    private List<BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs =
        [
            new(Loc["Nav.Tenants"].Value, "/system/tenants"),
            new(Loc["Tenants.New.Title"].Value, null, disabled: true),
        ];

        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true
            || !string.Equals(user.FindFirst("scope")?.Value, "System", StringComparison.OrdinalIgnoreCase))
        {
            _unauthorized = true;
        }
    }

    private async Task SubmitAsync()
    {
        _busy = true;
        try
        {
            var command = new CreateTenantCommand(
                Name: _model.Name,
                LegalName: string.IsNullOrWhiteSpace(_model.LegalName) ? null : _model.LegalName,
                LegalIdentityType: _model.LegalIdentityType,
                LegalIdentityNumber: _model.LegalIdentityNumber,
                Address: string.IsNullOrWhiteSpace(_model.Address) ? null : _model.Address,
                BillingTier: _model.BillingTier,
                HasDedicatedDatabase: _model.HasDedicatedDatabase,
                AdminFirstName: _model.AdminFirstName,
                AdminLastName: _model.AdminLastName,
                AdminEmail: _model.AdminEmail,
                AdminPhone: _model.AdminPhone,
                ProvinceId: _model.ProvinceId,
                DistrictId: _model.DistrictId,
                NeighborhoodId: _model.NeighborhoodId,
                ContactPerson: string.IsNullOrWhiteSpace(_model.ContactPerson) ? null : _model.ContactPerson,
                ContactEmail: string.IsNullOrWhiteSpace(_model.ContactEmail) ? null : _model.ContactEmail,
                ContactPhone: string.IsNullOrWhiteSpace(_model.ContactPhone) ? null : _model.ContactPhone,
                ContractStartDate: _model.ContractStartDate,
                ContractEndDate: _model.ContractEndDate,
                TransitionGraceDays: _model.TransitionGraceDays);

            var result = await Mediator.Send(command);
            if (result.IsFailure)
            {
                Snackbar.Add(Loc["Tenants.New.CreateError", result.FirstError.Message].Value, Severity.Error);
                return;
            }

            Snackbar.Add(Loc["Tenants.Save.Success", result.Value!.AdminEmail].Value, Severity.Success);
            Nav.NavigateTo("/system/tenants");
        }
        catch (Exception ex)
        {
            Snackbar.Add(Loc["Common.UnexpectedError", ex.Message].Value, Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }
}
