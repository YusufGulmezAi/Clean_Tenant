@page "/system/tenants/{urlCode}/edit"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject MediatR.IMediator Mediator
@inject ITenantCatalogReader TenantReader
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IStringLocalizer Loc
@using CleanTenant.Application.Features.Catalog.Readers
@using CleanTenant.Application.Features.Catalog.Tenants
@using CleanTenant.SharedKernel.Context
@using CleanTenant.ManagementApp.Components.Shared

<PageTitle>@Loc["Tenants.Edit.PageTitle"]</PageTitle>

@*
    v0.2.4.b.3 — Yönetim düzenleme (Sistem operatör için).
    v0.2.10.e.4 — Tenants.Edit.* anahtarlarıyla lokalize edildi.
    v0.2.12    — MudTabs: Genel + Kullanıcılar sekmesi eklendi.
*@

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

    @if (_unauthorized)
    {
        <MudAlert Severity="Severity.Warning">
            @Loc["Tenants.List.UnauthorizedSystem"]
        </MudAlert>
    }
    else if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_notFound)
    {
        <MudAlert Severity="Severity.Error">
            @Loc["Tenants.Edit.NotFound", UrlCode]
        </MudAlert>
    }
    else
    {
        <MudText Typo="Typo.h5" Class="mb-1">@Loc["Tenants.Edit.Title"]</MudText>
        <MudText Typo="Typo.caption" Color="Color.Default" Class="mb-4">
            @Loc["Tenants.Edit.UrlCodeLabel"] <code>@_urlCode</code>
        </MudText>

        <MudTabs Outlined="true"
                 Position="Position.Top"
                 Rounded="false"
                 Border="true"
                 KeepPanelsAlive="true"
                 PanelClass="pa-0">

            @* ── Genel ── *@
            <MudTabPanel Text="@Loc["Tenants.Edit.Tab.General"].Value"
                         Icon="@Icons.Material.Filled.Info">
                <div class="pa-3">
                    <TenantForm Model="_model"
                                Mode="TenantFormMode.Edit"
                                OnValidSubmit="@SubmitAsync"
                                IsSubmitting="@_busy"
                                SubmitButtonText="@Loc["Tenants.Edit.SubmitButton"].Value" />
                </div>
            </MudTabPanel>

            @* ── Kullanıcılar ── *@
            <MudTabPanel Text="@Loc["Tenants.Edit.Tab.Users"].Value"
                         Icon="@Icons.Material.Filled.People">
                <div class="pa-3">
                    <UserListPanel Scope="ScopeLevel.Tenant"
                                   TenantId="@_tenantId" />
                </div>
            </MudTabPanel>

        </MudTabs>
    }
</MudContainer>

@code {
    [Parameter] public string UrlCode { get; set; } = string.Empty;

    private Guid _tenantId;
    private TenantFormModel _model = new();
    private string _urlCode = string.Empty;
    private bool _loading = true;
    private bool _notFound;
    private bool _busy;
    private bool _unauthorized;

    private List<BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true
            || !string.Equals(user.FindFirst("scope")?.Value, "System", StringComparison.OrdinalIgnoreCase))
        {
            _unauthorized = true;
            _loading = false;
            return;
        }

        var detail = await TenantReader.GetDetailByUrlCodeAsync(UrlCode);
        if (detail is null)
        {
            _notFound = true;
            _loading = false;
            return;
        }

        _tenantId = detail.Id;
        _model = MapToFormModel(detail);
        _urlCode = detail.UrlCode;
        _breadcrumbs =
        [
            new(Loc["Nav.Tenants"].Value, "/system/tenants"),
            new(detail.Name, null, disabled: true),
            new(Loc["Common.Edit"].Value, null, disabled: true),
        ];
        _loading = false;
    }

    private static TenantFormModel MapToFormModel(TenantDetail d) => new()
    {
        Name = d.Name,
        LegalName = d.LegalName,
        LegalIdentityType = d.LegalIdentityType,
        LegalIdentityNumber = d.LegalIdentityNumber,
        Address = d.Address,
        BillingTier = d.BillingTier,
        HasDedicatedDatabase = d.HasDedicatedDatabase,
        AllowSystemWriteAccess = d.AllowSystemWriteAccess,
        ProvinceId = d.ProvinceId,
        DistrictId = d.DistrictId,
        NeighborhoodId = d.NeighborhoodId,
        ContactPerson = d.ContactPerson,
        ContactEmail = d.ContactEmail,
        ContactPhone = d.ContactPhone,
        ContractStartDate = d.ContractStartDate,
        ContractEndDate = d.ContractEndDate,
        TransitionGraceDays = d.TransitionGraceDays,
        Status = d.Status,
    };

    private async Task SubmitAsync()
    {
        _busy = true;
        try
        {
            var command = new UpdateTenantCommand(
                TenantId: _tenantId,
                Name: _model.Name,
                LegalName: string.IsNullOrWhiteSpace(_model.LegalName) ? null : _model.LegalName,
                LegalIdentityType: _model.LegalIdentityType,
                LegalIdentityNumber: _model.LegalIdentityNumber,
                Address: string.IsNullOrWhiteSpace(_model.Address) ? null : _model.Address,
                BillingTier: _model.BillingTier,
                HasDedicatedDatabase: _model.HasDedicatedDatabase,
                AllowSystemWriteAccess: _model.AllowSystemWriteAccess,
                ProvinceId: _model.ProvinceId,
                DistrictId: _model.DistrictId,
                NeighborhoodId: _model.NeighborhoodId,
                ContactPerson: string.IsNullOrWhiteSpace(_model.ContactPerson) ? null : _model.ContactPerson,
                ContactEmail: string.IsNullOrWhiteSpace(_model.ContactEmail) ? null : _model.ContactEmail,
                ContactPhone: string.IsNullOrWhiteSpace(_model.ContactPhone) ? null : _model.ContactPhone,
                ContractStartDate: _model.ContractStartDate,
                ContractEndDate: _model.ContractEndDate,
                TransitionGraceDays: _model.TransitionGraceDays,
                Status: _model.Status);

            var result = await Mediator.Send(command);
            if (result.IsFailure)
            {
                Snackbar.Add(Loc["Tenants.Edit.UpdateError", result.FirstError.Message].Value, Severity.Error);
                return;
            }

            Snackbar.Add(Loc["Tenants.Save.UpdateSuccess"].Value, Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(Loc["Common.UnexpectedError", ex.Message].Value, Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }
}
