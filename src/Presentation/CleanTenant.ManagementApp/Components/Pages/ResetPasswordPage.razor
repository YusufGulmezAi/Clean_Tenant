@page "/reset-password"
@layout EmptyLayout
@implements IDisposable
@inject PersistentComponentState ApplicationState
@inject IStringLocalizer Loc
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@*
    Şifre sıfırlama — 2. adım. Kullanıcı e-postasına gelen OTP kodu ve
    yeni şifresini girer. /auth/reset-password endpoint'i doğrular;
    başarıda cookie silinir ve /login?info=password-reset-success'e yönlendirilir.
*@

<PageTitle>@Loc["ResetPassword.PageTitle"]</PageTitle>

<MudPaper Elevation="3" Class="pa-8 mx-auto mt-16" Style="max-width: 460px;">
    <div class="d-flex align-center mb-6">
        <MudIcon Icon="@Icons.Material.Filled.LockReset" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h4" Class="ml-2">@Loc["ResetPassword.Title"]</MudText>
    </div>

    @if (!_hasSession)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4">
            @Loc["ResetPassword.NoSession"]
            <MudLink Href="/forgot-password">@Loc["ResetPassword.BackToForgot"]</MudLink>.
        </MudAlert>
    }
    else
    {
        <MudAlert Severity="Severity.Info" Class="mb-4">
            @Loc["ResetPassword.Subtitle"]
        </MudAlert>

        @if (!string.IsNullOrEmpty(ErrorCode))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">
                @MessageFor(ErrorCode)
            </MudAlert>
        }

        <form method="post" action="/auth/reset-password" id="reset-pwd-form">
            <div class="mb-4">
                <label for="code" class="d-block mb-1" style="font-weight: 500;">
                    @Loc["ResetPassword.Code"]
                </label>
                <input id="code" name="code" type="text"
                       autocomplete="one-time-code" required maxlength="6" inputmode="numeric"
                       style="width: 100%; padding: 10px; border: 1px solid rgba(0,0,0,0.23); border-radius: 4px; font-size: 1.2rem; letter-spacing: 0.3em; text-align: center;" />
            </div>

            <div class="mb-4">
                <label for="new-password" class="d-block mb-1" style="font-weight: 500;">
                    @Loc["ResetPassword.NewPassword"]
                </label>
                <input id="new-password" name="newPassword" type="password"
                       autocomplete="new-password" required minlength="8"
                       oninput="window.resetPwdValidate && window.resetPwdValidate()"
                       style="width: 100%; padding: 10px; border: 1px solid rgba(0,0,0,0.23); border-radius: 4px; font-size: 1rem;" />
            </div>

            <div class="mb-4">
                <label for="confirm-password" class="d-block mb-1" style="font-weight: 500;">
                    @Loc["ResetPassword.ConfirmPassword"]
                </label>
                <input id="confirm-password" type="password"
                       autocomplete="new-password" required minlength="8"
                       oninput="window.resetPwdValidate && window.resetPwdValidate()"
                       style="width: 100%; padding: 10px; border: 1px solid rgba(0,0,0,0.23); border-radius: 4px; font-size: 1rem;" />
                <span id="reset-pwd-mismatch" style="display:none; color:#d32f2f; font-size:0.8rem;">
                    @Loc["ResetPassword.Mismatch"]
                </span>
            </div>

            <button type="submit" id="reset-pwd-submit" disabled
                    style="width: 100%; padding: 12px; background-color: var(--mud-palette-primary); color: white; border: none; border-radius: 4px; font-size: 1rem; font-weight: 500; cursor: pointer; opacity: 0.5;">
                @Loc["ResetPassword.Submit"]
            </button>
        </form>

        <script>
            (function () {
                window.resetPwdValidate = function () {
                    var newPwd = document.getElementById('new-password').value || '';
                    var confirmPwd = document.getElementById('confirm-password').value || '';
                    var mismatch = document.getElementById('reset-pwd-mismatch');
                    var btn = document.getElementById('reset-pwd-submit');
                    var match = newPwd === confirmPwd;
                    var valid = newPwd.length >= 8 && confirmPwd.length >= 8 && match;
                    mismatch.style.display = (confirmPwd.length > 0 && !match) ? 'block' : 'none';
                    btn.disabled = !valid;
                    btn.style.opacity = valid ? '1' : '0.5';
                };
            })();
        </script>
    }

    <MudDivider Class="my-4" />

    <MudText Typo="Typo.caption" Color="Color.Default">
        <MudLink Href="/forgot-password">@Loc["ResetPassword.BackToForgot"]</MudLink>
        &nbsp;|&nbsp;
        <MudLink Href="/login">@Loc["ResetPassword.BackToLogin"]</MudLink>
    </MudText>
</MudPaper>

@code {
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorCode { get; set; }

    private const string PersistStateKey = "pwd-rst-present";
    private bool _hasSession;
    private PersistingComponentStateSubscription _persistingSubscription;

    protected override void OnInitialized()
    {
        _persistingSubscription = ApplicationState.RegisterOnPersisting(PersistFlagAsync);

        if (ApplicationState.TryTakeFromJson<bool>(PersistStateKey, out var saved))
        {
            _hasSession = saved;
        }
        else
        {
            var raw = HttpContext?.Request.Cookies[AuthEndpoints.ForgotPasswordEmailCookieName];
            _hasSession = !string.IsNullOrEmpty(raw);
        }
    }

    private Task PersistFlagAsync()
    {
        ApplicationState.PersistAsJson(PersistStateKey, _hasSession);
        return Task.CompletedTask;
    }

    public void Dispose() => _persistingSubscription.Dispose();

    private string MessageFor(string code) => code switch
    {
        "AUTH-030" => Loc["ResetPassword.Error.UserNotFound"].Value,
        "AUTH-031" => Loc["ResetPassword.Error.InvalidCode"].Value,
        "AUTH-032" => Loc["ResetPassword.Error.WeakPassword"].Value,
        "AUTH-034" => Loc["ResetPassword.NoSession"].Value,
        _ => Loc["ResetPassword.Error.Unknown", code].Value,
    };
}
