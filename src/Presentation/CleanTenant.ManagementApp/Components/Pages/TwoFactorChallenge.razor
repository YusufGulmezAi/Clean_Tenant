@page "/2fa/challenge"
@layout EmptyLayout
@implements IDisposable
@inject PersistentComponentState ApplicationState
@inject IStringLocalizer Loc
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@*
    2FA Challenge sayfası — Login akışında "TwoFactorRequired" sonucu sonrası
    yönlendirilir. v0.2.2.d: challenge token artık URL query'sinde değil,
    HttpOnly kısa ömürlü cookie'de (__ct_2fa_chal). Form'lar /auth/2fa/verify ve
    /auth/2fa/send-code endpoint'lerine POST eder — endpoint cookie'den okur.

    NOT: App.razor'da Routes @rendermode="InteractiveServer" → bu sayfa da çift
    render edilir (prerender + interactive). HttpContext sadece prerender'da
    mevcut; cookie'nin VARLIK BİLGİSİ (token değeri değil) PersistentComponentState
    ile interactive faza taşınır. Form post'larında cookie endpoint'e otomatik gider.

    v0.2.10.e.6 — TwoFactor.* + Common.* anahtarlarıyla lokalize edildi.
    MessageFor static → instance method.
*@

<PageTitle>@Loc["TwoFactor.Challenge.PageTitle"]</PageTitle>

<MudPaper Elevation="3" Class="pa-8 mx-auto mt-16" MaxWidth="MaxWidth.Small" Style="max-width: 460px;">
    <div class="d-flex align-center mb-6">
        <MudIcon Icon="@Icons.Material.Filled.Security" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h4" Class="ml-2">@Loc["TwoFactor.Challenge.Title"]</MudText>
    </div>

    @if (!_hasChallenge)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">
            @Loc["TwoFactor.Challenge.NoSession"]
            <MudLink Href="/login">@Loc["TwoFactor.Challenge.BackToLogin"]</MudLink>.
        </MudAlert>
    }
    else
    {
        @if (!string.IsNullOrEmpty(ErrorCode))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">
                @MessageFor(ErrorCode)
            </MudAlert>
        }
        @if (!string.IsNullOrEmpty(Info))
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">@Info</MudAlert>
        }

        <MudText Typo="Typo.body2" Color="Color.Default" Class="mb-4">
            @Loc["TwoFactor.Challenge.Prompt"]
        </MudText>

        <form method="post" action="/auth/2fa/verify">
            <div class="mb-3">
                <label for="method" class="d-block mb-1" style="font-weight: 500;">@Loc["TwoFactor.Method.Label"]</label>
                <select id="method" name="method"
                        onchange="window.cleantenant.challengeMethodSwitch && window.cleantenant.challengeMethodSwitch(this.value)"
                        style="width: 100%; padding: 10px; border: 1px solid rgba(0,0,0,0.23); border-radius: 4px; font-size: 1rem;">
                    <option value="Authenticator">@Loc["TwoFactor.Method.Authenticator"]</option>
                    <option value="Email">@Loc["TwoFactor.Method.Email"]</option>
                    <option value="Phone">@Loc["TwoFactor.Method.Sms"]</option>
                    <option value="RecoveryCode">@Loc["TwoFactor.Method.Recovery"]</option>
                </select>
            </div>

            @* 6 haneli OTP modu (Authenticator/Email/Phone için) *@
            <div id="challenge-otp" class="mb-4" style="display: block;">
                <label class="d-block mb-2" style="font-weight: 500;">@Loc["TwoFactor.Code.SixDigit"]</label>
                <div id="challenge-otp-inputs" class="d-flex justify-center" style="gap: 0.5rem;">
                    @for (int i = 0; i < 6; i++)
                    {
                        var idx = i;
                        <input type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1"
                               data-otp-index="@idx" autocomplete="one-time-code"
                               style="width: 48px; height: 56px; text-align: center; font-size: 1.5rem; border: 1px solid rgba(0,0,0,0.23); border-radius: 6px;" />
                    }
                </div>
            </div>

            @* Recovery kodu modu (XXXXX-XXXXX serbest metin) — JS toggle eder *@
            <div id="challenge-recovery" class="mb-4" style="display: none;">
                <label for="recovery-code" class="d-block mb-1" style="font-weight: 500;">
                    @Loc["TwoFactor.Code.Recovery"]
                </label>
                <input id="recovery-code" name="recovery-code-display" type="text" autocomplete="one-time-code"
                       placeholder="ABCDE-FGHIJ"
                       style="width: 100%; padding: 10px; border: 1px solid rgba(0,0,0,0.23); border-radius: 4px; font-size: 1rem; font-family: monospace;"
                       oninput="window.cleantenant.challengeSyncRecovery && window.cleantenant.challengeSyncRecovery(this.value)" />
            </div>

            @* Hidden field: cleantenant.js form submit'inde dolduracak (OTP veya recovery'den) *@
            <input id="challenge-code" name="code" type="hidden" value="" />

            <button type="submit"
                    id="challenge-submit"
                    disabled
                    style="width: 100%; padding: 12px; background-color: var(--mud-palette-primary); color: white; border: none; border-radius: 4px; font-size: 1rem; font-weight: 500; cursor: pointer; opacity: 0.5;">
                @Loc["TwoFactor.Verify"]
            </button>
        </form>

        <script>
            // cleantenant.js body sonunda yüklenir — inline script ondan ÖNCE
            // parse edilir; window.cleantenant henüz tanımlı değil. DOMContentLoaded
            // event'i tüm sync script'ler (cleantenant.js dahil) yüklendikten sonra
            // tetiklenir; init'i o zaman çalıştır.
            (function() {
                function init() {
                    if (!window.cleantenant || !window.cleantenant.otpForm) {
                        // Bir miktar daha bekle — cleantenant.js henüz parse edilmemiş.
                        setTimeout(init, 25);
                        return;
                    }

                    window.cleantenant.otpForm.init('challenge-otp-inputs', 'code', 'challenge-submit');

                    window.cleantenant.challengeMethodSwitch = function(method) {
                        var otpDiv = document.getElementById('challenge-otp');
                        var recoveryDiv = document.getElementById('challenge-recovery');
                        var submitBtn = document.getElementById('challenge-submit');
                        var hidden = document.getElementById('challenge-code');
                        if (method === 'RecoveryCode') {
                            otpDiv.style.display = 'none';
                            recoveryDiv.style.display = 'block';
                            var rv = document.getElementById('recovery-code').value || '';
                            hidden.value = rv;
                            submitBtn.disabled = rv.replace(/[^A-Za-z0-9]/g, '').length < 5;
                            submitBtn.style.opacity = submitBtn.disabled ? '0.5' : '1';
                        } else {
                            otpDiv.style.display = 'block';
                            recoveryDiv.style.display = 'none';
                            var inputs = document.querySelectorAll('#challenge-otp-inputs input[data-otp-index]');
                            var val = Array.from(inputs).map(function(i) { return i.value || ''; }).join('');
                            hidden.value = val;
                            submitBtn.disabled = val.length < 6;
                            submitBtn.style.opacity = submitBtn.disabled ? '0.5' : '1';
                        }
                    };

                    window.cleantenant.challengeSyncRecovery = function(value) {
                        var hidden = document.getElementById('challenge-code');
                        var submitBtn = document.getElementById('challenge-submit');
                        hidden.value = value || '';
                        var clean = (value || '').replace(/[^A-Za-z0-9]/g, '');
                        submitBtn.disabled = clean.length < 5;
                        submitBtn.style.opacity = submitBtn.disabled ? '0.5' : '1';
                    };
                }

                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', init);
                } else {
                    init();
                }
            })();
        </script>

        <MudDivider Class="my-4" />

        <form method="post" action="/auth/2fa/send-code">
            <input type="hidden" name="method" value="Email" />
            <button type="submit"
                    style="width: 100%; padding: 8px; background: transparent; color: var(--mud-palette-primary); border: 1px solid var(--mud-palette-primary); border-radius: 4px; cursor: pointer;">
                @Loc["TwoFactor.SendEmail"]
            </button>
        </form>

        <MudText Typo="Typo.caption" Color="Color.Default" Class="d-block mt-4">
            @Loc["TwoFactor.TokenValidity"] <MudLink Href="/login">@Loc["TwoFactor.RestartLogin"]</MudLink>.
        </MudText>
    }
</MudPaper>

@code {
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorCode { get; set; }

    [SupplyParameterFromQuery(Name = "info")]
    public string? Info { get; set; }

    // v0.2.2.d — Challenge token cookie'de; sayfa sadece cookie'nin VARLIK
    // bilgisini bilir (değeri form'lara yansıtmaz, leak yok). Endpoint
    // Verify/Send-code çağrılarında cookie'den okur. Bayrak interactive faza
    // PersistentComponentState ile taşınır.
    private const string PersistStateKey = "2fa-chal-present";
    private bool _hasChallenge;
    private PersistingComponentStateSubscription _persistingSubscription;

    protected override void OnInitialized()
    {
        _persistingSubscription = ApplicationState.RegisterOnPersisting(PersistFlagAsync);

        if (ApplicationState.TryTakeFromJson<bool>(PersistStateKey, out var saved))
        {
            // Interactive faz: prerender'da persist edilen bayrağı al.
            _hasChallenge = saved;
        }
        else
        {
            // Prerender (statik SSR): HttpContext'ten cookie varlığını oku.
            var raw = HttpContext?.Request.Cookies[AuthEndpoints.ChallengeCookieName];
            _hasChallenge = !string.IsNullOrEmpty(raw);
        }
    }

    private Task PersistFlagAsync()
    {
        ApplicationState.PersistAsJson(PersistStateKey, _hasChallenge);
        return Task.CompletedTask;
    }

    public void Dispose() => _persistingSubscription.Dispose();

    private string MessageFor(string code) => code switch
    {
        "AUTH-2FA-001" => Loc["TwoFactor.Error.MethodCodeRequired"].Value,
        "AUTH-2FA-INVALID-CODE" => Loc["TwoFactor.Error.InvalidOrExpired"].Value,
        "AUTH-2FA-CHALLENGE-NOT-FOUND" => Loc["TwoFactor.Error.ChallengeNotFound"].Value,
        "AUTH-2FA-METHOD-NOT-AVAILABLE" => Loc["TwoFactor.Error.MethodNotAvailable"].Value,
        _ => Loc["TwoFactor.Error.Unknown", code].Value,
    };
}
