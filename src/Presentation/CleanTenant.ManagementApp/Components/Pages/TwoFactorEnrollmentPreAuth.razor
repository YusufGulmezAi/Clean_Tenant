@page "/2fa/enroll-pre-auth"
@layout EmptyLayout
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@implements IDisposable
@inject MediatR.IMediator Mediator
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject PersistentComponentState ApplicationState
@inject IStringLocalizer Loc

@*
    v0.2.2.a — Pre-auth 2FA enrollment.
    Akış: Login → System scope kullanıcı + 2FA yok → buraya redirect.
    Kullanıcı henüz authenticated DEĞİL — cookie set'lemek için son adımda form
    post yapılır (/auth/2fa/enroll-pre-auth/finalize).

    v0.2.2.d — Enrollment challenge token query string yerine kısa ömürlü
    HttpOnly cookie'de (__ct_2fa_enroll). Sayfa prerender (statik SSR) fazında
    HttpContext üzerinden cookie'yi okur, PersistentComponentState ile
    InteractiveServer fazına taşır. Finalize endpoint cookie'den okur.

    State machine: QrCode → Verify (kod gir) → RecoveryCodes → Finalize (form post).

    v0.2.10.e.6 — TwoFactor.* + Common.* + Lookup.ErrorPrefix anahtarlarıyla
    lokalize edildi.
*@

<PageTitle>@Loc["TwoFactor.Enroll.PageTitle"]</PageTitle>

<MudPaper Elevation="3" Class="pa-8 mx-auto mt-8" MaxWidth="MaxWidth.Medium" Style="max-width: 560px;">
    <div class="d-flex align-center mb-4">
        <MudIcon Icon="@Icons.Material.Filled.Security" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h4" Class="ml-2">@Loc["TwoFactor.PreEnroll.Title"]</MudText>
    </div>

    @if (!_hasToken)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">
            @Loc["TwoFactor.PreEnroll.NoSession"]
            <MudLink Href="/login">@Loc["TwoFactor.Challenge.BackToLogin"]</MudLink>.
        </MudAlert>
    }
    else if (_step == EnrollmentStep.Loading)
    {
        <MudText Typo="Typo.body1" Class="mb-2">
            @Loc["TwoFactor.PreEnroll.Loading"]
        </MudText>
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />

        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mt-4">@_error</MudAlert>
        }
    }
    else if (_step == EnrollmentStep.QrCode)
    {
        <MudText Typo="Typo.body1" Color="Color.Default" Class="mb-3">
            @((MarkupString)Loc["TwoFactor.PreEnroll.SystemRoleInfo", $"<b>{_email}</b>"].Value)
        </MudText>

        <MudText Typo="Typo.h6" Class="mb-2">@Loc["TwoFactor.Enroll.Step1"]</MudText>

        @if (_qrCodeBase64 is not null)
        {
            <div class="d-flex justify-center mb-3">
                <img src="@($"data:image/png;base64,{_qrCodeBase64}")"
                     alt="@Loc["TwoFactor.Enroll.QrAlt"]"
                     style="width: 220px; height: 220px;" />
            </div>
        }

        <MudText Typo="Typo.body2" Color="Color.Default" Class="mb-2">
            @Loc["TwoFactor.Enroll.SecretHint"]
        </MudText>
        <MudPaper Elevation="0" Outlined="true" Class="pa-2 mb-4 d-flex align-center" Style="font-family: monospace;">
            <MudText Typo="Typo.body1">@_secret</MudText>
        </MudPaper>

        <MudText Typo="Typo.h6" Class="mb-2">@Loc["TwoFactor.Enroll.Step2"]</MudText>
        <div class="mb-3">
            <OtpCodeInput Value="@_confirmCode"
                          ValueChanged="@(v => _confirmCode = v)"
                          Disabled="@_busy" />
        </div>

        <MudButton Color="Color.Primary" Variant="Variant.Filled" FullWidth="true"
                   OnClick="@ConfirmAsync" Disabled="@(_busy || _confirmCode.Length < 6)">
            @Loc["Common.Confirm"]
        </MudButton>

        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mt-3">@_error</MudAlert>
        }
    }
    else if (_step == EnrollmentStep.RecoveryCodes)
    {
        <MudAlert Severity="Severity.Success" Class="mb-4">
            @((MarkupString)Loc["TwoFactor.Enroll.Success"].Value)
        </MudAlert>

        <MudGrid Class="mb-3">
            @foreach (var recoveryCode in _recoveryCodes)
            {
                <MudItem xs="6" sm="6">
                    <MudPaper Elevation="0" Outlined="true" Class="pa-2 d-flex justify-center"
                              Style="font-family: monospace; font-size: 0.95rem;">
                        @recoveryCode
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>

        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" FullWidth="true"
                   StartIcon="@Icons.Material.Filled.Download"
                   OnClick="@DownloadRecoveryCodesAsync"
                   Class="mb-3">
            @Loc["TwoFactor.Enroll.DownloadCodes"]
        </MudButton>

        <MudCheckBox T="bool" @bind-Value="_savedAcknowledged" Color="Color.Primary" Class="mt-2">
            @Loc["TwoFactor.Enroll.AckCodes"]
        </MudCheckBox>

        @* Finalize form post — cookie set'lemek için HttpContext gerekli.
           Token form'a hidden olarak GİTMEZ; endpoint cookie'den okur. *@
        <form method="post" action="/auth/2fa/enroll-pre-auth/finalize" class="mt-3">
            <button type="submit"
                    disabled="@(!_savedAcknowledged)"
                    style="width: 100%; padding: 12px; background-color: var(--mud-palette-primary); color: white; border: none; border-radius: 4px; font-size: 1rem; font-weight: 500; cursor: pointer; opacity: @(_savedAcknowledged ? "1" : "0.5");">
                @Loc["TwoFactor.PreEnroll.GoToPanel"]
            </button>
        </form>
    }

    <MudDivider Class="my-4" />

    <MudText Typo="Typo.caption" Color="Color.Default" Class="d-block text-center">
        @Loc["TwoFactor.PreEnroll.TokenValidity"] <MudLink Href="/login">@Loc["Common.Discard"]</MudLink>
    </MudText>
</MudPaper>

@code {
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private const string PersistStateKey = "2fa-enroll-token";

    private enum EnrollmentStep { Loading, QrCode, RecoveryCodes }
    private EnrollmentStep _step = EnrollmentStep.Loading;
    private bool _busy;
    private string? _error;
    private string? _email;
    private string? _secret;
    private string? _qrCodeBase64;
    private string _confirmCode = string.Empty;
    private IReadOnlyList<string> _recoveryCodes = [];
    private bool _savedAcknowledged;

    // v0.2.2.d — Token cookie'den okunup PersistentComponentState ile interactive
    // faza taşınır. _hasToken sayfa render kararları için, _token Mediator
    // çağrılarına Guid olarak parse edilir.
    private string? _token;
    private bool _hasToken;

    private PersistingComponentStateSubscription _persistingSubscription;
    private CancellationTokenSource? _cts;
    private bool _started;

    protected override void OnInitialized()
    {
        _cts = new();
        _persistingSubscription = ApplicationState.RegisterOnPersisting(PersistTokenAsync);

        if (ApplicationState.TryTakeFromJson<string?>(PersistStateKey, out var savedToken) && !string.IsNullOrEmpty(savedToken))
        {
            // Interactive faz: prerender'da persist edilen değeri al.
            _token = savedToken;
        }
        else if (HttpContext is not null)
        {
            // Prerender (statik SSR): cookie'den oku; PersistTokenAsync interactive'e taşır.
            _token = HttpContext.Request.Cookies[AuthEndpoints.EnrollmentCookieName];
        }

        _hasToken = !string.IsNullOrEmpty(_token);
    }

    private Task PersistTokenAsync()
    {
        if (!string.IsNullOrEmpty(_token))
        {
            ApplicationState.PersistAsJson(PersistStateKey, _token);
        }
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // InteractiveServer ilk render'da çağrılır — JSRuntime + Mediator hazır.
        // Token cookie'den (veya persist state'ten) gelir; başlamayı bir defa tetikle.
        if (firstRender && !_started && _hasToken)
        {
            _started = true;
            await StartAsync();
        }
    }

    private async Task StartAsync()
    {
        if (!TryParseToken(out var challengeToken))
        {
            _error = Loc["TwoFactor.PreEnroll.InvalidToken"].Value;
            await InvokeAsync(StateHasChanged);
            return;
        }

        _busy = true;
        try
        {
            var result = await Mediator.Send(
                new CleanTenant.Application.Features.Auth.TwoFactor.PreAuthEnrollment.StartPreAuthEnrollmentQuery(challengeToken),
                _cts!.Token);

            if (result.IsFailure)
            {
                _error = result.FirstError.Message;
                await InvokeAsync(StateHasChanged);
                return;
            }

            _email = result.Value!.Email;
            _secret = result.Value.Secret;
            _qrCodeBase64 = GenerateQrCodePngBase64(result.Value.QrCodeUri);
            _step = EnrollmentStep.QrCode;
        }
        catch (Exception ex)
        {
            _error = Loc["Lookup.ErrorPrefix", ex.Message].Value;
        }
        finally
        {
            _busy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ConfirmAsync()
    {
        if (!TryParseToken(out var challengeToken))
        {
            _error = Loc["TwoFactor.PreEnroll.InvalidToken"].Value;
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            var result = await Mediator.Send(
                new CleanTenant.Application.Features.Auth.TwoFactor.PreAuthEnrollment.CompletePreAuthEnrollmentCommand(challengeToken, _confirmCode.Trim()),
                _cts!.Token);

            if (result.IsFailure)
            {
                _error = result.FirstError.Message;
                return;
            }

            _recoveryCodes = result.Value!.RecoveryCodes;
            _step = EnrollmentStep.RecoveryCodes;
        }
        catch (Exception ex)
        {
            _error = Loc["Lookup.ErrorPrefix", ex.Message].Value;
        }
        finally
        {
            _busy = false;
        }
    }

    private bool TryParseToken(out Guid challengeToken)
    {
        challengeToken = Guid.Empty;
        if (string.IsNullOrEmpty(_token)) return false;
        return Guid.TryParseExact(_token, "N", out challengeToken) || Guid.TryParse(_token, out challengeToken);
    }

    private async Task DownloadRecoveryCodesAsync()
    {
        if (_recoveryCodes.Count == 0) return;
        var header = $"CleanTenant — Toplu Yapı Yönetimi · 2FA Kurtarma Kodları\nKullanıcı: {_email}\nTarih: {DateTimeOffset.Now:yyyy-MM-dd HH:mm}\n\nHer kod tek kullanımlıktır. Güvenli bir yerde saklayın.\n\n";
        var content = header + string.Join(Environment.NewLine, _recoveryCodes);
        var filename = $"cleantenant-recovery-codes-{DateTimeOffset.Now:yyyyMMdd-HHmm}.txt";
        await JS.InvokeVoidAsync("cleantenant.downloadTextFile", filename, content);
    }

    private static string GenerateQrCodePngBase64(string otpAuthUri)
    {
        using var generator = new QRCoder.QRCodeGenerator();
        using var data = generator.CreateQrCode(otpAuthUri, QRCoder.QRCodeGenerator.ECCLevel.Q);
        var pngBytes = new QRCoder.PngByteQRCode(data).GetGraphic(pixelsPerModule: 6);
        return Convert.ToBase64String(pngBytes);
    }

    public void Dispose()
    {
        _persistingSubscription.Dispose();
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
