@page "/2fa/enroll-pre-auth"
@layout EmptyLayout
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@implements IDisposable
@inject MediatR.IMediator Mediator
@inject NavigationManager Navigation

@*
    v0.2.2.a — Pre-auth 2FA enrollment.
    Akış: Login → System scope kullanıcı + 2FA yok → buraya redirect (?token=...).
    Kullanıcı henüz authenticated DEĞİL — cookie set'lemek için son adımda form
    post yapılır (/auth/2fa/enroll-pre-auth/finalize).

    State machine: QrCode → Verify (kod gir) → RecoveryCodes → Finalize (form post).
*@

<PageTitle>2FA Enrollment — CleanTenant</PageTitle>

<MudPaper Elevation="3" Class="pa-8 mx-auto mt-8" MaxWidth="MaxWidth.Medium" Style="max-width: 560px;">
    <div class="d-flex align-center mb-4">
        <MudIcon Icon="@Icons.Material.Filled.Security" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h4" Class="ml-2">2FA Kurulumu</MudText>
    </div>

    @if (string.IsNullOrEmpty(Token))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">
            Geçersiz enrollment token. <MudLink Href="/login">Giriş sayfasına dön</MudLink>.
        </MudAlert>
    }
    else if (_step == EnrollmentStep.Loading)
    {
        <MudText Typo="Typo.body1" Class="mb-2">
            Authenticator secret üretiliyor...
        </MudText>
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />

        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mt-4">@_error</MudAlert>
        }
    }
    else if (_step == EnrollmentStep.QrCode)
    {
        <MudText Typo="Typo.body1" Color="Color.Default" Class="mb-3">
            <b>@_email</b> hesabınız System rolünde — 2FA zorunlu. Bu kurulumu
            tamamlayana kadar Yönetim Paneline erişemezsiniz.
        </MudText>

        <MudText Typo="Typo.h6" Class="mb-2">1. Authenticator uygulamasıyla QR kodu tarayın</MudText>

        @if (_qrCodeBase64 is not null)
        {
            <div class="d-flex justify-center mb-3">
                <img src="@($"data:image/png;base64,{_qrCodeBase64}")"
                     alt="TOTP QR kodu"
                     style="width: 220px; height: 220px;" />
            </div>
        }

        <MudText Typo="Typo.body2" Color="Color.Default" Class="mb-2">
            QR kodu tarayamıyorsanız bu secret'ı elle girebilirsiniz:
        </MudText>
        <MudPaper Elevation="0" Outlined="true" Class="pa-2 mb-4 d-flex align-center" Style="font-family: monospace;">
            <MudText Typo="Typo.body1">@_secret</MudText>
        </MudPaper>

        <MudText Typo="Typo.h6" Class="mb-2">2. Uygulamanın verdiği 6 haneli kodu girin</MudText>
        <MudTextField @bind-Value="_confirmCode" Label="Kod" Variant="Variant.Outlined"
                      Placeholder="123456" MaxLength="6" Class="mb-3" />

        <MudButton Color="Color.Primary" Variant="Variant.Filled" FullWidth="true"
                   OnClick="@ConfirmAsync" Disabled="@(_busy || string.IsNullOrWhiteSpace(_confirmCode))">
            Onayla
        </MudButton>

        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mt-3">@_error</MudAlert>
        }
    }
    else if (_step == EnrollmentStep.RecoveryCodes)
    {
        <MudAlert Severity="Severity.Success" Class="mb-4">
            2FA aktif edildi! Aşağıdaki <b>10 recovery kodunu güvenli bir yere kaydedin</b>.
            Authenticator uygulamanıza erişim kaybederseniz bunlardan birini
            kullanabilirsiniz — her kod tek kullanımlıktır.
        </MudAlert>

        <MudGrid Class="mb-3">
            @foreach (var recoveryCode in _recoveryCodes)
            {
                <MudItem xs="6" sm="6">
                    <MudPaper Elevation="0" Outlined="true" Class="pa-2 d-flex justify-center"
                              Style="font-family: monospace; font-size: 0.95rem;">
                        @recoveryCode
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>

        <MudCheckBox T="bool" @bind-Value="_savedAcknowledged" Color="Color.Primary" Class="mt-2">
            Recovery kodlarını güvenli bir yere kaydettim.
        </MudCheckBox>

        @* Finalize form post — cookie set'lemek için HttpContext gerekli. *@
        <form method="post" action="/auth/2fa/enroll-pre-auth/finalize" class="mt-3">
            <input type="hidden" name="token" value="@Token" />
            <button type="submit"
                    disabled="@(!_savedAcknowledged)"
                    style="width: 100%; padding: 12px; background-color: var(--mud-palette-primary); color: white; border: none; border-radius: 4px; font-size: 1rem; font-weight: 500; cursor: pointer; opacity: @(_savedAcknowledged ? "1" : "0.5");">
                Yönetim Paneline Geç
            </button>
        </form>
    }

    <MudDivider Class="my-4" />

    <MudText Typo="Typo.caption" Color="Color.Default" Class="d-block text-center">
        Token 10 dakika geçerli. <MudLink Href="/login">Vazgeç</MudLink>
    </MudText>
</MudPaper>

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private enum EnrollmentStep { Loading, QrCode, RecoveryCodes }
    private EnrollmentStep _step = EnrollmentStep.Loading;
    private bool _busy;
    private string? _error;
    private string? _email;
    private string? _secret;
    private string? _qrCodeBase64;
    private string _confirmCode = string.Empty;
    private IReadOnlyList<string> _recoveryCodes = [];
    private bool _savedAcknowledged;

    private CancellationTokenSource? _cts;
    private bool _started;

    protected override void OnInitialized() => _cts = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // InteractiveServer ilk render'da çağrılır — JSRuntime + Mediator hazır.
        // Token query'den gelir; başlamayı bir defa tetikle.
        if (firstRender && !_started && !string.IsNullOrEmpty(Token))
        {
            _started = true;
            await StartAsync();
        }
    }

    private async Task StartAsync()
    {
        if (!Guid.TryParseExact(Token, "N", out var challengeToken)
            && !Guid.TryParse(Token, out challengeToken))
        {
            _error = "Geçersiz token formatı.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        _busy = true;
        try
        {
            var result = await Mediator.Send(
                new CleanTenant.Application.Features.Auth.TwoFactor.PreAuthEnrollment.StartPreAuthEnrollmentQuery(challengeToken),
                _cts!.Token);

            if (result.IsFailure)
            {
                _error = result.FirstError.Message;
                await InvokeAsync(StateHasChanged);
                return;
            }

            _email = result.Value!.Email;
            _secret = result.Value.Secret;
            _qrCodeBase64 = GenerateQrCodePngBase64(result.Value.QrCodeUri);
            _step = EnrollmentStep.QrCode;
        }
        catch (Exception ex)
        {
            _error = $"Hata: {ex.Message}";
        }
        finally
        {
            _busy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ConfirmAsync()
    {
        if (!Guid.TryParseExact(Token, "N", out var challengeToken)
            && !Guid.TryParse(Token, out challengeToken))
        {
            _error = "Geçersiz token formatı.";
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            var result = await Mediator.Send(
                new CleanTenant.Application.Features.Auth.TwoFactor.PreAuthEnrollment.CompletePreAuthEnrollmentCommand(challengeToken, _confirmCode.Trim()),
                _cts!.Token);

            if (result.IsFailure)
            {
                _error = result.FirstError.Message;
                return;
            }

            _recoveryCodes = result.Value!.RecoveryCodes;
            _step = EnrollmentStep.RecoveryCodes;
        }
        catch (Exception ex)
        {
            _error = $"Hata: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    private static string GenerateQrCodePngBase64(string otpAuthUri)
    {
        using var generator = new QRCoder.QRCodeGenerator();
        using var data = generator.CreateQrCode(otpAuthUri, QRCoder.QRCodeGenerator.ECCLevel.Q);
        var pngBytes = new QRCoder.PngByteQRCode(data).GetGraphic(pixelsPerModule: 6);
        return Convert.ToBase64String(pngBytes);
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
