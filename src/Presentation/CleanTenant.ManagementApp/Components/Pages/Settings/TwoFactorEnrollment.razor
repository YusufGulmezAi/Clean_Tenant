@page "/settings/2fa/enroll"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@implements IDisposable
@inject MediatR.IMediator Mediator
@inject NavigationManager Navigation

@*
    v0.2.2 — TOTP enrollment. Authenticated kullanıcı kendi hesabına TOTP
    metoduyla 2FA ekler. QR kod görseli QRCoder PNG ile üretilir.
    Akış: secret üret → QR göster → kullanıcı kod gir → confirm → 10 recovery code göster.
*@

<PageTitle>2FA Enrollment — CleanTenant</PageTitle>

<MudBreadcrumbs Items="@_breadcrumbs" Class="px-0 pb-2" />

<MudText Typo="Typo.h4" Class="mb-1">İki Faktörlü Doğrulama (TOTP)</MudText>
<MudText Typo="Typo.body1" Color="Color.Default" Class="mb-4">
    Google Authenticator, Microsoft Authenticator veya benzer bir uygulamayla
    hesabınıza ek güvenlik katmanı ekleyin.
</MudText>

@if (_step == EnrollmentStep.Start)
{
    <MudPaper Elevation="0" Outlined="true" Class="pa-4">
        <MudText Typo="Typo.body1" Class="mb-3">
            Başlamak için "Enrollment başlat" butonuna tıklayın. Bir QR kod üreteceğiz.
        </MudText>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Security"
                   OnClick="@StartEnrollmentAsync"
                   Disabled="@_busy">
            Enrollment başlat
        </MudButton>
        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mt-3">@_error</MudAlert>
        }
    </MudPaper>
}
else if (_step == EnrollmentStep.QrCode)
{
    <MudPaper Elevation="0" Outlined="true" Class="pa-4">
        <MudText Typo="Typo.h6" Class="mb-3">1. Authenticator uygulamasını açın ve QR kodu tarayın</MudText>

        @if (_qrCodeBase64 is not null)
        {
            <div class="d-flex justify-center mb-3">
                <img src="@($"data:image/png;base64,{_qrCodeBase64}")"
                     alt="TOTP QR kodu"
                     style="width: 240px; height: 240px;" />
            </div>
        }

        <MudText Typo="Typo.body2" Color="Color.Default" Class="mb-2">
            QR kodu tarayamıyorsanız bu secret'ı elle girebilirsiniz:
        </MudText>
        <MudPaper Elevation="0" Outlined="true" Class="pa-2 mb-4 d-flex align-center" Style="font-family: monospace;">
            <MudText Typo="Typo.body1">@_secret</MudText>
        </MudPaper>

        <MudText Typo="Typo.h6" Class="mb-2">2. Authenticator uygulamasının verdiği 6 haneli kodu girin</MudText>
        <MudTextField @bind-Value="_confirmCode" Label="Kod" Variant="Variant.Outlined"
                      Placeholder="123456" MaxLength="6" Class="mb-3" />

        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="@ConfirmEnrollmentAsync" Disabled="@(_busy || string.IsNullOrWhiteSpace(_confirmCode))">
            Onayla ve 2FA'yı Aktif Et
        </MudButton>
        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mt-3">@_error</MudAlert>
        }
    </MudPaper>
}
else if (_step == EnrollmentStep.RecoveryCodes)
{
    <MudPaper Elevation="0" Outlined="true" Class="pa-4">
        <MudAlert Severity="Severity.Success" Class="mb-4">
            2FA aktif edildi! Aşağıdaki <b>10 recovery kodunu güvenli bir yere kaydedin</b>.
            Her kod tek kullanımlıktır — authenticator app'inize erişim kaybederseniz
            bunlardan birini kullanırsınız.
        </MudAlert>

        <MudGrid>
            @foreach (var recoveryCode in _recoveryCodes)
            {
                <MudItem xs="6" sm="4">
                    <MudPaper Elevation="0" Outlined="true" Class="pa-2 d-flex justify-center" Style="font-family: monospace; font-size: 0.95rem;">
                        @recoveryCode
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>

        <MudCheckBox T="bool" @bind-Value="_savedAcknowledged" Color="Color.Primary" Class="mt-4">
            Recovery kodlarını güvenli bir yere kaydettim.
        </MudCheckBox>

        <MudButton Color="Color.Primary" Variant="Variant.Filled" Class="mt-3"
                   OnClick="@FinishAsync" Disabled="@(!_savedAcknowledged)">
            Tamamla ve Dashboard'a Dön
        </MudButton>
    </MudPaper>
}

@code {
    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Anasayfa", href: "/", icon: Icons.Material.Filled.Home),
        new("Ayarlar", href: null, disabled: true),
        new("2FA Enrollment", href: null, disabled: true),
    ];

    private enum EnrollmentStep { Start, QrCode, RecoveryCodes }
    private EnrollmentStep _step = EnrollmentStep.Start;
    private bool _busy;
    private string? _error;
    private string? _secret;
    private string? _qrCodeBase64;
    private string _confirmCode = string.Empty;
    private IReadOnlyList<string> _recoveryCodes = [];
    private bool _savedAcknowledged;

    private CancellationTokenSource? _cts;

    protected override void OnInitialized() => _cts = new();

    private async Task StartEnrollmentAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var result = await Mediator.Send(
                new CleanTenant.Application.Features.Auth.TwoFactor.EnrollTotp.EnrollTotpCommand(),
                _cts!.Token);

            if (result.IsFailure)
            {
                _error = result.FirstError.Message;
                return;
            }

            _secret = result.Value!.Secret;
            _qrCodeBase64 = GenerateQrCodePngBase64(result.Value.QrCodeUri);
            _step = EnrollmentStep.QrCode;
        }
        catch (Exception ex)
        {
            _error = $"Hata: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ConfirmEnrollmentAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var result = await Mediator.Send(
                new CleanTenant.Application.Features.Auth.TwoFactor.ConfirmTotpEnrollment.ConfirmTotpEnrollmentCommand(_confirmCode.Trim()),
                _cts!.Token);

            if (result.IsFailure)
            {
                _error = result.FirstError.Message;
                return;
            }

            _recoveryCodes = result.Value!.RecoveryCodes;
            _step = EnrollmentStep.RecoveryCodes;
        }
        catch (Exception ex)
        {
            _error = $"Hata: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    private void FinishAsync() => Navigation.NavigateTo("/", forceLoad: true);

    private static string GenerateQrCodePngBase64(string otpAuthUri)
    {
        using var generator = new QRCoder.QRCodeGenerator();
        using var data = generator.CreateQrCode(otpAuthUri, QRCoder.QRCodeGenerator.ECCLevel.Q);
        var pngBytes = new QRCoder.PngByteQRCode(data).GetGraphic(pixelsPerModule: 6);
        return Convert.ToBase64String(pngBytes);
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
