@page "/settings/2fa/enroll"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject NavigationManager Nav

@*
    v0.2.13 — TOTP enrollment artık birleşik profil sayfasının Güvenlik (2FA)
    sekmesindedir (/profile). Bu rota geriye dönük uyumluluk için yönlendirir.
    Login öncesi (pre-auth) enrollment ayrı bir akıştır (TwoFactorEnrollmentPreAuth).
*@

@code {
    protected override void OnInitialized() => Nav.NavigateTo("/profile", replace: true);
}
