@page "/settings/theme"
@inject NavigationManager Nav

@*
    v0.2.13.d — Tema yönetimi profil sayfasının Tema sekmesine taşındı. Bu route
    eski bağlantılar/yer imleri için korunur ve /profile?tab=theme'e yönlendirir.
    (Tema kartları + gece modu artık ProfileThemePanel komponentinde.)
*@

@code {
    protected override void OnInitialized()
        => Nav.NavigateTo("/profile?tab=theme", replace: true);
}
