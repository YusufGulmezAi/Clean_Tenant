@page "/settings/theme"
@rendermode InteractiveServer
@implements IDisposable
@inject IThemeService ThemeService

<PageTitle>Tema Ayarları — CleanTenant</PageTitle>

<MudBreadcrumbs Items="@_breadcrumbs" Class="px-0 pb-2" />

<MudText Typo="Typo.h4" Class="mb-1">Tema Ayarları</MudText>
<MudText Typo="Typo.body1" Color="Color.Default" Class="mb-4">
    4 hazır tema preset'inden birini seçin. Tercihiniz tarayıcıda kalıcılaşır ve
    bir sonraki girişte otomatik uygulanır.
</MudText>

<MudGrid>
    @foreach (var preset in _presets)
    {
        var isActive = preset == _selected;
        var theme = CleanTenantThemes.Resolve(preset);
        var palette = _isDark ? (Palette)theme.PaletteDark : theme.PaletteLight;

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="@(isActive ? 6 : 1)"
                      Class="@($"pa-3 cursor-pointer{(isActive ? " mud-border-primary" : "")}")"
                      Outlined="@isActive"
                      @onclick="@(() => OnPresetSelected(preset))">

                <div class="d-flex justify-space-between align-center mb-2">
                    <MudText Typo="Typo.subtitle1">@CleanTenantThemes.DisplayName(preset)</MudText>
                    @if (isActive)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Primary" Size="Size.Small" />
                    }
                </div>

                <div class="d-flex" style="height: 48px;">
                    <div style="@($"flex:1; background:{palette.Primary};")"></div>
                    <div style="@($"flex:1; background:{palette.Secondary};")"></div>
                    <div style="@($"flex:1; background:{palette.AppbarBackground};")"></div>
                </div>

                <MudText Typo="Typo.caption" Color="Color.Default" Class="mt-2">
                    Primary · Secondary · AppBar
                </MudText>
            </MudPaper>
        </MudItem>
    }
</MudGrid>

<MudPaper Elevation="0" Outlined="true" Class="pa-4 mt-6">
    <div class="d-flex align-center">
        <MudSwitch T="bool" Value="@_isDark" ValueChanged="@OnDarkChanged" Color="Color.Primary" Label="@(_isDark ? "Koyu mod aktif" : "Açık mod aktif")" />
        <MudSpacer />
        <MudIcon Icon="@(_isDark ? Icons.Material.Filled.DarkMode : Icons.Material.Filled.LightMode)" Color="Color.Default" />
    </div>
</MudPaper>

@code {
    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Anasayfa", href: "/", icon: Icons.Material.Filled.Home),
        new("Ayarlar", href: null, disabled: true),
        new("Tema", href: null, disabled: true),
    ];

    private readonly ThemePresetId[] _presets =
    [
        ThemePresetId.KurumsalMavi,
        ThemePresetId.TeskilatsalYesil,
        ThemePresetId.MudBlazorMor,
        ThemePresetId.KoyuKurumsal,
    ];

    private ThemePresetId _selected = ThemePresetId.KurumsalMavi;
    private bool _isDark;

    protected override void OnInitialized()
    {
        ThemeService.ThemeChanged += OnThemeChanged;
        Sync();
    }

    private void OnThemeChanged()
    {
        Sync();
        InvokeAsync(StateHasChanged);
    }

    private void Sync()
    {
        _selected = ThemeService.CurrentPreset;
        _isDark = ThemeService.IsDarkMode;
    }

    private async Task OnPresetSelected(ThemePresetId preset)
    {
        if (preset == _selected) return;
        await ThemeService.SetPresetAsync(preset);
    }

    private async Task OnDarkChanged(bool value)
    {
        if (value == _isDark) return;
        await ThemeService.ToggleDarkModeAsync();
    }

    public void Dispose() => ThemeService.ThemeChanged -= OnThemeChanged;
}
