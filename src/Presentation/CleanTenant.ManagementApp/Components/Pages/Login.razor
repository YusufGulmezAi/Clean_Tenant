@page "/login"
@layout EmptyLayout
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject IStringLocalizer Loc
@*
    Login sayfası — Static SSR. Form /auth/sign-in endpoint'ine POST eder.
    İnteraktivite minimum (loading state SignalR-bağımsız). Hata gösterimi
    query string'den (?error=CODE) alınır.

    v0.2.14 — Hesap kilitleme revizesi (Tasarım C görsel dili):
      - Hatalı kimlik/şifre → jenerik uyarı (kalan deneme sayısı GÖSTERİLMEZ,
        güvenlik/enumeration tercihi).
      - Hesap kilitliyse (AUTH-003 + ?lockedUntil=ISO) → şık kırmızı kilit kartı +
        canlı geri sayım (mm:ss). Süre dolunca form otomatik tekrar açılır.
*@

<PageTitle>@Loc["Login.PageTitle"]</PageTitle>

<MudPaper Elevation="3" Class="pa-8 mx-auto mt-16" MaxWidth="MaxWidth.Small" Style="max-width: 460px;">
    <div class="d-flex align-center mb-6">
        <MudIcon Icon="@Icons.Material.Filled.Domain" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h4" Class="ml-2">@Loc["Layout.AppBar.Brand"]</MudText>
    </div>

    @if (!string.IsNullOrEmpty(Info))
    {
        <MudAlert Severity="Severity.Success" Class="mb-4">
            @InfoMessageFor(Info)
        </MudAlert>
    }

    @if (IsLockout)
    {
        @* ── Kilit kartı (Tasarım C) — kırmızı şerit + canlı geri sayım ── *@
        <div class="lockout-card mb-4">
            <div class="lockout-card__head">
                <MudIcon Icon="@Icons.Material.Filled.LockClock" Color="Color.Error" Size="Size.Medium" />
                <span class="lockout-card__title">@Loc["Login.Locked.Title"]</span>
            </div>
            <div class="lockout-card__body">@Loc["Login.Locked.Message"]</div>
            @if (LockedUntilUtc is not null)
            {
                <div class="lockout-card__countdown">
                    <span class="lockout-card__countdown-label">@Loc["Login.Locked.RemainingLabel"]</span>
                    <span id="lockout-countdown"
                          class="lockout-card__countdown-value"
                          data-until="@LockedUntilUtc.Value.ToString("O")">--:--</span>
                </div>
            }
        </div>
    }
    else if (!string.IsNullOrEmpty(ErrorCode))
    {
        <MudAlert Severity="@SeverityFor(ErrorCode)" Class="mb-4" ShowCloseIcon="true">
            @MessageFor(ErrorCode)
        </MudAlert>
    }

    <form method="post" action="/auth/sign-in">
        <input type="hidden" name="persona" value="Management" />

        <div class="mb-3">
            <label for="identifier" class="d-block mb-1" style="font-weight: 500;">
                @Loc["Login.Identifier"]
            </label>
            <input id="identifier"
                   name="identifier"
                   type="text"
                   required
                   autocomplete="username"
                   autofocus
                   disabled="@IsLockout"
                   class="mud-input-control-input-container"
                   style="width: 100%; padding: 10px; border: 1px solid rgba(0,0,0,0.23); border-radius: 4px; font-size: 1rem;" />
        </div>

        <div class="mb-3">
            <label for="password" class="d-block mb-1" style="font-weight: 500;">@Loc["Login.Password"]</label>
            <input id="password"
                   name="password"
                   type="password"
                   required
                   autocomplete="current-password"
                   disabled="@IsLockout"
                   style="width: 100%; padding: 10px; border: 1px solid rgba(0,0,0,0.23); border-radius: 4px; font-size: 1rem;" />
        </div>

        <div class="mb-4 d-flex align-center">
            <input id="rememberMe" name="rememberMe" type="checkbox" value="true" disabled="@IsLockout" />
            <label for="rememberMe" class="ml-2">@Loc["Login.RememberMe.Days"]</label>
        </div>

        <button type="submit"
                id="login-submit"
                disabled="@IsLockout"
                style="width: 100%; padding: 12px; background-color: var(--mud-palette-primary); color: white; border: none; border-radius: 4px; font-size: 1rem; font-weight: 500; cursor: pointer;">
            @Loc["Login.SubmitButton"]
        </button>
    </form>

    <MudDivider Class="my-4" />

    <MudText Typo="Typo.caption" Color="Color.Default" Align="Align.Center" Class="d-block">
        <MudLink Href="/forgot-password">@Loc["Login.ForgotPassword"]</MudLink>
    </MudText>

    <MudText Typo="Typo.caption" Color="Color.Default" Align="Align.Center" Class="d-block mt-1">
        v0.2.14 · @Loc["Login.Footer"]
    </MudText>
</MudPaper>

@* Kilit kartı görünümü — sade, tema değişkenleriyle uyumlu. *@
<style>
    .lockout-card {
        border: 1px solid var(--mud-palette-error);
        border-left: 4px solid var(--mud-palette-error);
        border-radius: 8px;
        background-color: rgba(244, 67, 54, 0.06);
        padding: 16px;
    }
    .lockout-card__head { display: flex; align-items: center; gap: 8px; }
    .lockout-card__title { font-weight: 600; color: var(--mud-palette-error); }
    .lockout-card__body { margin-top: 6px; font-size: 0.9rem; color: var(--mud-palette-text-secondary); }
    .lockout-card__countdown {
        margin-top: 12px; display: flex; flex-direction: column; align-items: center;
    }
    .lockout-card__countdown-label { font-size: 0.75rem; color: var(--mud-palette-text-secondary); }
    .lockout-card__countdown-value {
        font-size: 2rem; font-weight: 700; font-variant-numeric: tabular-nums;
        color: var(--mud-palette-error); letter-spacing: 2px;
    }
</style>

@if (IsLockout && LockedUntilUtc is not null)
{
    @* Canlı geri sayım — Static SSR olduğu için saf JS. Süre dolunca /login'e döner. *@
    <script>
        (function () {
            var el = document.getElementById('lockout-countdown');
            if (!el) return;
            var until = new Date(el.getAttribute('data-until')).getTime();
            function pad(n) { return (n < 10 ? '0' : '') + n; }
            function tick() {
                var diff = Math.max(0, Math.floor((until - Date.now()) / 1000));
                el.textContent = pad(Math.floor(diff / 60)) + ':' + pad(diff % 60);
                if (diff <= 0) { clearInterval(timer); window.location.href = '/login'; }
            }
            tick();
            var timer = setInterval(tick, 1000);
        })();
    </script>
}

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorCode { get; set; }

    [SupplyParameterFromQuery(Name = "info")]
    public string? Info { get; set; }

    /// <summary>Kilit bitiş zamanı (ISO 8601 / UTC) — yalnız AUTH-003'te dolu.</summary>
    [SupplyParameterFromQuery(Name = "lockedUntil")]
    public string? LockedUntil { get; set; }

    /// <summary>Hesap kilitli mi? AUTH-003 hata kodu kilit demektir.</summary>
    private bool IsLockout => string.Equals(ErrorCode, "AUTH-003", StringComparison.Ordinal);

    /// <summary>Kilit bitiş zamanının parse edilmiş UTC hali (geçersizse null).</summary>
    private DateTimeOffset? LockedUntilUtc =>
        DateTimeOffset.TryParse(
            LockedUntil,
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.AdjustToUniversal | System.Globalization.DateTimeStyles.AssumeUniversal,
            out var parsed)
            ? parsed
            : null;

    private string InfoMessageFor(string info) => info switch
    {
        "password-reset-success" => Loc["Login.Info.PasswordResetSuccess"].Value,
        _ => info,
    };

    private static Severity SeverityFor(string code) => code switch
    {
        "AUTH-001" or "AUTH-009" => Severity.Warning,
        "AUTH-002" or "AUTH-003" => Severity.Error,
        "AUTH-010" => Severity.Error,
        "AUTH-2FA-ENROLLMENT-REQUIRED" => Severity.Info,
        "AUTH-2FA-ENROLL-CHALLENGE-NOT-FOUND" => Severity.Warning,
        "AUTH-2FA-ENROLL-NOT-VERIFIED" => Severity.Warning,
        "AUTH-004" => Severity.Error,
        _ => Severity.Error,
    };

    private string MessageFor(string code) => code switch
    {
        "AUTH-001" => Loc["Login.Error.IdentifierRequired"].Value,
        "AUTH-002" => Loc["Login.Error.Invalid"].Value,
        "AUTH-003" => Loc["Login.Error.Lockout"].Value,
        "AUTH-004" => Loc["Login.Error.NoManagementScope"].Value,
        "AUTH-009" => Loc["Login.Error.IdentifierTypeUnknown"].Value,
        "AUTH-010" => Loc["Login.Error.Deactivated"].Value,
        // v0.2.2.a öncesi error — sistem normalde otomatik enrollment sayfasına
        // yönlendirir; bu mesaj yalnız edge case'lerde (tutarsız 2FA durumu) görünür.
        "AUTH-2FA-ENROLLMENT-REQUIRED" => Loc["Login.Error.TwoFactorEnrollmentRequired"].Value,
        "AUTH-2FA-ENROLL-CHALLENGE-NOT-FOUND" => Loc["Login.Error.EnrollmentExpired"].Value,
        "AUTH-2FA-ENROLL-NOT-VERIFIED" => Loc["Login.Error.EnrollmentNotVerified"].Value,
        _ => Loc["Login.Error.Unknown", code].Value,
    };
}
