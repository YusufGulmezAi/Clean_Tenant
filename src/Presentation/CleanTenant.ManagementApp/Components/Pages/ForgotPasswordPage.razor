@page "/forgot-password"
@layout EmptyLayout
@inject IStringLocalizer Loc
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@*
    Şifre sıfırlama — 1. adım. Kullanıcı e-posta adresini girer;
    /auth/forgot-password endpoint'i OTP e-postayla gönderir ve
    __ct_pwd_rst cookie set'leyip /reset-password'a yönlendirir.
*@

<PageTitle>@Loc["ForgotPassword.PageTitle"]</PageTitle>

<MudPaper Elevation="3" Class="pa-8 mx-auto mt-16" Style="max-width: 460px;">
    <div class="d-flex align-center mb-6">
        <MudIcon Icon="@Icons.Material.Filled.LockReset" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h4" Class="ml-2">@Loc["ForgotPassword.Title"]</MudText>
    </div>

    <MudAlert Severity="Severity.Info" Class="mb-4">
        @Loc["ForgotPassword.Subtitle"]
    </MudAlert>

    @if (!string.IsNullOrEmpty(ErrorCode))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">
            @MessageFor(ErrorCode)
        </MudAlert>
    }

    <form method="post" action="/auth/forgot-password">
        <div class="mb-4">
            <label for="email" class="d-block mb-1" style="font-weight: 500;">
                @Loc["ForgotPassword.Email"]
            </label>
            <input id="email" name="email" type="email"
                   autocomplete="email" required
                   style="width: 100%; padding: 10px; border: 1px solid rgba(0,0,0,0.23); border-radius: 4px; font-size: 1rem;" />
        </div>

        <button type="submit"
                style="width: 100%; padding: 12px; background-color: var(--mud-palette-primary); color: white; border: none; border-radius: 4px; font-size: 1rem; font-weight: 500; cursor: pointer;">
            @Loc["ForgotPassword.Submit"]
        </button>
    </form>

    <MudDivider Class="my-4" />

    <MudText Typo="Typo.caption" Color="Color.Default">
        <MudLink Href="/login">@Loc["ForgotPassword.BackToLogin"]</MudLink>
    </MudText>
</MudPaper>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorCode { get; set; }

    private string MessageFor(string code) => code switch
    {
        "AUTH-033" => Loc["ForgotPassword.Error.EmailRequired"].Value,
        _ => Loc["ForgotPassword.Error.Unknown", code].Value,
    };
}
