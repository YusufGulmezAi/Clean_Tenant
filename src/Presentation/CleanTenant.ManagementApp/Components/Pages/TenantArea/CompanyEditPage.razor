@page "/tenant/companies/{urlCode}/edit"

@using CleanTenant.Application.Features.Main.Companies
@using CleanTenant.Application.Features.Main.Readers
@using CleanTenant.ManagementApp.Components.Shared
@using Microsoft.AspNetCore.Components

@inject IMainCatalogReader Reader
@inject IStringLocalizer Loc

<PageTitle>@Loc["Companies.Edit.PageTitle"]</PageTitle>

@*
    v0.2.10.e.5 — Companies.Edit.* anahtarlarıyla lokalize edildi.
*@

<MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
    <MudBreadcrumbs Items="@_breadcrumbs" Class="px-0 mb-4"></MudBreadcrumbs>

    @if (!_initialized)
    {
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="60px" Class="mb-2" />
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="300px" />
    }
    else if (_detail is null)
    {
        <MudAlert Severity="Severity.Warning">@Loc["Companies.Edit.NotFound"]</MudAlert>
    }
    else
    {
        <MudText Typo="Typo.h5" Class="mb-3">@_detail.Name</MudText>
        <CompanyDetailTabs Detail="@_detail" ListHref="/tenant/companies" />
    }
</MudContainer>

@code {
    [Parameter]
    public string UrlCode { get; set; } = string.Empty;

    private List<BreadcrumbItem> _breadcrumbs = [];
    private CompanyDetail? _detail;
    private bool _initialized;

    protected override async Task OnInitializedAsync()
    {
        _detail = await Reader.GetDetailByUrlCodeAsync(UrlCode);

        if (_detail is not null)
        {
            _breadcrumbs =
            [
                new BreadcrumbItem(Loc["Companies.List.Title"].Value, href: "/tenant/companies"),
                new BreadcrumbItem(_detail.Name, href: null, disabled: true),
            ];
        }

        _initialized = true;
    }
}
