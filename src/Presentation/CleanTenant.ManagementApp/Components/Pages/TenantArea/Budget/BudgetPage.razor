@* v0.2.15 — Legacy bütçe sayfası ARŞİVLENDİ.
   Eski BudgetEntry tabanlı sayfa kaldırıldı; bu rota artık yeni bütçe
   yönetim UI'sine (/tenant/budgets) yönlendirir. Eski yer imleri çalışsın diye
   rota korunur. *@
@page "/tenant/budget"
@page "/tenant/budget/{CompanyId:guid}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject NavigationManager Nav

<MudProgressLinear Indeterminate="true" Class="my-4" />

@code {
    /// <summary>Opsiyonel site; verilirse site-özel yeni sayfaya yönlendirilir.</summary>
    [Parameter] public Guid? CompanyId { get; set; }

    protected override void OnParametersSet()
    {
        var target = CompanyId is { } id ? $"/tenant/budgets/{id}" : "/tenant/budgets";
        Nav.NavigateTo(target, replace: true);
    }
}
