@page "/tenant/budget/{CompanyId:guid}/vs-actual"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject AuthenticationStateProvider AuthProvider
@inject ICurrentSessionAccessor SessionAccessor
@inject IMainCatalogReader CompanyReader
@inject MediatR.IMediator Mediator
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IStringLocalizer Loc
@using CleanTenant.Application.Common.Auth
@using CleanTenant.SharedKernel.Common.Results
@using CleanTenant.Application.Features.Main.Accounting.Reports
@using CleanTenant.Application.Features.Main.Accounting.Readers
@using CleanTenant.Application.Features.Main.Accounting.FiscalYears
@using CleanTenant.Application.Features.Main.Readers
@using CleanTenant.Domain.Tenant.Accounting.Enums

@*
    v0.2.13.a — Bütçe / Gerçekleşen karşılaştırma raporu (Tenant scope).
    Bütçe Adım 0 ile birlikte Site scope'tan Tenant scope'a taşındı.
    Yetki: `tenant.budget.view`. FAZ 5+ ile veri kaynağı yeni Butce modeline bağlanacak.
*@

<PageTitle>Bütçe - Gerçekleşen Karşılaştırma</PageTitle>

@if (_unauthorized)
{
    <MudAlert Severity="Severity.Warning" Class="my-3">
        Bu sayfaya erişim yetkiniz bulunmuyor. Yönetim kapsamında `tenant.budget.view` izni gereklidir.
    </MudAlert>
}
else if (!_initialized)
{
    <MudText Typo="Typo.h6" Class="my-3">Yükleniyor...</MudText>
}
else
{
    <div class="d-flex align-center justify-space-between mb-3">
        <MudText Typo="Typo.h5">Bütçe / Gerçekleşen — @_companyName</MudText>
        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="@(() => Nav.NavigateTo($"/tenant/budget/{CompanyId}"))">
            Bütçeye Dön
        </MudButton>
    </div>

    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6">
                <MudSelect T="FiscalYearListItem?" @bind-Value="_selectedYear"
                           Label="Mali Yıl"
                           AnchorOrigin="Origin.BottomLeft"
                           Required="true">
                    @foreach (var fy in _fiscalYears)
                    {
                        <MudSelectItem T="FiscalYearListItem?" Value="fy">@fy.Label</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="int?" @bind-Value="_selectedMonth"
                           Label="Ay (boş = tüm yıl)"
                           Clearable="true"
                           AnchorOrigin="Origin.BottomLeft">
                    @for (int m = 1; m <= 12; m++)
                    {
                        var month = m;
                        <MudSelectItem T="int?" Value="@((int?)month)">@month. Ay</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           FullWidth="true"
                           Disabled="@(_loading || _selectedYear is null)"
                           OnClick="@LoadReportAsync">
                    Raporu Görüntüle
                </MudButton>
            </MudItem>
        </MudGrid>
        @if (_loading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-3" />
        }
    </MudPaper>

    @if (_hasResult)
    {
        <MudStack Row="true" Spacing="2" Class="mb-2">
            <MudButton StartIcon="@Icons.Material.Filled.PictureAsPdf"
                       Color="Color.Error" Variant="Variant.Outlined"
                       Disabled="true">PDF</MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.TableChart"
                       Color="Color.Success" Variant="Variant.Outlined"
                       Disabled="true">Excel</MudButton>
        </MudStack>

        @if (_report is null || _report.Lines.Count == 0)
        {
            <MudAlert Severity="Severity.Info">
                Rapor verisi bulunamadı. (FAZ 6 implementasyonuyla tamamlanacak)
            </MudAlert>
        }
        else
        {
            <MudTable Items="@_report.Lines" Hover="true" Striped="true" Bordered="true" Dense="true">
                <HeaderContent>
                    <MudTh>Hesap Kodu</MudTh>
                    <MudTh>Hesap Adı</MudTh>
                    <MudTh Style="text-align:right">Bütçe</MudTh>
                    <MudTh Style="text-align:right">Gerçekleşen</MudTh>
                    <MudTh Style="text-align:right">Sapma</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Hesap Kodu">
                        <MudText Typo="Typo.body2" Style="font-family:monospace">@context.AccountCode</MudText>
                    </MudTd>
                    <MudTd DataLabel="Hesap Adı">@context.AccountName</MudTd>
                    <MudTd DataLabel="Bütçe" Style="text-align:right">@context.Budgeted.ToString("N2")</MudTd>
                    <MudTd DataLabel="Gerçekleşen" Style="text-align:right">@context.Actual.ToString("N2")</MudTd>
                    <MudTd DataLabel="Sapma" Style="text-align:right">
                        <MudText Color="@VarianceColor(context.Variance)">
                            @context.Variance.ToString("N2")
                        </MudText>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    }
}

@code {
    [Parameter] public Guid CompanyId { get; set; }

    private string _companyName = "";
    private bool _unauthorized;
    private bool _initialized;
    private bool _loading;
    private bool _hasResult;

    private IReadOnlyList<FiscalYearListItem> _fiscalYears = [];
    private FiscalYearListItem? _selectedYear;
    private int? _selectedMonth;
    private BudgetVsActualReport? _report;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true) { _unauthorized = true; _initialized = true; return; }

        var scope = user.FindFirst("scope")?.Value;
        var isSystem = string.Equals(scope, "System", StringComparison.OrdinalIgnoreCase);
        if (!isSystem && !string.Equals(scope, "Tenant", StringComparison.OrdinalIgnoreCase))
        {
            _unauthorized = true;
            _initialized = true;
            return;
        }

        if (!isSystem)
        {
            var session = SessionAccessor.Current;
            if (session is null || !session.Permissions.Contains("tenant.budget.view"))
            {
                _unauthorized = true;
                _initialized = true;
                return;
            }
        }

        var company = await CompanyReader.GetByIdAsync(CompanyId);
        if (company is null)
        {
            _unauthorized = true;
            _initialized = true;
            return;
        }
        _companyName = company.Name;

        var fyResult = await Mediator.Send(new GetFiscalYearsQuery(CompanyId));
        if (fyResult.IsSuccess)
        {
            _fiscalYears = fyResult.Value!;
            _selectedYear = _fiscalYears.FirstOrDefault(x => x.IsCurrentYear) ?? _fiscalYears.FirstOrDefault();
        }

        _initialized = true;
    }

    private async Task LoadReportAsync()
    {
        if (_selectedYear is null) return;
        _loading = true;
        _hasResult = false;
        StateHasChanged();

        var result = await Mediator.Send(new GetBudgetVsActualQuery(CompanyId, _selectedYear.Id, _selectedMonth));

        if (result.IsFailure)
        {
            Snackbar.Add($"Rapor yüklenemedi: {result.FirstError.Message}", Severity.Error);
        }
        else
        {
            _report = result.Value;
            _hasResult = true;
        }

        _loading = false;
    }

    private static Color VarianceColor(decimal variance) =>
        variance > 0 ? Color.Error :
        variance < 0 ? Color.Success :
        Color.Default;
}
