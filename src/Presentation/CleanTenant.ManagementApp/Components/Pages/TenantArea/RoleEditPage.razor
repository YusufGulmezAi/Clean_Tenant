@page "/tenant/roles/{urlCode}/edit"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject NavigationManager Nav

@*
    v0.2.13.b — Rol düzenleme artık /access > "Roller & İzinler" sekmesindeki
    RoleDialog modalı ile yapılır. Bu eski route (/tenant/roles/{code}/edit)
    /access'e yönlendirir.
*@

@code {
    [Parameter] public string UrlCode { get; set; } = string.Empty;

    protected override void OnInitialized()
    {
        Nav.NavigateTo("/access", forceLoad: false, replace: true);
    }
}
