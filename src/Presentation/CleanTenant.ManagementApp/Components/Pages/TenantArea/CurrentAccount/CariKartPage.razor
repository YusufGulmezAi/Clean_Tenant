@* Cari Kart — BB-merkezli kişi/borç kartı (Nordic hibrit kabuk). S5a: kabuk + KPI +
   sidebar; sekme içerikleri S5b, tahsilat sihirbazı S5c. *@
@page "/tenant/current-accounts/{CompanyId:guid}/{UnitId:guid}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject AuthenticationStateProvider AuthProvider
@inject ICurrentSessionAccessor SessionAccessor
@inject MediatR.IMediator Mediator
@inject NavigationManager Nav
@inject IStringLocalizer Loc
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using CleanTenant.Application.Common.Auth
@using CleanTenant.Application.Features.Main.Parties
@using CleanTenant.Application.Features.Main.Parties.CurrentAccount
@using CleanTenant.Application.Features.Main.Parties.Tenures
@using CleanTenant.Application.Features.Main.Accruals.Queries
@using CleanTenant.Application.Features.Main.Collections.Queries
@using CleanTenant.Domain.Tenant.Parties.Enums

<PageTitle>@(_tenures is null ? Loc["Cari.Card.PageTitle"].Value : $"Daire {_tenures.UnitNumber}")</PageTitle>

@if (_unauthorized)
{
    <MudAlert Severity="Severity.Warning" Class="my-3">@Loc["Cari.Unauthorized"]</MudAlert>
}
else if (!_initialized)
{
    <MudProgressLinear Indeterminate="true" Class="my-4" />
}
else if (_tenures is null)
{
    <MudAlert Severity="Severity.Error" Class="my-3">@Loc["Cari.Card.NotFound"]</MudAlert>
}
else
{
    <div class="cari-shell">
        <div class="cari-topbar">
            <button class="cari-back" @onclick="@(() => Nav.NavigateTo($"/tenant/current-accounts/{CompanyId}"))">
                ← @Loc["Cari.Card.BackToList"]
            </button>
            <span class="cari-crumb">@_tenures.BuildingName ▸ <b>Daire @_tenures.UnitNumber</b></span>
        </div>

        @* ── Header card ───────────────────────────────────────────── *@
        <section class="header-card">
            <div class="hc-row">
                <div class="avatar">@Initials</div>
                <div class="hc-identity">
                    <h1>@Loc["Cari.Card.Unit"] @_tenures.UnitNumber</h1>
                    <div class="hc-meta">
                        @if (_activeOwner is not null)
                        {
                            <span class="tag tag-malik">@Loc["Cari.Tag.Owner"]: @_activeOwner.PartyName</span>
                        }
                        @if (_activeTenant is not null)
                        {
                            <span class="tag tag-kiraci">@Loc["Cari.Tag.Tenant"]: @_activeTenant.PartyName</span>
                        }
                        @if (_activeOwner is null && _activeTenant is null)
                        {
                            <span class="tag tag-none">@Loc["Cari.Card.NoResponsible"]</span>
                        }
                    </div>
                    <div class="hc-bb-ref">🏢 @_tenures.BuildingName ▸ @Loc["Cari.Card.Unit"] @_tenures.UnitNumber</div>
                </div>
                <div class="quick-actions">
                    @if (_canRecord)
                    {
                        <button class="qa-btn primary" @onclick="OpenCollectionWizardAsync">
                            + @Loc["Cari.Card.RecordCollection"]
                        </button>
                    }
                </div>
            </div>

            <div class="kpi-strip">
                <div class="kpi">
                    <div class="kpi-label">@Loc["Cari.Kpi.Accrued"]</div>
                    <div class="kpi-value">@Fmt(_kpi.TotalAccrued)</div>
                </div>
                <div class="kpi">
                    <div class="kpi-label">@Loc["Cari.Kpi.Collected"]</div>
                    <div class="kpi-value pos">@Fmt(_kpi.TotalCollected)</div>
                </div>
                <div class="kpi">
                    <div class="kpi-label">@Loc["Cari.Kpi.Overdue"]</div>
                    <div class="kpi-value @(_kpi.OverdueAmount > 0 ? "neg" : "")">@Fmt(_kpi.OverdueAmount)</div>
                </div>
                <div class="kpi">
                    <div class="kpi-label">@Loc["Cari.Kpi.Balance"]</div>
                    <div class="kpi-value @(_kpi.NetBalance > 0 ? "neg" : "pos")">
                        @Fmt(_kpi.NetBalance) @(_kpi.NetBalance > 0 ? Loc["Cari.Kpi.Debtor"].Value : "")
                    </div>
                </div>
            </div>
        </section>

        @* ── Body: sidebar + content ───────────────────────────────── *@
        <div class="body-layout">
            <aside class="sidebar">
                @foreach (var grp in TabGroups)
                {
                    <div class="nav-group">
                        <div class="nav-group-label">@grp.Label</div>
                        @foreach (var t in grp.Tabs)
                        {
                            <button class="nav-item @(_tab == t.Key ? "active" : "")"
                                    disabled="@(!t.Active)"
                                    @onclick="@(() => _tab = t.Key)">
                                @t.Title
                                @if (!t.Active)
                                {
                                    <span class="nav-soon">@Loc["Cari.Tab.Soon"]</span>
                                }
                            </button>
                        }
                    </div>
                }
            </aside>

            <main class="cari-content">
                <div class="cari-panel">
                    <div class="cari-panel-head">@CurrentTabTitle</div>
                    <div class="cari-panel-body">
                        @switch (_tab)
                        {
                            case "genel":
                                @if (_partyDetail is null)
                                {
                                    <MudAlert Severity="Severity.Info" Dense="true">@Loc["Cari.Genel.NoParty"]</MudAlert>
                                }
                                else
                                {
                                    <MudGrid Spacing="2">
                                        @Field(Loc["Cari.Field.FullName"].Value, _partyDetail.FullName)
                                        @Field(Loc["Cari.Field.Kind"].Value, Loc[_partyDetail.Kind == PartyKind.Legal ? "Cari.Kind.Legal" : "Cari.Kind.Individual"].Value)
                                        @Field("TCKN", _partyDetail.Tckn)
                                        @Field("VKN", _partyDetail.Vkn)
                                        @Field(Loc["Cari.Field.Birth"].Value, _partyDetail.BirthDate?.ToString("dd.MM.yyyy"))
                                        @Field(Loc["Cari.Field.Phone"].Value, _partyDetail.Phone)
                                        @Field(Loc["Cari.Field.Email"].Value, _partyDetail.Email)
                                        @Field(Loc["Cari.Field.Address"].Value, _partyDetail.AddressLine)
                                        @Field("KVKK", _partyDetail.KvkkConsentGiven ? Loc["Cari.Field.KvkkYes"].Value : Loc["Cari.Field.KvkkNo"].Value)
                                    </MudGrid>
                                    @if (_partyDetail.PiiMasked)
                                    {
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary mt-3">@Loc["Cari.Genel.PiiMasked"]</MudText>
                                    }
                                }
                                break;

                            case "hissedar":
                                @if (_tenures!.Owners.Count == 0)
                                {
                                    <MudAlert Severity="Severity.Info" Dense="true">@Loc["Cari.Hissedar.Empty"]</MudAlert>
                                }
                                else
                                {
                                    <MudSimpleTable Dense="true" Hover="true">
                                        <thead><tr>
                                            <th>@Loc["Cari.Tag.Owner"]</th>
                                            <th style="text-align:right">@Loc["Cari.Col.Share"]</th>
                                            <th>@Loc["Cari.Col.Liability"]</th>
                                            <th>@Loc["Cari.Col.Period"]</th>
                                            <th>@Loc["Cari.Col.Status"]</th>
                                        </tr></thead>
                                        <tbody>
                                        @foreach (var o in _tenures.Owners)
                                        {
                                            <tr>
                                                <td>@o.PartyName</td>
                                                <td style="text-align:right">%@o.SharePercent.ToString("0.##")</td>
                                                <td>@(o.IsJointAndSeveral ? Loc["Cari.Col.JointSeveral"].Value : "—")</td>
                                                <td>@D(o.StartDate) – @(o.EndDate is null ? "…" : D(o.EndDate))</td>
                                                <td>@StatusChip(o.IsActive)</td>
                                            </tr>
                                        }
                                        </tbody>
                                    </MudSimpleTable>
                                }
                                break;

                            case "oturan":
                                <MudSimpleTable Dense="true" Hover="true">
                                    <thead><tr>
                                        <th>@Loc["Cari.Col.Person"]</th>
                                        <th>@Loc["Cari.Col.Role"]</th>
                                        <th>@Loc["Cari.Col.Period"]</th>
                                        <th>@Loc["Cari.Col.Status"]</th>
                                    </tr></thead>
                                    <tbody>
                                    @foreach (var o in _tenures!.Owners)
                                    {
                                        <tr><td>@o.PartyName</td><td>@Loc["Cari.Tag.Owner"]</td><td>@D(o.StartDate) – @(o.EndDate is null ? "…" : D(o.EndDate))</td><td>@StatusChip(o.IsActive)</td></tr>
                                    }
                                    @foreach (var t in _tenures.Tenants)
                                    {
                                        <tr><td>@t.PartyName</td><td>@Loc["Cari.Tag.Tenant"]</td><td>@D(t.StartDate) – @(t.EndDate is null ? "…" : D(t.EndDate))</td><td>@StatusChip(t.IsActive)</td></tr>
                                    }
                                    @if (_tenures.Owners.Count == 0 && _tenures.Tenants.Count == 0)
                                    {
                                        <tr><td colspan="4" class="cari-placeholder">@Loc["Cari.Oturan.Empty"]</td></tr>
                                    }
                                    </tbody>
                                </MudSimpleTable>
                                break;

                            case "iletisimkisi":
                                @if (_tenures!.Contacts.Count == 0)
                                {
                                    <MudAlert Severity="Severity.Info" Dense="true">@Loc["Cari.Contacts.Empty"]</MudAlert>
                                }
                                else
                                {
                                    <MudSimpleTable Dense="true" Hover="true">
                                        <thead><tr><th>@Loc["Cari.Col.Person"]</th><th>@Loc["Cari.Col.Role"]</th><th>@Loc["Cari.Col.Period"]</th><th>@Loc["Cari.Col.Status"]</th></tr></thead>
                                        <tbody>
                                        @foreach (var c in _tenures.Contacts)
                                        {
                                            <tr><td>@c.PartyName</td><td>@c.ContactRole</td><td>@D(c.StartDate) – @(c.EndDate is null ? "…" : D(c.EndDate))</td><td>@StatusChip(c.IsActive)</td></tr>
                                        }
                                        </tbody>
                                    </MudSimpleTable>
                                }
                                break;

                            case "cari":
                                @if (_ledger.Count == 0)
                                {
                                    <MudAlert Severity="Severity.Info" Dense="true">@Loc["Cari.Ledger.Empty"]</MudAlert>
                                }
                                else
                                {
                                    <MudSimpleTable Dense="true" Hover="true">
                                        <thead><tr>
                                            <th>@Loc["Cari.Col.Date"]</th>
                                            <th>@Loc["Cari.Col.Description"]</th>
                                            <th style="text-align:right">@Loc["Cari.Col.Debit"]</th>
                                            <th style="text-align:right">@Loc["Cari.Col.Credit"]</th>
                                            <th style="text-align:right">@Loc["Cari.Col.Balance"]</th>
                                        </tr></thead>
                                        <tbody>
                                        @foreach (var e in _ledger)
                                        {
                                            <tr>
                                                <td>@e.Date.ToString("dd.MM.yyyy")</td>
                                                <td>@e.Description</td>
                                                <td style="text-align:right">@(e.Debit > 0 ? e.Debit.ToString("N2") : "—")</td>
                                                <td style="text-align:right">@(e.Credit > 0 ? e.Credit.ToString("N2") : "—")</td>
                                                <td style="text-align:right">@e.RunningBalance.ToString("N2")</td>
                                            </tr>
                                        }
                                        </tbody>
                                    </MudSimpleTable>
                                }
                                break;

                            case "tahakkuk":
                                <div class="kpi-strip" style="margin-top:0;margin-bottom:16px;">
                                    <div class="kpi"><div class="kpi-label">@Loc["Cari.Kpi.Accrued"]</div><div class="kpi-value">@Fmt(_debt?.TotalAccrued ?? 0)</div></div>
                                    <div class="kpi"><div class="kpi-label">@Loc["Cari.Debt.Paid"]</div><div class="kpi-value pos">@Fmt(_debt?.PaidAmount ?? 0)</div></div>
                                    <div class="kpi"><div class="kpi-label">@Loc["Cari.Debt.Remaining"]</div><div class="kpi-value @((_debt?.RemainingAmount ?? 0) > 0 ? "neg" : "")">@Fmt(_debt?.RemainingAmount ?? 0)</div></div>
                                    <div class="kpi"><div class="kpi-label">@Loc["Cari.Kpi.Overdue"]</div><div class="kpi-value @((_debt?.OverdueAmount ?? 0) > 0 ? "neg" : "")">@Fmt(_debt?.OverdueAmount ?? 0)</div></div>
                                </div>
                                <MudText Typo="Typo.subtitle2" Class="mb-2">@Loc["Cari.Tahakkuk.Collections"]</MudText>
                                @if (_collections.Count == 0)
                                {
                                    <MudAlert Severity="Severity.Info" Dense="true">@Loc["Cari.Tahakkuk.NoCollection"]</MudAlert>
                                }
                                else
                                {
                                    <MudSimpleTable Dense="true" Hover="true">
                                        <thead><tr><th>@Loc["Cari.Col.Date"]</th><th style="text-align:right">@Loc["Cari.Col.Amount"]</th><th>@Loc["Cari.Col.Method"]</th><th>@Loc["Cari.Col.Reference"]</th></tr></thead>
                                        <tbody>
                                        @foreach (var c in _collections)
                                        {
                                            <tr><td>@c.PaymentDate.ToString("dd.MM.yyyy")</td><td style="text-align:right">@c.Amount.ToString("N2")</td><td>@c.Method</td><td>@(c.Reference ?? "—")</td></tr>
                                        }
                                        </tbody>
                                    </MudSimpleTable>
                                }
                                break;

                            default:
                                <p class="cari-placeholder">@Loc["Cari.Panel.NextPhase"]</p>
                                break;
                        }
                    </div>
                </div>
            </main>
        </div>
    </div>
}

@code {
    [Parameter] public Guid CompanyId { get; set; }
    [Parameter] public Guid UnitId { get; set; }

    private bool _unauthorized, _initialized;
    private bool _canRecord;
    private Guid _tenantId;
    private string _tab = "genel";
    private UnitTenures? _tenures;
    private CurrentAccountKpi _kpi = new(0, 0, 0, 0);
    private OwnershipItem? _activeOwner;
    private TenancyItem? _activeTenant;
    private PartyDetail? _partyDetail;
    private IReadOnlyList<LedgerEntryRow> _ledger = [];
    private UnitDebtStatus? _debt;
    private IReadOnlyList<CollectionListItem> _collections = [];

    private string Initials => _tenures is null ? "?" : $"D{_tenures.UnitNumber}";

    private sealed record TabDef(string Key, string Title, bool Active);
    private sealed record TabGroup(string Label, TabDef[] Tabs);

    private TabGroup[] TabGroups => [
        new(Loc["Cari.Group.Identity"].Value, [
            new("genel", Loc["Cari.Tab.General"].Value, true),
            new("sozlesme", Loc["Cari.Tab.Contract"].Value, false),
            new("hissedar", Loc["Cari.Tab.Shareholders"].Value, true),
            new("oturan", Loc["Cari.Tab.Residents"].Value, true),
            new("iletisimkisi", Loc["Cari.Tab.Contacts"].Value, true),
        ]),
        new(Loc["Cari.Group.Financial"].Value, [
            new("cari", Loc["Cari.Tab.Ledger"].Value, true),
            new("tahakkuk", Loc["Cari.Tab.Accruals"].Value, true),
            new("abonelik", Loc["Cari.Tab.Subscriptions"].Value, false),
            new("icra", Loc["Cari.Tab.Enforcement"].Value, false),
        ]),
        new(Loc["Cari.Group.Interaction"].Value, [
            new("iletisim", Loc["Cari.Tab.CommHistory"].Value, false),
            new("dosyalar", Loc["Cari.Tab.Files"].Value, false),
            new("sikayet", Loc["Cari.Tab.Complaints"].Value, false),
            new("araclar", Loc["Cari.Tab.Vehicles"].Value, false),
        ]),
    ];

    private bool IsActiveTab(string key) => TabGroups.SelectMany(g => g.Tabs).First(t => t.Key == key).Active;
    private string CurrentTabTitle => TabGroups.SelectMany(g => g.Tabs).First(t => t.Key == _tab).Title;

    private static string Fmt(decimal v) => v.ToString("N2") + " ₺";
    private static string? D(DateOnly? d) => d?.ToString("dd.MM.yyyy");

    private RenderFragment Field(string label, string? value) => __builder =>
    {
        <MudItem xs="12" sm="6" md="4">
            <div style="font-size:10.5px;text-transform:uppercase;letter-spacing:.06em;color:var(--mud-palette-text-secondary);">@label</div>
            <div style="font-weight:500;">@(string.IsNullOrWhiteSpace(value) ? "—" : value)</div>
        </MudItem>
    };

    private RenderFragment StatusChip(bool active) => __builder =>
    {
        <MudChip T="string" Size="Size.Small" Color="@(active ? Color.Success : Color.Default)">
            @(active ? Loc["Cari.Status.Active"].Value : Loc["Cari.Status.Past"].Value)
        </MudChip>
    };

    protected override async Task OnParametersSetAsync()
    {
        _initialized = false;
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        if (authState.User?.Identity?.IsAuthenticated != true) { _unauthorized = true; _initialized = true; return; }
        var session = SessionAccessor.Current;
        var isSystem = string.Equals(authState.User.FindFirst("scope")?.Value, "System", StringComparison.OrdinalIgnoreCase);
        if (!isSystem && (session is null || !session.Permissions.Contains("tenant.party.view")))
        {
            _unauthorized = true; _initialized = true; return;
        }
        _canRecord = isSystem || (session?.Permissions.Contains("tenant.collection.record") ?? false);
        if (authState.User.FindFirst("tenant_id") is { Value: var tid } && Guid.TryParseExact(tid, "N", out var tGuid))
            _tenantId = tGuid;

        var tenures = await Mediator.Send(new GetUnitTenuresQuery(CompanyId, UnitId));
        if (tenures.IsFailure || tenures.Value is null) { _tenures = null; _initialized = true; return; }
        _tenures = tenures.Value;
        _activeOwner = _tenures.Owners.FirstOrDefault(o => o.IsActive);
        _activeTenant = _tenures.Tenants.FirstOrDefault(t => t.IsActive);

        var kpi = await Mediator.Send(new GetUnitCurrentAccountKpiQuery(CompanyId, UnitId));
        if (kpi.IsSuccess && kpi.Value is not null) _kpi = kpi.Value;

        // Sekme verileri (S5b) — tek BB için topluca yükle
        var primaryPartyId = _activeOwner?.PartyId ?? _activeTenant?.PartyId;
        if (primaryPartyId is { } pid)
        {
            var pd = await Mediator.Send(new GetPartyDetailQuery(CompanyId, pid));
            if (pd.IsSuccess) _partyDetail = pd.Value;
        }
        var ledger = await Mediator.Send(new GetUnitLedgerQuery(CompanyId, UnitId));
        if (ledger.IsSuccess && ledger.Value is not null) _ledger = ledger.Value;
        var debt = await Mediator.Send(new GetUnitDebtStatusQuery(CompanyId, UnitId));
        if (debt.IsSuccess) _debt = debt.Value;
        var cols = await Mediator.Send(new GetUnitCollectionHistoryQuery(CompanyId, UnitId));
        if (cols.IsSuccess && cols.Value is not null) _collections = cols.Value;

        _initialized = true;
    }

    private async Task OpenCollectionWizardAsync()
    {
        if (!_canRecord || _tenures is null) return;
        var parameters = new DialogParameters<CollectionWizardDialog>
        {
            { x => x.TenantId, _tenantId },
            { x => x.CompanyId, CompanyId },
            { x => x.UnitId, UnitId },
            { x => x.UnitNumber, _tenures.UnitNumber },
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<CollectionWizardDialog>(Loc["Cari.Wizard.Title"].Value, parameters, options);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is true)
        {
            Snackbar.Add(Loc["Cari.Wizard.Success"].Value, Severity.Success);
            await RefreshFinancialsAsync();
        }
    }

    private async Task RefreshFinancialsAsync()
    {
        var kpi = await Mediator.Send(new GetUnitCurrentAccountKpiQuery(CompanyId, UnitId));
        if (kpi.IsSuccess && kpi.Value is not null) _kpi = kpi.Value;
        var ledger = await Mediator.Send(new GetUnitLedgerQuery(CompanyId, UnitId));
        if (ledger.IsSuccess && ledger.Value is not null) _ledger = ledger.Value;
        var debt = await Mediator.Send(new GetUnitDebtStatusQuery(CompanyId, UnitId));
        if (debt.IsSuccess) _debt = debt.Value;
        var cols = await Mediator.Send(new GetUnitCollectionHistoryQuery(CompanyId, UnitId));
        if (cols.IsSuccess && cols.Value is not null) _collections = cols.Value;
        StateHasChanged();
    }
}
