@page "/tenant/companies/new"

@using CleanTenant.Application.Features.Main.Companies
@using CleanTenant.Application.Common.Auth
@using CleanTenant.ManagementApp.Components.Shared
@using MediatR
@using Microsoft.AspNetCore.Components

@inject IMediator Mediator
@inject ICurrentSessionAccessor SessionAccessor
@inject NavigationManager Nav
@inject IStringLocalizer Loc

<PageTitle>@Loc["Companies.New.PageTitle"]</PageTitle>

@*
    v0.2.10.e.5 — Companies.New.* + Common.* anahtarlarıyla lokalize edildi.
*@

@if (_initialized)
{
    <CompanyForm Model="@_model"
                     Mode="@CompanyFormMode.Create"
                     OnValidSubmit="@CreateAsync"
                     IsSubmitting="@_isSubmitting"
                     SubmitButtonText="@Loc["Companies.New.SubmitButton"]"
                     CancelHref="/tenant/companies" />

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mt-4">@_errorMessage</MudAlert>
        }
}
else
{
    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" Class="mb-4" />
    <MudSkeleton SkeletonType="SkeletonType.Text" />
}

@code {
    private CompanyFormModel _model = new();
    private bool _initialized = false;
    private bool _isSubmitting = false;
    private string _errorMessage = string.Empty;

    protected override void OnInitialized()
    {
        _model = new CompanyFormModel();
        _initialized = true;
    }

    private async Task CreateAsync()
    {
        _isSubmitting = true;
        _errorMessage = string.Empty;

        try
        {
            var session = SessionAccessor.Current;
            if (session is null || session.TenantId is null || session.TenantId == Guid.Empty)
            {
                _errorMessage = Loc["Companies.TenantNew.NoSession"].Value;
                _isSubmitting = false;
                return;
            }

            var command = new CreateCompanyCommand(
                TenantId: session.TenantId.Value,
                Name: _model.Name,
                LegalName: _model.LegalName,
                Vkn: _model.Vkn,
                Email: _model.Email,
                Phone: _model.Phone,
                AdminFirstName: _model.AdminFirstName,
                AdminLastName: _model.AdminLastName,
                AdminEmail: _model.AdminEmail,
                AdminPhone: _model.AdminPhone);

            var result = await Mediator.Send(command);

            if (result.IsSuccess && result.Value is not null)
            {
                Nav.NavigateTo($"/tenant/companies/{result.Value.UrlCode}/edit");
            }
            else
            {
                _errorMessage = result.FirstError.Message;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = Loc["Common.UnexpectedError", ex.Message].Value;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
