@page "/tenant/companies"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IMainCatalogReader CompanyReader
@inject AuthenticationStateProvider AuthProvider
@inject PersistentComponentState PersistentState
@inject IStringLocalizer Loc
@implements IDisposable
@using CleanTenant.Application.Features.Main.Readers
@using CleanTenant.ManagementApp.Components.Shared

<PageTitle>@Loc["Companies.TenantList.PageTitle"]</PageTitle>

@*
    v0.2.4.a — Aktif Yönetim bağlamındaki Site listesi (sadece o yönetime ait).

    v0.2.13.d — Liste görünümü ortak CompaniesListView komponentine taşındı; bu
    sayfa yalnız aktif tenant_id'yi doğrular, sadece o tenant'a ait siteleri
    (GetByTenantAsync) yükler ve persistence yönetir. Tasarım Sistem sayfasıyla
    ortaktır (bkz. CompaniesListView); bağlam farkları: Yönetim kolonu gizli,
    Bina Şeması aksiyonu görünür.
*@

@if (_unauthorized)
{
    <MudAlert Severity="Severity.Warning" Class="my-3">
        @Loc["Companies.TenantList.NoTenant"]
    </MudAlert>
}
else
{
    <CompaniesListView Items="@_items"
                       EditRoutePrefix="/tenant/companies"
                       ShowTenantColumn="false"
                       ShowBuildingSchemaAction="true"
                       SearchPlaceholder="@Loc["Companies.TenantList.Search"]"
                       ExportTitle="@Loc["Companies.TenantList.ExportTitle", _tenantName ?? string.Empty].Value"
                       OnDeleted="ReloadAsync" />
}

@code {
    private const string PersistKey = "tenantarea.companies.list";
    private bool _unauthorized;
    private Guid? _activeTenantId;
    private string? _tenantName;
    private IReadOnlyList<CompanyListItem>? _items;
    private PersistingComponentStateSubscription _persistSubscription;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true)
        {
            _unauthorized = true;
            return;
        }

        if (user.FindFirst("tenant_id") is { Value: var tid } && Guid.TryParseExact(tid, "N", out var tenantGuid))
        {
            _activeTenantId = tenantGuid;
            _tenantName = user.FindFirst("tenant_name")?.Value;
        }
        else
        {
            _unauthorized = true;
            return;
        }

        if (PersistentState.TryTakeFromJson<List<CompanyListItem>>(PersistKey, out var cached) && cached is not null)
        {
            _items = cached;
        }
        else
        {
            _items = await CompanyReader.GetByTenantAsync(_activeTenantId.Value);
        }

        _persistSubscription = PersistentState.RegisterOnPersisting(() =>
        {
            PersistentState.PersistAsJson(PersistKey, _items);
            return Task.CompletedTask;
        });
    }

    private async Task ReloadAsync()
        => _items = await CompanyReader.GetByTenantAsync(_activeTenantId!.Value);

    public void Dispose() => _persistSubscription.Dispose();
}
