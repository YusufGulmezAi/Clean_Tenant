@page "/tenant/companies"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IMainCatalogReader CompanyReader
@inject AuthenticationStateProvider AuthProvider
@inject PersistentComponentState PersistentState
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable
@using CleanTenant.Application.Common.Export
@using CleanTenant.Application.Features.Main.Companies
@using CleanTenant.Application.Features.Main.Readers
@using CleanTenant.Domain.Tenant.Companies
@using CleanTenant.ManagementApp.Components.Shared
@using MediatR

@inject IMediator Mediator

<PageTitle>Siteler — Yönetim</PageTitle>

@*
    v0.2.4.a — DataTable<TItem> migration. Aktif Yönetim bağlamındaki Site
    listesi (sadece o yönetime ait olanlar).
*@

@if (_unauthorized)
{
    <MudAlert Severity="Severity.Warning" Class="my-3">
        Aktif Yönetim bağlamı yok. Önce bir Yönetim seçin.
    </MudAlert>
}
else
{
    <div Class="d-flex justify-between align-center mb-4">
        <div></div>
        <MudButton Href="/tenant/companies/new"
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Add">
            Yeni Site
        </MudButton>
    </div>

    <DataTable TItem="CompanyListItem"
               Items="@_items"
               Title="@($"Siteler — {_tenantName}")"
               SearchPlaceholder="Site ara…"
               SearchableFields="@(row => new[] { row.Name, row.UrlCode, row.LegalName, row.Vkn })"
               ExportColumns="@_exportColumns"
               ExportTitle="@($"{_tenantName}-Siteler")">
        <Columns>
            <PropertyColumn T="CompanyListItem" TProperty="string" Property="@(c => c.Name)" Title="Site Adı" />
            <PropertyColumn T="CompanyListItem" TProperty="string" Property="@(c => c.UrlCode)" Title="URL Kodu" />
            <PropertyColumn T="CompanyListItem" TProperty="string" Property="@(c => c.LegalName)" Title="Yasal Ad" />
            <PropertyColumn T="CompanyListItem" TProperty="string" Property="@(c => c.Vkn)" Title="VKN" />
            <PropertyColumn T="CompanyListItem" TProperty="CompanyStatus" Property="@(c => c.Status)" Title="Durum">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small"
                             Color="@(context.Item.Status == CompanyStatus.Active ? Color.Success : Color.Default)">
                        @context.Item.Status
                    </MudChip>
                </CellTemplate>
            </PropertyColumn>
            <TemplateColumn T="CompanyListItem" CellClass="d-flex justify-end gap-1" Filterable="false" Sortable="false">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   Color="Color.Info"
                                   Title="Düzenle"
                                   Href="@($"/tenant/companies/{context.Item.Id}/edit")" />
                    <MudIconButton Icon="@Icons.Material.Filled.Login"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   Title="Bu Site bağlamına geç"
                                   OnClick="@(() => SwitchAsync(context.Item.Id))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   Title="Sil"
                                   OnClick="@(() => DeleteAsync(context.Item.Id))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </DataTable>
}

@code {
    private const string PersistKey = "tenantarea.companies.list";
    private bool _unauthorized;
    private Guid? _activeTenantId;
    private string? _tenantName;
    private IReadOnlyList<CompanyListItem>? _items;
    private PersistingComponentStateSubscription _persistSubscription;

    private static readonly IReadOnlyList<ExportColumn<CompanyListItem>> _exportColumns =
    [
        new() { Header = "Site Adı", Selector = r => r.Name },
        new() { Header = "URL Kodu", Selector = r => r.UrlCode },
        new() { Header = "Yasal Ad", Selector = r => r.LegalName },
        new() { Header = "VKN", Selector = r => r.Vkn },
        new() { Header = "Durum", Selector = r => r.Status.ToString() },
    ];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true)
        {
            _unauthorized = true;
            return;
        }

        if (user.FindFirst("tenant_id") is { Value: var tid } && Guid.TryParseExact(tid, "N", out var tenantGuid))
        {
            _activeTenantId = tenantGuid;
            _tenantName = user.FindFirst("tenant_name")?.Value;
        }
        else
        {
            _unauthorized = true;
            return;
        }

        if (PersistentState.TryTakeFromJson<List<CompanyListItem>>(PersistKey, out var cached) && cached is not null)
        {
            _items = cached;
            return;
        }

        _items = await CompanyReader.GetByTenantAsync(_activeTenantId.Value);

        _persistSubscription = PersistentState.RegisterOnPersisting(() =>
        {
            PersistentState.PersistAsJson(PersistKey, _items);
            return Task.CompletedTask;
        });
    }

    private Task OnRowClick(DataGridRowClickEventArgs<CompanyListItem> args)
        => SwitchAsync(args.Item.Id);

    private async Task SwitchAsync(Guid companyId)
    {
        if (_activeTenantId is null) return;
        var returnUrl = "/" + Nav.ToBaseRelativePath(Nav.Uri);
        await JS.InvokeVoidAsync(
            "cleantenant.submitTenantSwitch",
            _activeTenantId.Value.ToString(),
            returnUrl,
            companyId.ToString());
    }

    private async Task DeleteAsync(Guid companyId)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Bu siteyi silmek istediğinizden emin misiniz?");
        if (!confirmed) return;

        var command = new DeleteCompanyCommand(companyId);
        var result = await Mediator.Send(command);

        if (result.IsSuccess)
        {
            _items = await CompanyReader.GetByTenantAsync(_activeTenantId!.Value);
        }
    }

    public void Dispose() => _persistSubscription.Dispose();
}
