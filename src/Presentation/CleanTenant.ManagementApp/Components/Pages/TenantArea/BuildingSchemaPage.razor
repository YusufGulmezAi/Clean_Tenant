    // ── Excel ────────────────────────────────────────────────────────────────

    private async Task DownloadTemplateAsync()
    {
        if (_isBusy) return;
        _isBusy = true;
        try
        {
            var result = await Mediator.Send(new GenerateBuildingSchemaTemplateQuery());
            if (result.IsSuccess)
            {
                var base64 = Convert.ToBase64String(result.Value!);
                await JS.InvokeVoidAsync("cleantenant.downloadBlobBase64",
                    "yapi-semasi-sablonu.xlsx", base64,
                    "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            }
            else Snackbar.Add(result.FirstError.Message, Severity.Error);
        }
        finally { _isBusy = false; }
    }

    private void OnImportFileSelected(InputFileChangeEventArgs e) => _importFile = e.File;

    private async Task ImportExcelAsync()
    {
        if (_importFile is null || _isBusy) return;
        _isBusy = true;
        try
        {
            await using var stream = _importFile.OpenReadStream(maxAllowedSize: 10_485_760);
            var result = await Mediator.Send(new ImportBuildingSchemaCommand(CompanyId, stream));

            if (result.IsFailure) { Snackbar.Add(result.FirstError.Message, Severity.Error); return; }

            var importResult = result.Value;
            if (importResult is null) return;
            if (importResult.HasErrors && importResult.ErrorWorkbook is not null)
            {
                var base64 = Convert.ToBase64String(importResult.ErrorWorkbook);
                await JS.InvokeVoidAsync("cleantenant.downloadBlobBase64",
                    "yapi-semasi-hatalar.xlsx", base64,
                    "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
                Snackbar.Add("Excel'de hatalar var. Hata raporu indirildi.", Severity.Warning);
            }
            else
            {
                Snackbar.Add($"{importResult.ImportedUnitCount} bağımsız bölüm aktarıldı.", Severity.Success);
                _showImport = false;
                _importFile = null;
                await LoadSchemaAsync();
            }
        }
        finally { _isBusy = false; }
    }

