    // ── Inner models ─────────────────────────────────────────────────────────

    private sealed class BuildingFormModel
    {
        public string Name { get; set; } = string.Empty;
        public string? MunicipalNo { get; set; }
        public BuildingType Type { get; set; } = BuildingType.Residential;

        public void Reset()
        {
            Name = string.Empty;
            MunicipalNo = null;
            Type = BuildingType.Residential;
        }

        public void Load(BuildingDto b)
        {
            Name = b.Name;
            MunicipalNo = b.MunicipalNo;
            Type = b.Type;
        }
    }

    private sealed class UnitFormModel
    {
        public string Number { get; set; } = string.Empty;
        public string? NationalAddressCode { get; set; }
        public UnitType Type { get; set; } = UnitType.Apartment;
        public decimal SquareMeters { get; set; }
        public int LandShare { get; set; }
        public decimal? AllocatedArea { get; set; }
        public int Floor { get; set; }
        public CleanTenant.Domain.Tenant.BuildingSchema.Orientation Orientation { get; set; } = CleanTenant.Domain.Tenant.BuildingSchema.Orientation.Unknown;
        public ApartmentLayout Layout { get; set; } = ApartmentLayout.OneBedroom;

        public void Reset()
        {
            Number = string.Empty;
            NationalAddressCode = null;
            Type = UnitType.Apartment;
            SquareMeters = 0;
            LandShare = 0;
            AllocatedArea = null;
            Floor = 0;
            Orientation = CleanTenant.Domain.Tenant.BuildingSchema.Orientation.Unknown;
            Layout = ApartmentLayout.OneBedroom;
        }

        public void Load(UnitDto u)
        {
            Number = u.Number;
            NationalAddressCode = u.NationalAddressCode;
            Type = u.Type;
            SquareMeters = u.SquareMeters;
            LandShare = u.LandShare;
            AllocatedArea = u.AllocatedArea;
            Floor = u.Floor;
            Orientation = u.Orientation;
            Layout = u.Layout;
        }
    }
