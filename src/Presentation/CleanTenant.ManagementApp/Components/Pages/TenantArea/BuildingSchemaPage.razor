    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        if (authState.User?.Identity?.IsAuthenticated != true)
        {
            _unauthorized = true;
            _isLoading = false;
            return;
        }

        var company = await CompanyReader.GetByIdAsync(CompanyId);
        if (company is null)
        {
            _unauthorized = true;
            _isLoading = false;
            return;
        }

        _companyName = company.Name;
        await LoadSchemaAsync();
    }

    private async Task LoadSchemaAsync()
    {
        _isLoading = true;
        var result = await Mediator.Send(new GetBuildingSchemaQuery(CompanyId));
        _schema = result.IsSuccess ? result.Value : null;
        _isLoading = false;
    }

    // ── Block ────────────────────────────────────────────────────────────────

    private void StartEditBlock(BlockDto block)
    {
        _editingBlockId = block.Id;
        _editingBlockName = block.Name;
    }

    private async Task AddBlockAsync()
    {
        if (string.IsNullOrWhiteSpace(_addBlockName) || _isBusy) return;
        _isBusy = true;
        try
        {
            var result = await Mediator.Send(new CreateBlockCommand(CompanyId, _addBlockName.Trim()));
            if (result.IsSuccess)
            {
                _addBlockName = string.Empty;
                _showAddBlock = false;
                await LoadSchemaAsync();
            }
            else Snackbar.Add(result.FirstError.Message, Severity.Error);
        }
        finally { _isBusy = false; }
    }

    private async Task SaveEditBlockAsync()
    {
        if (_editingBlockId is null || string.IsNullOrWhiteSpace(_editingBlockName) || _isBusy) return;
        _isBusy = true;
        try
        {
            var result = await Mediator.Send(new UpdateBlockCommand(_editingBlockId.Value, _editingBlockName.Trim()));
            if (result.IsSuccess) { _editingBlockId = null; await LoadSchemaAsync(); }
            else Snackbar.Add(result.FirstError.Message, Severity.Error);
        }
        finally { _isBusy = false; }
    }

    private async Task DeleteBlockAsync(Guid blockId, string name)
    {
        if (_isBusy) return;
        var ok = await JS.InvokeAsync<bool>("confirm", $"Ada '{name}' silinecek. Devam edilsin mi?");
        if (!ok) return;
        _isBusy = true;
        try
        {
            var result = await Mediator.Send(new DeleteBlockCommand(blockId));
            if (result.IsSuccess) await LoadSchemaAsync();
            else Snackbar.Add(result.FirstError.Message, Severity.Error);
        }
        finally { _isBusy = false; }
    }

    private async Task MoveBlockAsync(BlockDto block, int direction)
    {
        if (_isBusy) return;
        var ordered = _schema!.Blocks.OrderBy(b => b.SortOrder).ToList();
        var idx = ordered.IndexOf(block);
        if (idx + direction < 0 || idx + direction >= ordered.Count) return;
        ordered.RemoveAt(idx);
        ordered.Insert(idx + direction, block);
        _isBusy = true;
        try
        {
            var result = await Mediator.Send(
                new ReorderBlocksCommand(CompanyId, ordered.Select(b => b.Id).ToList()));
            if (result.IsSuccess) await LoadSchemaAsync();
            else Snackbar.Add(result.FirstError.Message, Severity.Error);
        }
        finally { _isBusy = false; }
    }

