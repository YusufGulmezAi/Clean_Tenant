    // ── Unit ─────────────────────────────────────────────────────────────────

    private void ToggleAddUnit(Guid buildingId)
    {
        if (_unitFormBuildingId == buildingId)
        {
            _unitFormBuildingId = null;
        }
        else
        {
            _unitFormBuildingId = buildingId;
            _isEditingUnit = false;
            _editingUnitId = null;
            _unitForm.Reset();
        }
    }

    private void StartEditUnit(Guid buildingId, UnitDto unit)
    {
        _unitFormBuildingId = buildingId;
        _isEditingUnit = true;
        _editingUnitId = unit.Id;
        _unitForm.Load(unit);
    }

    private async Task SaveUnitAsync()
    {
        if (string.IsNullOrWhiteSpace(_unitForm.Number) || _isBusy) return;
        _isBusy = true;
        try
        {
            if (_isEditingUnit && _editingUnitId.HasValue)
            {
                var result = await Mediator.Send(new UpdateUnitCommand(
                    _editingUnitId.Value,
                    _unitForm.Number.Trim(),
                    _unitForm.NationalAddressCode?.Trim(),
                    _unitForm.Type,
                    _unitForm.SquareMeters,
                    _unitForm.LandShare,
                    _unitForm.AllocatedArea,
                    _unitForm.Floor,
                    _unitForm.Orientation,
                    _unitForm.Layout));

                if (result.IsSuccess)
                {
                    _unitFormBuildingId = null;
                    _editingUnitId = null;
                    _isEditingUnit = false;
                    _unitForm.Reset();
                    await LoadSchemaAsync();
                }
                else Snackbar.Add(result.FirstError.Message, Severity.Error);
            }
            else if (_unitFormBuildingId.HasValue)
            {
                var result = await Mediator.Send(new CreateUnitCommand(
                    _unitFormBuildingId.Value,
                    _unitForm.Number.Trim(),
                    _unitForm.NationalAddressCode?.Trim(),
                    _unitForm.Type,
                    _unitForm.SquareMeters,
                    _unitForm.LandShare,
                    _unitForm.AllocatedArea,
                    _unitForm.Floor,
                    _unitForm.Orientation,
                    _unitForm.Layout));

                if (result.IsSuccess)
                {
                    _unitForm.Reset();
                    Snackbar.Add("BB eklendi.", Severity.Success);
                    await LoadSchemaAsync();
                }
                else Snackbar.Add(result.FirstError.Message, Severity.Error);
            }
        }
        finally { _isBusy = false; }
    }

