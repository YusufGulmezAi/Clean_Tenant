@page "/about"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IStringLocalizer Loc

<PageTitle>@Loc["About.PageTitle"]</PageTitle>

@*
    v0.2.10.e.6 — About.* anahtarlarıyla lokalize edildi. Teknik stack ve
    Faz 0 çıktıları geliştirici notları olarak raw bırakıldı.
*@

<MudText Typo="Typo.h4" Class="mb-4">@Loc["About.Title"]</MudText>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudPaper Elevation="0" Outlined="true" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">@Loc["About.AppSection"]</MudText>
            <MudList T="string" Dense="true">
                <MudListItem Icon="@Icons.Material.Filled.Apps">@Loc["About.Name"] @AppName</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Tag">@Loc["About.Version"] @AppVersion</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Schedule">@Loc["About.Phase"] 1 (UI başlangıç)</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Memory">.NET 10 + Blazor Server + MudBlazor</MudListItem>
            </MudList>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Elevation="0" Outlined="true" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">@Loc["About.PhaseZero.Title"]</MudText>
            <MudList T="string" Dense="true">
                <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">Auth + 2FA + Multi-scope + Support Mode</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">MediatR pipeline + FluentValidation + Permission Checker</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">Audit Interceptor + Serilog (4 DB)</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">146 yeşil test + 4 git tag</MudListItem>
            </MudList>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private const string AppName = "CleanTenant Yönetim";
    private static readonly string AppVersion =
        System.Reflection.Assembly.GetEntryAssembly()?.GetName().Version?.ToString() ?? "0.2.1";
}
