@page "/company/accounting/settings"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject AuthenticationStateProvider AuthProvider
@inject MediatR.IMediator Mediator
@inject ISnackbar Snackbar
@inject IStringLocalizer Loc
@using CleanTenant.SharedKernel.Common.Results
@using CleanTenant.Application.Features.Main.Accounting.AccountingSettings
@using CleanTenant.Domain.Tenant.Accounting.Enums

<PageTitle>Muhasebe Ayarları</PageTitle>

@if (_unauthorized)
{
    <MudAlert Severity="Severity.Warning" Class="my-3">
        Bu sayfaya erişim yetkiniz bulunmuyor. Şirket kapsamında giriş yapınız.
    </MudAlert>
}
else if (!_initialized)
{
    <MudText Typo="Typo.h6" Class="my-3">Yükleniyor...</MudText>
}
else
{
    <MudText Typo="Typo.h5" Class="mb-4">Muhasebe Ayarları</MudText>

    @if (_settings is null || !_settings.IsActivated)
    {
        <MudAlert Severity="Severity.Info" Class="mb-4">
            Şirket için muhasebe henüz aktifleştirilmemiş. Aktifleştirme; hesap planını (TDHP)
            ve <b>ilk mali yılı</b> oluşturur. Mali yıl tarih aralığını sitenin kendi dönemine
            göre aşağıdan ayarlayabilirsiniz (varsayılan cari takvim yılı).
        </MudAlert>

        <MudPaper Class="pa-4 mb-4" Elevation="1">
            <MudText Typo="Typo.subtitle1" Class="mb-3">İlk Mali Yıl</MudText>
            <MudForm @ref="_fyMudForm">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="4">
                        <MudTextField @bind-Value="_fyForm.Label" Label="Etiket (örn: 2026, 2026-2027)"
                                      Required="true" MaxLength="50" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker @bind-Date="_fyForm.StartDateDt" Label="Başlangıç Tarihi"
                                       DateFormat="dd.MM.yyyy" Required="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker @bind-Date="_fyForm.EndDateDt" Label="Bitiş Tarihi"
                                       DateFormat="dd.MM.yyyy" Required="true" />
                    </MudItem>
                    @if (_fyForm.IsNonCalendar)
                    {
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Info" Dense="true">
                                Takvim dışı mali yıl: başlangıç ve bitiş yılları farklı.
                            </MudAlert>
                        </MudItem>
                    }
                </MudGrid>
            </MudForm>
            <div class="d-flex justify-center mt-4">
                <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.AccountBalance"
                           OnClick="@ActivateAsync" Disabled="@_activating">
                    @if (_activating)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Muhasebeyi Aktifleştir
                </MudButton>
            </div>
        </MudPaper>
    }
    else
    {
        <MudPaper Class="pa-4" Elevation="1">
            <MudAlert Severity="Severity.Success" Dense="true" Class="mb-4">
                Muhasebe modülü aktif. Aktivasyon ayarı değiştirilemez.
            </MudAlert>

            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@(_settings.DefaultCurrency)"
                                  Label="Varsayılan Para Birimi"
                                  ReadOnly="true"
                                  HelperText="Aktivasyon sırasında belirlenir, değiştirilemez." />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="VatPeriod" @bind-Value="_form.VatPeriod" Label="KDV Periyodu">
                        @foreach (VatPeriod p in Enum.GetValues<VatPeriod>())
                        {
                            <MudSelectItem Value="p">@GetVatPeriodLabel(p)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSwitch T="bool" @bind-Value="_form.RequireApproval"
                               Label="Çift İmza (Dual-Control) Onayı"
                               Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSwitch T="bool" @bind-Value="_form.EDefterEnabled"
                               Label="e-Defter Etkin"
                               Color="Color.Primary" />
                </MudItem>
            </MudGrid>

            <div class="d-flex gap-2 mt-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="@SaveAsync" Disabled="@_saving">
                    @if (_saving)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Kaydet
                </MudButton>
            </div>
        </MudPaper>
    }
}

@code {
    private Guid _companyId;
    private Guid? _tenantId;
    private bool _unauthorized;
    private bool _initialized;
    private bool _saving;
    private bool _activating;

    private AccountingSettingsDto? _settings;
    private SettingsForm _form = new();
    private MudForm? _fyMudForm;
    private FiscalYearActivationForm _fyForm = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true) { _unauthorized = true; _initialized = true; return; }
        var scope = user.FindFirst("scope")?.Value;
        if (!string.Equals(scope, "Company", StringComparison.OrdinalIgnoreCase)) { _unauthorized = true; _initialized = true; return; }
        if (user.FindFirst("company_id") is { Value: var cid } && Guid.TryParseExact(cid, "N", out var cGuid))
            _companyId = cGuid;
        else { _unauthorized = true; _initialized = true; return; }
        if (user.FindFirst("tenant_id") is { Value: var tid } && Guid.TryParseExact(tid, "N", out var tGuid))
            _tenantId = tGuid;
        _fyForm.Label = DateTime.Today.Year.ToString(System.Globalization.CultureInfo.InvariantCulture);
        await LoadDataAsync();
        _initialized = true;
    }

    private async Task LoadDataAsync()
    {
        var result = await Mediator.Send(new GetAccountingSettingsQuery(_companyId));
        if (result.IsSuccess && result.Value is { } s)
        {
            _settings = s;
            _form = new SettingsForm
            {
                RequireApproval = s.RequireApproval,
                VatPeriod = s.VatPeriod,
                EDefterEnabled = s.EDefterEnabled
            };
        }
        // IsActivated false ise veya henüz kayıt yoksa _settings null kalır
    }

    private async Task ActivateAsync()
    {
        if (_tenantId is null)
        {
            Snackbar.Add("Kiracı bilgisi bulunamadı.", Severity.Error);
            return;
        }

        if (_fyMudForm is not null)
        {
            await _fyMudForm.Validate();
            if (!_fyMudForm.IsValid) return;
        }
        if (_fyForm.StartDate is null || _fyForm.EndDate is null)
        {
            Snackbar.Add("Mali yıl başlangıç ve bitiş tarihi zorunludur.", Severity.Warning);
            return;
        }
        if (_fyForm.EndDate <= _fyForm.StartDate)
        {
            Snackbar.Add("Bitiş tarihi başlangıç tarihinden sonra olmalıdır.", Severity.Warning);
            return;
        }

        _activating = true;
        try
        {
            var result = await Mediator.Send(new ActivateAccountingCommand(
                _companyId, _tenantId.Value, _fyForm.Label, _fyForm.StartDate, _fyForm.EndDate));
            if (result.IsFailure)
            {
                Snackbar.Add(result.FirstError.Message, Severity.Error);
                return;
            }

            Snackbar.Add("Muhasebe modülü başarıyla aktifleştirildi.", Severity.Success);
            await LoadDataAsync();
        }
        finally
        {
            _activating = false;
        }
    }

    private async Task SaveAsync()
    {
        if (_settings is null) return;

        _saving = true;
        try
        {
            var result = await Mediator.Send(new UpdateAccountingSettingsCommand(
                _companyId,
                _form.RequireApproval,
                _settings.DefaultCurrency,
                _form.VatPeriod,
                _form.EDefterEnabled));

            if (result.IsFailure)
            {
                Snackbar.Add(result.FirstError.Message, Severity.Error);
                return;
            }

            Snackbar.Add("Muhasebe ayarları kaydedildi.", Severity.Success);
            await LoadDataAsync();
        }
        finally
        {
            _saving = false;
        }
    }

    private static string GetVatPeriodLabel(VatPeriod p) => p switch
    {
        VatPeriod.Monthly => "Aylık",
        VatPeriod.Quarterly => "3 Aylık",
        _ => p.ToString()
    };

    private class SettingsForm
    {
        public bool RequireApproval { get; set; }
        public VatPeriod VatPeriod { get; set; } = VatPeriod.Monthly;
        public bool EDefterEnabled { get; set; }
    }

    private sealed class FiscalYearActivationForm
    {
        public string Label { get; set; } = "";
        public DateTime? StartDateDt { get; set; } = new DateTime(DateTime.Today.Year, 1, 1);
        public DateTime? EndDateDt { get; set; } = new DateTime(DateTime.Today.Year, 12, 31);
        public DateOnly? StartDate => StartDateDt.HasValue ? DateOnly.FromDateTime(StartDateDt.Value) : null;
        public DateOnly? EndDate => EndDateDt.HasValue ? DateOnly.FromDateTime(EndDateDt.Value) : null;
        public bool IsNonCalendar => StartDate.HasValue && EndDate.HasValue && StartDate.Value.Year != EndDate.Value.Year;
    }
}
