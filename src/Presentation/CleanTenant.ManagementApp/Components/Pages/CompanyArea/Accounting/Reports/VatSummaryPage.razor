@page "/company/accounting/reports/vat-summary"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject AuthenticationStateProvider AuthProvider
@inject MediatR.IMediator Mediator
@inject ISnackbar Snackbar
@inject IStringLocalizer Loc
@using CleanTenant.SharedKernel.Common.Results
@using CleanTenant.Application.Features.Main.Accounting.Reports
@using CleanTenant.Application.Features.Main.Accounting.Readers
@using CleanTenant.Application.Features.Main.Accounting.FiscalYears
@using CleanTenant.Application.Features.Main.Accounting.AccountCodes
@using CleanTenant.Domain.Tenant.Accounting.Enums

<PageTitle>KDV Raporu</PageTitle>

@if (_unauthorized)
{
    <MudAlert Severity="Severity.Warning" Class="my-3">
        Bu sayfaya erişim yetkiniz bulunmuyor. Şirket kapsamında giriş yapınız.
    </MudAlert>
}
else if (!_initialized)
{
    <MudText Typo="Typo.h6" Class="my-3">Yükleniyor...</MudText>
}
else
{
    <MudText Typo="Typo.h5" Class="mb-4">KDV Raporu</MudText>

    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="3">
                <MudNumericField T="int" @bind-Value="_selectedYear"
                                 Label="Yıl"
                                 Min="2000"
                                 Max="2099"
                                 Required="true" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="int" @bind-Value="_selectedMonth"
                           Label="Ay"
                           AnchorOrigin="Origin.BottomLeft"
                           Required="true">
                    @for (int m = 1; m <= 12; m++)
                    {
                        var month = m;
                        <MudSelectItem T="int" Value="month">@month. Ay</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           FullWidth="true"
                           Disabled="@_loading"
                           OnClick="@LoadReportAsync">
                    Raporu Görüntüle
                </MudButton>
            </MudItem>
        </MudGrid>
        @if (_loading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-3" />
        }
    </MudPaper>

    @if (_hasResult)
    {
        <MudStack Row="true" Spacing="2" Class="mb-2">
            <MudButton StartIcon="@Icons.Material.Filled.PictureAsPdf"
                       Color="Color.Error" Variant="Variant.Outlined"
                       Disabled="true">PDF</MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.TableChart"
                       Color="Color.Success" Variant="Variant.Outlined"
                       Disabled="true">Excel</MudButton>
        </MudStack>

        @if (_report is null)
        {
            <MudAlert Severity="Severity.Info">
                Rapor verisi bulunamadı. (Faz 6 implementasyonuyla tamamlanacak)
            </MudAlert>
        }
        else
        {
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4" Elevation="2">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">İndirilecek KDV</MudText>
                        <MudText Typo="Typo.h6" Color="Color.Success">
                            @_report.IndirilecekKdv.ToString("N2") TL
                        </MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4" Elevation="2">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Hesaplanan KDV</MudText>
                        <MudText Typo="Typo.h6" Color="Color.Warning">
                            @_report.HesaplananKdv.ToString("N2") TL
                        </MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4" Elevation="2">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Devreden KDV</MudText>
                        <MudText Typo="Typo.h6" Color="Color.Info">
                            @_report.Devreden.ToString("N2") TL
                        </MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4" Elevation="2" Style="border: 2px solid var(--mud-palette-error);">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Ödenecek KDV</MudText>
                        <MudText Typo="Typo.h6" Color="Color.Error">
                            <b>@_report.Odenecek.ToString("N2") TL</b>
                        </MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    }
}

@code {
    private Guid _companyId;
    private Guid? _tenantId;
    private bool _unauthorized;
    private bool _initialized;
    private bool _loading;
    private bool _hasResult;

    private int _selectedYear = DateTime.Today.Year;
    private int _selectedMonth = DateTime.Today.Month;
    private VatSummaryReport? _report;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true) { _unauthorized = true; _initialized = true; return; }
        var scope = user.FindFirst("scope")?.Value;
        if (!string.Equals(scope, "Company", StringComparison.OrdinalIgnoreCase)) { _unauthorized = true; _initialized = true; return; }
        if (user.FindFirst("company_id") is { Value: var cid } && Guid.TryParseExact(cid, "N", out var cGuid))
            _companyId = cGuid;
        else { _unauthorized = true; _initialized = true; return; }
        if (user.FindFirst("tenant_id") is { Value: var tid } && Guid.TryParseExact(tid, "N", out var tGuid))
            _tenantId = tGuid;

        _initialized = true;
    }

    private async Task LoadReportAsync()
    {
        _loading = true;
        _hasResult = false;
        StateHasChanged();

        var result = await Mediator.Send(new GetVatSummaryQuery(_companyId, _selectedYear, _selectedMonth));

        if (result.IsFailure)
        {
            Snackbar.Add($"Rapor yüklenemedi: {result.FirstError.Message}", Severity.Error);
        }
        else
        {
            _report = result.Value;
            _hasResult = true;
        }

        _loading = false;
    }
}
