                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Title="Düzenle"
                                               OnClick="@(() => OpenEditUnit(unit, buildingId))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" Title="Sil"
                                               OnClick="@(() => DeleteUnitAsync(unit))" />
