@page "/company/building-schema"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject AuthenticationStateProvider AuthProvider
@inject MediatR.IMediator Mediator
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IStringLocalizer Loc
@inject IJSRuntime JS
@inject IMainCatalogReader CompanyReader
@using CleanTenant.SharedKernel.Common.Results
@using CleanTenant.Application.Features.Main.Readers
@using CleanTenant.Application.Features.Main.BuildingSchema.Excel
@using CleanTenant.Application.Features.Main.BuildingSchema.Queries
@using CleanTenant.Application.Features.Main.BuildingSchema.Lands
@using CleanTenant.Application.Features.Main.BuildingSchema.Parcels
@using CleanTenant.Application.Features.Main.BuildingSchema.Buildings
@using CleanTenant.Application.Features.Main.BuildingSchema.Blocks
@using CleanTenant.Application.Features.Main.BuildingSchema.Units
@using CleanTenant.Domain.Tenant.BuildingSchema
@* Orientation hem MudBlazor'da hem domain'de var; bu sayfada domain enum'unu kastediyoruz. *@
@using Orientation = CleanTenant.Domain.Tenant.BuildingSchema.Orientation

<PageTitle>Yapı Şeması</PageTitle>

@if (_unauthorized)
{
    <MudAlert Severity="Severity.Warning" Class="my-3">
        Bu sayfaya erişim yetkiniz bulunmuyor. Şirket kapsamında giriş yapınız.
    </MudAlert>
}
else if (!_initialized)
{
    <MudProgressLinear Indeterminate="true" Class="my-3" />
}
else
{
    <div class="d-flex align-center justify-space-between mb-4">
        <MudText Typo="Typo.h5">Yapı Şeması</MudText>
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="@ReloadAsync" Size="Size.Small">Yenile</MudButton>
            <MudButton Variant="Variant.Outlined" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.FileDownload"
                       OnClick="@DownloadTemplateAsync" Disabled="@_busy">Şablon İndir</MudButton>
            @if (_canManage)
            {
                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Upload"
                           OnClick="@(() => _showImport = !_showImport)">Excel Yükle</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.AddLocationAlt"
                           OnClick="@(() => OpenForm(FormMode.AddLand, Guid.Empty))">
                    Ada Ekle
                </MudButton>
            }
        </div>
    </div>

    @if (_showImport)
    {
        <MudPaper Elevation="1" Class="pa-4 mb-4">
            <MudText Typo="Typo.subtitle1" GutterBottom="true">Excel ile Toplu Yükleme</MudText>
            <MudText Typo="Typo.body2" Class="mb-2" Color="Color.Secondary">
                Önce "Şablon İndir" ile şablonu alıp talimatlara göre doldurun, sonra buradan yükleyin.
                Hatalı satırlar, en sağda kırmızı "HATA" kolonu işaretlenmiş bir dosya olarak geri indirilir.
            </MudText>
            <InputFile id="bs-import-file" OnChange="OnImportFileSelected" accept=".xlsx" style="display:none" />
            <div class="d-flex align-center gap-3 flex-wrap">
                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.AttachFile"
                           Disabled="@_busy"
                           OnClick="@(async () => await JS.InvokeVoidAsync("cleantenant.clickElement", "bs-import-file"))">
                    Dosya Seç
                </MudButton>
                @if (_importFile is not null)
                {
                    <MudText Typo="Typo.body2">@_importFile.Name</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="@ImportExcelAsync" Disabled="@_busy">
                        @if (_busy)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Yükleniyor…</span>
                        }
                        else
                        {
                            <span>Yükle</span>
                        }
                    </MudButton>
                }
            </div>
        </MudPaper>
    }

    @* ── Genel toplam kartları (Dashboard stili, renkli arka plan) ── *@
    @if (_schema is not null)
    {
        <MudGrid Class="mb-4" Spacing="2">
            <MudItem xs="6" sm="4" md="2">
                <MudPaper Elevation="2" Class="pa-3 d-flex flex-column" Style="height:100%;background:var(--mud-palette-primary);color:#fff;">
                    <div class="d-flex align-center mb-1">
                        <MudIcon Icon="@Icons.Material.Filled.Map" Size="Size.Small" Style="color:#fff" />
                        <MudText Typo="Typo.subtitle2" Class="ml-2">Ada</MudText>
                    </div>
                    <MudText Typo="Typo.h4">@LandCount.ToString("N0")</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" sm="4" md="2">
                <MudPaper Elevation="2" Class="pa-3 d-flex flex-column" Style="height:100%;background:var(--mud-palette-info);color:#fff;">
                    <div class="d-flex align-center mb-1">
                        <MudIcon Icon="@Icons.Material.Filled.Layers" Size="Size.Small" Style="color:#fff" />
                        <MudText Typo="Typo.subtitle2" Class="ml-2">Parsel</MudText>
                    </div>
                    <MudText Typo="Typo.h4">@ParcelCount.ToString("N0")</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" sm="4" md="2">
                <MudPaper Elevation="2" Class="pa-3 d-flex flex-column" Style="height:100%;background:var(--mud-palette-tertiary);color:#fff;">
                    <div class="d-flex align-center mb-1">
                        <MudIcon Icon="@Icons.Material.Filled.Apartment" Size="Size.Small" Style="color:#fff" />
                        <MudText Typo="Typo.subtitle2" Class="ml-2">Bina</MudText>
                    </div>
                    <MudText Typo="Typo.h4">@BuildingCount.ToString("N0")</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" sm="4" md="2">
                <MudPaper Elevation="2" Class="pa-3 d-flex flex-column" Style="height:100%;background:var(--mud-palette-success);color:#fff;">
                    <div class="d-flex align-center mb-1">
                        <MudIcon Icon="@Icons.Material.Filled.MeetingRoom" Size="Size.Small" Style="color:#fff" />
                        <MudText Typo="Typo.subtitle2" Class="ml-2">BB</MudText>
                    </div>
                    <MudText Typo="Typo.h4">@AllUnits.Count.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,.85)">@UnitTypeBreakdown(AllUnits)</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" sm="4" md="2">
                <MudPaper Elevation="2" Class="pa-3 d-flex flex-column" Style="height:100%;background:var(--mud-palette-secondary);color:#fff;">
                    <div class="d-flex align-center mb-1">
                        <MudIcon Icon="@Icons.Material.Filled.SquareFoot" Size="Size.Small" Style="color:#fff" />
                        <MudText Typo="Typo.subtitle2" Class="ml-2">Toplam m²</MudText>
                    </div>
                    <MudText Typo="Typo.h4">@TotalSqm.ToString("#,##0.##")</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" sm="4" md="2">
                <MudPaper Elevation="2" Class="pa-3 d-flex flex-column" Style="height:100%;background:var(--mud-palette-dark);color:#fff;">
                    <div class="d-flex align-center mb-1">
                        <MudIcon Icon="@Icons.Material.Filled.AspectRatio" Size="Size.Small" Style="color:#fff" />
                        <MudText Typo="Typo.subtitle2" Class="ml-2">Toplam Tahsis Alanı</MudText>
                    </div>
                    <MudText Typo="Typo.h4">@TotalAllocated.ToString("#,##0.##")</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" sm="4" md="2">
                <MudPaper Elevation="2" Class="pa-3 d-flex flex-column" Style="height:100%;background:var(--mud-palette-warning);color:#fff;">
                    <div class="d-flex align-center mb-1">
                        <MudIcon Icon="@Icons.Material.Filled.Percent" Size="Size.Small" Style="color:#fff" />
                        <MudText Typo="Typo.subtitle2" Class="ml-2">Toplam Arsa Payı</MudText>
                    </div>
                    <MudText Typo="Typo.h4">@TotalLandShare.ToString("N0")</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }

    @* ── Ada Ekleme Formu (en üst) ─────────────────────────────────── *@
    @if (_formMode == FormMode.AddLand)
    {
        <MudPaper Class="pa-4 mb-3 border-l-4 mud-border-primary" Elevation="1">
            <MudText Typo="Typo.subtitle1" Class="mb-2">Yeni Ada</MudText>
            <div class="d-flex gap-2 align-center">
                <MudTextField @bind-Value="_formName" Label="Ada Adı" Variant="Variant.Outlined"
                              Margin="Margin.Dense" Style="max-width:320px" Immediate="true" />
                <MudButton Color="Color.Primary" Variant="Variant.Filled"
                           OnClick="@SaveLandAsync" Disabled="@string.IsNullOrWhiteSpace(_formName)">Kaydet</MudButton>
                <MudButton Variant="Variant.Text" OnClick="@CancelForm">İptal</MudButton>
            </div>
        </MudPaper>
    }

    @if (_schema is null || _schema.Lands.Count == 0)
    {
        <MudAlert Severity="Severity.Info">
            Henüz ada tanımlanmamış. "Ada Ekle" ile başlayın.
        </MudAlert>
    }
    else
    {
        <MudExpansionPanels MultiExpansion="true">
        @foreach (var land in _schema.Lands.OrderBy(l => l.SortOrder))
        {
            <MudExpansionPanel @key="land.Id" Expanded="@_expanded.Contains(land.Id)"
                               ExpandedChanged="@(v => SetExpanded(land.Id, v))">
                <TitleContent>
                    <div class="d-flex align-center" style="width:100%">
                        <MudIcon Icon="@Icons.Material.Filled.Map" Color="Color.Primary" Class="mr-2" />
                        <MudText Typo="Typo.subtitle1" Class="fw-bold mr-2">@land.Name</MudText>
                        @LandSummary(land)
                        @if (_canManage)
                        {
                            <div class="d-flex gap-1" @onclick:stopPropagation="true">
                                <MudIconButton Icon="@Icons.Material.Filled.AddCircleOutline" Size="Size.Small"
                                               Title="Parsel Ekle" Color="Color.Success"
                                               OnClick="@(() => OpenForm(FormMode.AddParcel, land.Id))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                               Title="Ada Düzenle" Color="Color.Default"
                                               OnClick="@(() => OpenForm(FormMode.EditLand, land.Id, land.Name))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Title="Ada Sil" Color="Color.Error"
                                               OnClick="@(() => DeleteLandAsync(land))" />
                            </div>
                        }
                    </div>
                </TitleContent>
                <ChildContent>
                @* Performans: ağır içerik yalnız panel açıkken render edilir (lazy). *@
                @if (_expanded.Contains(land.Id))
                {
                    @* ── Ada düzenleme / parsel ekleme formu ─── *@
                    @if (_formMode == FormMode.EditLand && _formParentId == land.Id)
                    {
                        <MudPaper Class="pa-3 mb-3 mud-border-warning border-l-4" Elevation="0">
                            <div class="d-flex gap-2 align-center">
                                <MudTextField @bind-Value="_formName" Label="Ada Adı" Variant="Variant.Outlined"
                                              Margin="Margin.Dense" Style="max-width:320px" Immediate="true" />
                                <MudButton Color="Color.Primary" Variant="Variant.Filled"
                                           OnClick="@SaveLandAsync" Disabled="@string.IsNullOrWhiteSpace(_formName)">Kaydet</MudButton>
                                <MudButton Variant="Variant.Text" OnClick="@CancelForm">İptal</MudButton>
                            </div>
                        </MudPaper>
                    }
                    @if (_formMode == FormMode.AddParcel && _formParentId == land.Id)
                    {
                        <MudPaper Class="pa-3 mb-3 mud-border-success border-l-4" Elevation="0">
                            <MudText Typo="Typo.body2" Class="mb-1">Yeni Parsel</MudText>
                            <div class="d-flex gap-2 align-center">
                                <MudTextField @bind-Value="_formName" Label="Parsel Adı" Variant="Variant.Outlined"
                                              Margin="Margin.Dense" Style="max-width:320px" Immediate="true" />
                                <MudButton Color="Color.Success" Variant="Variant.Filled"
                                           OnClick="@SaveParcelAsync" Disabled="@string.IsNullOrWhiteSpace(_formName)">Kaydet</MudButton>
                                <MudButton Variant="Variant.Text" OnClick="@CancelForm">İptal</MudButton>
                            </div>
                        </MudPaper>
                    }

                    @* ── Parseller ─── *@
                    <MudExpansionPanels MultiExpansion="true" Class="ml-4">
                    @foreach (var parcel in land.Parcels.OrderBy(p => p.SortOrder))
                    {
                        <MudExpansionPanel @key="parcel.Id" Expanded="@_expanded.Contains(parcel.Id)"
                                           ExpandedChanged="@(v => SetExpanded(parcel.Id, v))">
                            <TitleContent>
                                <div class="d-flex align-center" style="width:100%">
                                    <MudIcon Icon="@Icons.Material.Filled.Layers" Size="Size.Small" Color="Color.Secondary" Class="mr-2" />
                                    <MudText Typo="Typo.body1" Class="mr-2">@parcel.Name</MudText>
                                    @ParcelSummary(parcel)
                                    @if (_canManage)
                                    {
                                        <div class="d-flex gap-1" @onclick:stopPropagation="true">
                                            <MudIconButton Icon="@Icons.Material.Filled.AddCircleOutline" Size="Size.Small"
                                                           Title="Yapı Ekle" Color="Color.Success"
                                                           OnClick="@(() => OpenForm(FormMode.AddBuilding, parcel.Id))" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                           Title="Parsel Düzenle" Color="Color.Default"
                                                           OnClick="@(() => OpenForm(FormMode.EditParcel, parcel.Id, parcel.Name))" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                           Title="Parsel Sil" Color="Color.Error"
                                                           OnClick="@(() => DeleteParcelAsync(parcel))" />
                                        </div>
                                    }
                                </div>
                            </TitleContent>
                            <ChildContent>
                            @if (_expanded.Contains(parcel.Id))
                            {
                                @* Parsel düzenleme / yapı ekleme formu *@
                                @if (_formMode == FormMode.EditParcel && _formParentId == parcel.Id)
                                {
                                    <MudPaper Class="pa-3 mb-2 mud-border-warning border-l-4" Elevation="0">
                                        <div class="d-flex gap-2 align-center">
                                            <MudTextField @bind-Value="_formName" Label="Parsel Adı" Variant="Variant.Outlined"
                                                          Margin="Margin.Dense" Style="max-width:280px" Immediate="true" />
                                            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                                                       OnClick="@SaveParcelAsync" Disabled="@string.IsNullOrWhiteSpace(_formName)">Kaydet</MudButton>
                                            <MudButton Variant="Variant.Text" OnClick="@CancelForm">İptal</MudButton>
                                        </div>
                                    </MudPaper>
                                }
                                @if (_formMode == FormMode.AddBuilding && _formParentId == parcel.Id)
                                {
                                    <MudPaper Class="pa-3 mb-2 mud-border-success border-l-4" Elevation="0">
                                        <MudText Typo="Typo.body2" Class="mb-2">Yeni Yapı</MudText>
                                        <div class="d-flex flex-wrap gap-2 align-center">
                                            <MudTextField @bind-Value="_formName" Label="Yapı Adı" Variant="Variant.Outlined"
                                                          Margin="Margin.Dense" Style="min-width:200px" Immediate="true" />
                                            <MudTextField @bind-Value="_formMunicipalNo" Label="Belediye No (opsiyonel)"
                                                          Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:160px" />
                                            <MudSelect T="BuildingType" @bind-Value="_formBuildingType" Label="Yapı Tipi"
                                                       Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:160px">
                                                @foreach (BuildingType bt in Enum.GetValues<BuildingType>())
                                                {
                                                    <MudSelectItem Value="bt">@BuildingTypeLabel(bt)</MudSelectItem>
                                                }
                                            </MudSelect>
                                            <MudButton Color="Color.Success" Variant="Variant.Filled"
                                                       OnClick="@SaveBuildingAsync" Disabled="@string.IsNullOrWhiteSpace(_formName)">Kaydet</MudButton>
                                            <MudButton Variant="Variant.Text" OnClick="@CancelForm">İptal</MudButton>
                                        </div>
                                    </MudPaper>
                                }

                                @* ── Yapılar ─── *@
                                <MudExpansionPanels MultiExpansion="true" Class="ml-4">
                                @foreach (var building in parcel.Buildings.OrderBy(b => b.SortOrder))
                                {
                                    <MudExpansionPanel @key="building.Id" Expanded="@_expanded.Contains(building.Id)"
                                                       ExpandedChanged="@(v => SetExpanded(building.Id, v))">
                                        <TitleContent>
                                            <div class="d-flex align-center" style="width:100%">
                                                <MudIcon Icon="@Icons.Material.Filled.Apartment" Size="Size.Small" Color="Color.Tertiary" Class="mr-2" />
                                                <MudText Typo="Typo.body2" Class="fw-medium mr-2">
                                                    @building.Name
                                                    @if (!string.IsNullOrEmpty(building.MunicipalNo))
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Class="ml-1">@building.MunicipalNo</MudChip>
                                                    }
                                                </MudText>
                                                @BuildingSummary(building)
                                                @if (_canManage)
                                                {
                                                    <div class="d-flex gap-1" @onclick:stopPropagation="true">
                                                        <MudIconButton Icon="@Icons.Material.Filled.ViewWeek" Size="Size.Small"
                                                                       Title="Blok Ekle" Color="Color.Info"
                                                                       OnClick="@(() => OpenForm(FormMode.AddBlock, building.Id))" />
                                                        <MudIconButton Icon="@Icons.Material.Filled.MeetingRoom" Size="Size.Small"
                                                                       Title="Bağımsız Bölüm Ekle (bina altı)" Color="Color.Success"
                                                                       OnClick="@(() => OpenAddUnit(building.Id, null))" />
                                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                                       Title="Yapı Düzenle" Color="Color.Default"
                                                                       OnClick="@(() => OpenBuildingEdit(building))" />
                                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                       Title="Yapı Sil" Color="Color.Error"
                                                                       OnClick="@(() => DeleteBuildingAsync(building))" />
                                                    </div>
                                                }
                                            </div>
                                        </TitleContent>
                                        <ChildContent>
                                        @if (_expanded.Contains(building.Id))
                                        {
                                            @* Yapı düzenleme / blok ekleme formu *@
                                            @if (_formMode == FormMode.EditBuilding && _formParentId == building.Id)
                                            {
                                                <MudPaper Class="pa-3 mb-2 mud-border-warning border-l-4" Elevation="0">
                                                    <div class="d-flex flex-wrap gap-2 align-center">
                                                        <MudTextField @bind-Value="_formName" Label="Yapı Adı" Variant="Variant.Outlined"
                                                                      Margin="Margin.Dense" Style="min-width:200px" Immediate="true" />
                                                        <MudTextField @bind-Value="_formMunicipalNo" Label="Belediye No"
                                                                      Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:160px" />
                                                        <MudSelect T="BuildingType" @bind-Value="_formBuildingType" Label="Yapı Tipi"
                                                                   Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:160px">
                                                            @foreach (BuildingType bt in Enum.GetValues<BuildingType>())
                                                            {
                                                                <MudSelectItem Value="bt">@BuildingTypeLabel(bt)</MudSelectItem>
                                                            }
                                                        </MudSelect>
                                                        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                                                                   OnClick="@SaveBuildingAsync" Disabled="@string.IsNullOrWhiteSpace(_formName)">Kaydet</MudButton>
                                                        <MudButton Variant="Variant.Text" OnClick="@CancelForm">İptal</MudButton>
                                                    </div>
                                                </MudPaper>
                                            }
                                            @if (_formMode == FormMode.AddBlock && _formParentId == building.Id)
                                            {
                                                <MudPaper Class="pa-3 mb-2 mud-border-info border-l-4" Elevation="0">
                                                    <MudText Typo="Typo.body2" Class="mb-1">Yeni Blok/Kule</MudText>
                                                    <div class="d-flex gap-2 align-center">
                                                        <MudTextField @bind-Value="_formName" Label="Blok Adı (örn. A Blok, 1. Kule)"
                                                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                                                      Style="max-width:280px" Immediate="true" />
                                                        <MudButton Color="Color.Info" Variant="Variant.Filled"
                                                                   OnClick="@SaveBlockAsync" Disabled="@string.IsNullOrWhiteSpace(_formName)">Kaydet</MudButton>
                                                        <MudButton Variant="Variant.Text" OnClick="@CancelForm">İptal</MudButton>
                                                    </div>
                                                </MudPaper>
                                            }

                                            @* ── Bloklar ─── *@
                                            @foreach (var block in building.Blocks.OrderBy(b => b.SortOrder))
                                            {
                                                <div class="d-flex align-center pa-1 gap-1 mb-1 rounded"
                                                     style="margin-left:12px; background:var(--mud-palette-background-grey);">
                                                    <MudIcon Icon="@Icons.Material.Filled.ViewWeek" Size="Size.Small"
                                                             Color="Color.Info" Class="mr-1" />
                                                    <MudText Typo="Typo.body2" Class="flex-grow-1">@block.Name</MudText>
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Default">
                                                        @block.Units.Count BB
                                                    </MudChip>
                                                    @if (_canManage)
                                                    {
                                                        <MudIconButton Icon="@Icons.Material.Filled.MeetingRoom" Size="Size.Small"
                                                                       Color="Color.Success" Title="Bağımsız Bölüm Ekle"
                                                                       OnClick="@(() => OpenAddUnit(building.Id, block.Id))" />
                                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                                       Color="Color.Default" Title="Blok Düzenle"
                                                                       OnClick="@(() => OpenForm(FormMode.EditBlock, block.Id, block.Name))" />
                                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                       Color="Color.Error" Title="Blok Sil"
                                                                       OnClick="@(() => DeleteBlockAsync(block))" />
                                                    }
                                                </div>
                                                @* Blok düzenleme formu *@
                                                @if (_formMode == FormMode.EditBlock && _formParentId == block.Id)
                                                {
                                                    <MudPaper Class="pa-2 mb-1 mud-border-warning border-l-4"
                                                              Elevation="0" Style="margin-left:12px;">
                                                        <div class="d-flex gap-2 align-center">
                                                            <MudTextField @bind-Value="_formName" Label="Blok Adı" Variant="Variant.Outlined"
                                                                          Margin="Margin.Dense" Style="max-width:240px" Immediate="true" />
                                                            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                                                                       OnClick="@SaveBlockAsync" Disabled="@string.IsNullOrWhiteSpace(_formName)">Kaydet</MudButton>
                                                            <MudButton Variant="Variant.Text" OnClick="@CancelForm">İptal</MudButton>
                                                        </div>
                                                    </MudPaper>
                                                }
                                                @* Blok altı BB ekleme/düzenleme formu *@
                                                @if (IsUnitFormFor(building.Id, block.Id))
                                                {
                                                    @UnitFormPanel
                                                }
                                                @* Blok altındaki BB'ler *@
                                                @if (block.Units.Count > 0)
                                                {
                                                    <div class="mt-1 mb-1" style="margin-left:28px;">
                                                        @UnitTable(block.Units.OrderBy(u => u.SortOrder), building.Id)
                                                    </div>
                                                }
                                            }

                                            @* ── Direkt (bloksuz) BB'ler ─── *@
                                            @if (IsUnitFormFor(building.Id, null))
                                            {
                                                @UnitFormPanel
                                            }
                                            @if (building.Units.Count > 0)
                                            {
                                                <div class="mt-1" style="margin-left:12px;">
                                                    @UnitTable(building.Units.OrderBy(u => u.SortOrder), building.Id)
                                                </div>
                                            }
                                        }
                                        </ChildContent>
                                    </MudExpansionPanel>
                                }
                                </MudExpansionPanels>
                            }
                            </ChildContent>
                        </MudExpansionPanel>
                    }
                    </MudExpansionPanels>
                }
                </ChildContent>
            </MudExpansionPanel>
        }
        </MudExpansionPanels>
    }
}

@code {
    private Guid _companyId;
    private string _companyName = "";
    private bool _unauthorized;
    private bool _initialized;
    private bool _canManage;
    private bool _busy;
    private BuildingSchemaDto? _schema;

    // ─── Form state ────────────────────────────────────────────────────────
    private FormMode _formMode = FormMode.None;
    private Guid _formParentId;  // parent veya entity id (mode'a göre)
    private string _formName = "";
    private string _formMunicipalNo = "";
    private BuildingType _formBuildingType = BuildingType.Residential;

    // Accordion: açık panellerin id'leri (kontrollü genişletme). Form açılınca ilgili
    // panel otomatik genişler ki form (ChildContent'te) görünür olsun.
    private readonly HashSet<Guid> _expanded = new();
    private void SetExpanded(Guid id, bool expanded)
    {
        if (expanded) _expanded.Add(id);
        else _expanded.Remove(id);
    }

    // ── Excel toplu yükleme ───────────────────────────────────────────────
    private bool _showImport;
    private IBrowserFile? _importFile;

    private async Task DownloadTemplateAsync()
    {
        if (_busy) return;
        _busy = true;
        try
        {
            var result = await Mediator.Send(new GenerateBuildingSchemaTemplateQuery());
            if (result.IsSuccess)
            {
                var base64 = Convert.ToBase64String(result.Value!);
                await JS.InvokeVoidAsync("cleantenant.downloadBlobBase64",
                    BuildExcelFileName(), base64,
                    "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            }
            else Snackbar.Add(result.FirstError.Message, Severity.Error);
        }
        finally { _busy = false; }
    }

    // Dosya adı: "{Site Adı} Yapı Şeması [Hatalar] dd.MM.yyyy HH.mm.xlsx".
    // (':' dosya adında geçersiz olduğu için saat ayıracı '.' kullanılır; site adı sanitize edilir.)
    private string BuildExcelFileName(string? suffix = null)
    {
        var name = string.Join("_", _companyName.Split(System.IO.Path.GetInvalidFileNameChars()));
        if (string.IsNullOrWhiteSpace(name)) name = "Site";
        var s = string.IsNullOrEmpty(suffix) ? "" : " " + suffix;
        return $"{name} Yapı Şeması{s} {DateTime.Now:dd.MM.yyyy HH.mm}.xlsx";
    }

    private void OnImportFileSelected(InputFileChangeEventArgs e) => _importFile = e.File;

    private async Task ImportExcelAsync()
    {
        if (_importFile is null || _busy) return;
        _busy = true;
        StateHasChanged();   // spinner'ı hemen göster (parse/kayıt UI thread'ini meşgul edebilir)
        try
        {
            // Blazor Server: BrowserFileStream yalnız ASENKRON okuma destekler; ClosedXML ise
            // senkron okur. Önce async olarak MemoryStream'e kopyala, sonra onu gönder.
            await using var browserStream = _importFile.OpenReadStream(maxAllowedSize: 10_485_760);
            using var ms = new MemoryStream();
            await browserStream.CopyToAsync(ms);
            ms.Position = 0;
            var result = await Mediator.Send(new ImportBuildingSchemaCommand(_companyId, ms));
            if (result.IsFailure) { Snackbar.Add(result.FirstError.Message, Severity.Error); return; }

            var importResult = result.Value;
            if (importResult is null) return;
            if (importResult.HasErrors && importResult.ErrorWorkbook is not null)
            {
                var base64 = Convert.ToBase64String(importResult.ErrorWorkbook);
                await JS.InvokeVoidAsync("cleantenant.downloadBlobBase64",
                    BuildExcelFileName("Hatalar"), base64,
                    "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
                Snackbar.Add("Bazı satırlarda hata var. İndirilen dosyadaki kırmızı 'HATA' kolonunu düzeltip tekrar yükleyin.", Severity.Warning);
            }
            else
            {
                Snackbar.Add($"{importResult.ImportedUnitCount} bağımsız bölüm içe aktarıldı.", Severity.Success);
                _showImport = false;
                _importFile = null;
                await ReloadAsync();
            }
        }
        finally { _busy = false; }
    }

    private enum FormMode
    {
        None,
        AddLand, EditLand,
        AddParcel, EditParcel,
        AddBuilding, EditBuilding,
        AddBlock, EditBlock,
        AddUnit, EditUnit
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true) { _unauthorized = true; _initialized = true; return; }

        var scope = user.FindFirst("scope")?.Value;
        if (!string.Equals(scope, "Company", StringComparison.OrdinalIgnoreCase))
        {
            _unauthorized = true; _initialized = true; return;
        }

        if (user.FindFirst("company_id") is { Value: var cid }
            && Guid.TryParseExact(cid, "N", out var cGuid))
            _companyId = cGuid;
        else { _unauthorized = true; _initialized = true; return; }

        var company = await CompanyReader.GetByIdAsync(_companyId);
        _companyName = company?.Name ?? "Site";

        _canManage = true; // BuildingSchema.Manage permission — endpoint handler guard eder

        await ReloadAsync();
        _initialized = true;
    }

    private async Task ReloadAsync()
    {
        var result = await Mediator.Send(new GetBuildingSchemaQuery(_companyId));
        if (result.IsSuccess)
