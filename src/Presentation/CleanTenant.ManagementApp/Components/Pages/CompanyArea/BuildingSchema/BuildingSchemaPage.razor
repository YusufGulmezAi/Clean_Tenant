    private async Task SaveUnitAsync()
    {
        if (string.IsNullOrWhiteSpace(_unitForm.Number)) return;

        string? error = null;
        if (_editingUnitId.HasValue)
        {
            var r = await Mediator.Send(new UpdateUnitCommand(
                _editingUnitId.Value, _unitForm.Number.Trim(), _unitForm.NationalAddressCode,
                _unitForm.Type, _unitForm.SquareMeters, _unitForm.LandShare, _unitForm.AllocatedArea,
                _unitForm.Floor, _unitForm.Orientation, _unitForm.Layout, _unitFormBlockId));
            if (r.IsFailure) error = r.FirstError.Message;
        }
        else
        {
            var r = await Mediator.Send(new CreateUnitCommand(
                _unitFormBuildingId, _unitForm.Number.Trim(), _unitForm.NationalAddressCode,
                _unitForm.Type, _unitForm.SquareMeters, _unitForm.LandShare, _unitForm.AllocatedArea,
                _unitForm.Floor, _unitForm.Orientation, _unitForm.Layout, _unitFormBlockId));
            if (r.IsFailure) error = r.FirstError.Message;
        }

        if (error is not null) { Snackbar.Add(error, Severity.Error); return; }
        Snackbar.Add("Bağımsız bölüm kaydedildi.", Severity.Success);
        CancelForm();
        await ReloadAsync();
