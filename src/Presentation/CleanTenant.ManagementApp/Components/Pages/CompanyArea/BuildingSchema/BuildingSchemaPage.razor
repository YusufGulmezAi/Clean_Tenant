            <MudButton Color="Color.Success" Variant="Variant.Filled" OnClick="@SaveUnitAsync"
                       Disabled="@(string.IsNullOrWhiteSpace(_unitForm.Number))">Kaydet</MudButton>
            <MudButton Variant="Variant.Text" OnClick="@CancelForm">İptal</MudButton>
        </div>
    </MudPaper>;

    // BB'leri tablo yapısında, düzenle/sil aksiyonlarıyla listeler.
    private RenderFragment UnitTable(IEnumerable<UnitDto> units, Guid buildingId) =>
        @<MudSimpleTable Dense="true" Hover="true" Bordered="true" Striped="true" Elevation="0" Style="background:transparent">
            <thead>
                <tr>
                    <th>No</th>
                    <th>Tip</th>
                    <th style="text-align:right">m²</th>
                    <th style="text-align:right">Tahsis Alanı</th>
                    <th style="text-align:right">Arsa Payı</th>
                    <th style="text-align:right">Kat</th>
                    <th>Düzen</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var unit in units)
                {
                    <tr>
                        <td style="font-weight:500">@unit.Number</td>
                        <td>@UnitTypeLabel(unit.Type)</td>
                        <td style="text-align:right">@unit.SquareMeters.ToString("0.##")</td>
                        <td style="text-align:right">@(unit.AllocatedArea?.ToString("0.##") ?? "—")</td>
                        <td style="text-align:right">@unit.LandShare</td>
                        <td style="text-align:right">@unit.Floor</td>
                        <td>@LayoutLabel(unit.Layout)</td>
