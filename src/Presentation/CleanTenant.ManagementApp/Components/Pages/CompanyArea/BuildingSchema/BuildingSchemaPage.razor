                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>;

    // ─── Etiket yardımcıları (DB-seed: BuildingSchema.* anahtarları) ──────────

    private string UnitTypeLabel(UnitType t) => t switch
    {
        UnitType.Apartment => Loc["BuildingSchema.Unit.Type.Daire"].Value,
        UnitType.Office => Loc["BuildingSchema.Unit.Type.Ofis"].Value,
        UnitType.Shop => Loc["BuildingSchema.Unit.Type.Dukkan"].Value,
        UnitType.Store => Loc["BuildingSchema.Unit.Type.Magaza"].Value,
        UnitType.Storage => Loc["BuildingSchema.Unit.Type.Depo"].Value,
        UnitType.Parking => Loc["BuildingSchema.Unit.Type.Otopark"].Value,
        UnitType.Shelter => Loc["BuildingSchema.Unit.Type.Siginak"].Value,
        _ => Loc["BuildingSchema.Type.Diger"].Value,
    };

    private string OrientationLabel(Orientation o) => o switch
    {
        Orientation.North => Loc["BuildingSchema.Orient.North"].Value,
        Orientation.South => Loc["BuildingSchema.Orient.South"].Value,
        Orientation.East => Loc["BuildingSchema.Orient.East"].Value,
        Orientation.West => Loc["BuildingSchema.Orient.West"].Value,
        Orientation.NorthEast => Loc["BuildingSchema.Orient.NE"].Value,
        Orientation.NorthWest => Loc["BuildingSchema.Orient.NW"].Value,
        Orientation.SouthEast => Loc["BuildingSchema.Orient.SE"].Value,
        Orientation.SouthWest => Loc["BuildingSchema.Orient.SW"].Value,
        _ => Loc["BuildingSchema.Orient.Unknown"].Value,
    };

    private string LayoutLabel(ApartmentLayout l) => l.ToDisplay();

    // ─── Özet istatistikleri (yüklü _schema'dan hesaplanır) ──────────────────
    private int LandCount => _schema?.Lands.Count ?? 0;
    private int ParcelCount => _schema?.Lands.Sum(l => l.Parcels.Count) ?? 0;
    private int BuildingCount => _schema?.Lands.Sum(l => l.Parcels.Sum(p => p.Buildings.Count)) ?? 0;

    private List<UnitDto> AllUnits => _schema is null
        ? []
        : _schema.Lands
            .SelectMany(l => l.Parcels)
            .SelectMany(p => p.Buildings)
            .SelectMany(b => b.Units.Concat(b.Blocks.SelectMany(bk => bk.Units)))
            .ToList();

    private decimal TotalSqm => AllUnits.Sum(u => u.SquareMeters);
    private decimal TotalAllocated => AllUnits.Sum(u => u.AllocatedArea ?? 0);
    private int TotalLandShare => AllUnits.Sum(u => u.LandShare);

    // "12 (8 Daire, 3 Dükkan, 1 Ofis)" biçiminde tip-kırılımlı sayım.
    private string UnitBreakdown(IEnumerable<UnitDto> source)
    {
        var units = source as IReadOnlyCollection<UnitDto> ?? source.ToList();
        if (units.Count == 0) return "0";
        var byType = units.GroupBy(u => u.Type)
            .OrderByDescending(g => g.Count())
            .Select(g => $"{g.Count()} {UnitTypeLabel(g.Key)}");
        return $"{units.Count} ({string.Join(", ", byType)})";
    }

    // Sadece tip kırılımı ("8 Daire, 3 Dükkan") — sayım/parantez yok (kart alt-yazısı için).
    private string UnitTypeBreakdown(IEnumerable<UnitDto> source)
    {
        var units = source as IReadOnlyCollection<UnitDto> ?? source.ToList();
        if (units.Count == 0) return "—";
        return string.Join(", ", units.GroupBy(u => u.Type)
            .OrderByDescending(g => g.Count())
            .Select(g => $"{g.Count()} {UnitTypeLabel(g.Key)}"));
    }

    // Bir alt-ağacın tüm BB'leri (blok-altı + bina-altı).
    private static IEnumerable<UnitDto> UnitsOf(BuildingDto b) => b.Units.Concat(b.Blocks.SelectMany(bk => bk.Units));
    private static IEnumerable<UnitDto> UnitsOf(ParcelDto p) => p.Buildings.SelectMany(b => UnitsOf(b));
    private static IEnumerable<UnitDto> UnitsOf(LandDto l) => l.Parcels.SelectMany(p => UnitsOf(p));

    // Renkli tek metrik rozeti ("Etiket: Değer").
    private RenderFragment MetricChip(string label, string value, Color color) =>
        @<MudChip T="string" Size="Size.Small" Color="@color" Variant="Variant.Filled" Class="ma-0">@label: @value</MudChip>;

    // Seviye adının yanındaki renkli özet grubu (flex-grow → aksiyon butonlarını sağa iter).
    private RenderFragment LandSummary(LandDto l) =>
        @<div class="d-flex flex-wrap align-center gap-1 flex-grow-1">
            <MudText Typo="Typo.caption" Class="mr-1" Style="opacity:.6;font-weight:600">Toplam</MudText>
            @MetricChip("Parsel", l.Parcels.Count.ToString(), Color.Info)
            @MetricChip("Bina", l.Parcels.Sum(p => p.Buildings.Count).ToString(), Color.Tertiary)
            @MetricChip("BB", UnitBreakdown(UnitsOf(l)), Color.Success)
            @MetricChip("m²", UnitsOf(l).Sum(u => u.SquareMeters).ToString("0.##"), Color.Primary)
            @MetricChip("Arsa Payı", UnitsOf(l).Sum(u => u.LandShare).ToString(), Color.Secondary)
        </div>;

    private RenderFragment ParcelSummary(ParcelDto p) =>
        @<div class="d-flex flex-wrap align-center gap-1 flex-grow-1">
            <MudText Typo="Typo.caption" Class="mr-1" Style="opacity:.6;font-weight:600">Toplam</MudText>
            @MetricChip("Bina", p.Buildings.Count.ToString(), Color.Tertiary)
            @MetricChip("BB", UnitBreakdown(UnitsOf(p)), Color.Success)
            @MetricChip("m²", UnitsOf(p).Sum(u => u.SquareMeters).ToString("0.##"), Color.Primary)
            @MetricChip("Arsa Payı", UnitsOf(p).Sum(u => u.LandShare).ToString(), Color.Secondary)
        </div>;

    private RenderFragment BuildingSummary(BuildingDto b) =>
        @<div class="d-flex flex-wrap align-center gap-1 flex-grow-1">
            <MudText Typo="Typo.caption" Class="mr-1" Style="opacity:.6;font-weight:600">Toplam</MudText>
            @MetricChip("BB", UnitBreakdown(UnitsOf(b)), Color.Success)
            @MetricChip("m²", UnitsOf(b).Sum(u => u.SquareMeters).ToString("0.##"), Color.Primary)
            @MetricChip("Arsa Payı", UnitsOf(b).Sum(u => u.LandShare).ToString(), Color.Secondary)
        </div>;

    private sealed class UnitFormModel
    {
        public string Number { get; set; } = "";
        public string? NationalAddressCode { get; set; }
        public UnitType Type { get; set; } = UnitType.Apartment;
        public decimal SquareMeters { get; set; }
        public int LandShare { get; set; }
        public decimal? AllocatedArea { get; set; }
        public int Floor { get; set; }
        public Orientation Orientation { get; set; } = Orientation.Unknown;
        public ApartmentLayout Layout { get; set; } = ApartmentLayout.Unknown;

        public void Reset()
        {
            Number = "";
            NationalAddressCode = null;
            Type = UnitType.Apartment;
            SquareMeters = 0;
            LandShare = 0;
            AllocatedArea = null;
            Floor = 0;
            Orientation = Orientation.Unknown;
            Layout = ApartmentLayout.Unknown;
        }

        public void Load(UnitDto u)
        {
            Number = u.Number;
            NationalAddressCode = u.NationalAddressCode;
            Type = u.Type;
            SquareMeters = u.SquareMeters;
            LandShare = u.LandShare;
            AllocatedArea = u.AllocatedArea;
            Floor = u.Floor;
            Orientation = u.Orientation;
            Layout = u.Layout;
        }
    }
}
