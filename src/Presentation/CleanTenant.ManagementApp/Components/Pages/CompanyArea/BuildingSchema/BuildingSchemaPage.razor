        Snackbar.Add("Bağımsız bölüm silindi.", Severity.Success);
        await ReloadAsync();
    }

    // BB ekleme/düzenleme formu (state-driven; aktif bağlamda render edilir).
    private RenderFragment UnitFormPanel => @<MudPaper Class="pa-3 mb-2 mud-border-success border-l-4" Elevation="0" Style="margin-left:28px;">
        <MudText Typo="Typo.body2" Class="mb-2">
            @(_editingUnitId.HasValue ? "Bağımsız Bölüm Düzenle" : "Yeni Bağımsız Bölüm")@(_unitFormBlockId is null ? " (bina altı)" : "")
        </MudText>
        <div class="d-flex flex-wrap gap-2 align-center">
            <MudTextField @bind-Value="_unitForm.Number" Label="No" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:110px" Immediate="true" />
            <MudNumericField T="decimal" @bind-Value="_unitForm.SquareMeters" Label="m²" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Format="F2" Style="max-width:110px" />
            <MudNumericField T="int" @bind-Value="_unitForm.LandShare" Label="Arsa Payı" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Style="max-width:110px" />
            <MudNumericField T="decimal?" @bind-Value="_unitForm.AllocatedArea" Label="Tahsis Alanı" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Format="F2" Style="max-width:120px" />
            <MudNumericField T="int" @bind-Value="_unitForm.Floor" Label="Kat" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:80px" />
            <MudSelect T="UnitType" @bind-Value="_unitForm.Type" Label="Tip" Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:130px">
                @foreach (UnitType t in Enum.GetValues<UnitType>())
                {
                    <MudSelectItem Value="t">@UnitTypeLabel(t)</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="Orientation" @bind-Value="_unitForm.Orientation" Label="Cephe" Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:130px">
                @foreach (Orientation o in Enum.GetValues<Orientation>())
                {
                    <MudSelectItem Value="o">@OrientationLabel(o)</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="ApartmentLayout" @bind-Value="_unitForm.Layout" Label="Düzen" Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:110px">
