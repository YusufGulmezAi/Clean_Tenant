@using CleanTenant.Domain.Identity.Tenants
@using MudBlazor

@*
    v0.2.4.b.3 — Yönetim CRUD paylaşımlı form bileşeni. Üç modda da aynı
    markup; alanların görünür/read-only/gizli durumları code-behind property'leri
    üzerinden kontrol edilir.

    v0.2.10.e.3 — TenantForm.* anahtarları ile lokalize edildi. Phone placeholder
    "0(5XX) XXX-XX-XX" raw bırakıldı (format mask, locale-bağımsız).
*@

<MudForm @ref="_form" Model="@Model" Validation="@ValidateValue" ValidationDelay="0">
    <MudCard Elevation="0" Outlined="true">
        <MudCardContent>
            <MudGrid>
                <MudItem xs="12">
                    <MudText Typo="Typo.h6">@Loc["TenantForm.Section.Tenant"]</MudText>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Name"
                                  For="@(() => Model.Name)"
                                  Label="@Loc["TenantForm.Name"]"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  MaxLength="256"
                                  Immediate="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.LegalName"
                                  For="@(() => Model.LegalName)"
                                  Label="@Loc["TenantForm.LegalName"]"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  MaxLength="512"
                                  Immediate="true" />
                </MudItem>

                <MudItem xs="12" sm="4">
                    <MudSelect T="LegalIdentityType"
                               @bind-Value="Model.LegalIdentityType"
                               Label="@Loc["TenantForm.LegalIdentityType"]"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               ReadOnly="@IdentityReadOnly">
                        <MudSelectItem Value="@LegalIdentityType.Vkn">@Loc["TenantForm.IdentityType.Vkn"]</MudSelectItem>
                        <MudSelectItem Value="@LegalIdentityType.Tckn">@Loc["TenantForm.IdentityType.Tckn"]</MudSelectItem>
                        <MudSelectItem Value="@LegalIdentityType.Ykn">@Loc["TenantForm.IdentityType.Ykn"]</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="8">
                    <MudTextField @bind-Value="Model.LegalIdentityNumber"
                                  For="@(() => Model.LegalIdentityNumber)"
                                  Label="@IdentityNumberLabel"
                                  HelperText="@IdentityNumberHelperText"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  MaxLength="11"
                                  ReadOnly="@IdentityReadOnly"
                                  Immediate="true" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="Model.Address"
                                  For="@(() => Model.Address)"
                                  Label="@Loc["TenantForm.Address"]"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Lines="2"
                                  MaxLength="512"
                                  Immediate="true" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudSelect T="BillingTier"
                               @bind-Value="Model.BillingTier"
                               Label="@Loc["TenantForm.BillingTier"]"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               ReadOnly="@BillingReadOnly">
                        <MudSelectItem Value="@BillingTier.Free">@Loc["TenantForm.Tier.Free"]</MudSelectItem>
                        <MudSelectItem Value="@BillingTier.Standard">@Loc["TenantForm.Tier.Standard"]</MudSelectItem>
                        <MudSelectItem Value="@BillingTier.Enterprise">@Loc["TenantForm.Tier.Enterprise"]</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" Class="d-flex align-center">
                    <MudSwitch T="bool"
                               @bind-Value="Model.HasDedicatedDatabase"
                               Color="Color.Primary"
                               Label="@Loc["TenantForm.DedicatedDb"]"
                               ReadOnly="@DedicatedDbReadOnly" />
                </MudItem>

                @if (ShowSystemWriteAccess)
                {
                    <MudItem xs="12">
                        <MudSwitch T="bool"
                                   @bind-Value="Model.AllowSystemWriteAccess"
                                   Color="Color.Primary"
                                   Label="@Loc["TenantForm.AllowSystemWrite"]" />
                        <MudText Typo="Typo.caption" Color="Color.Default" Class="ml-12">
                            @Loc["TenantForm.AllowSystemWrite.Help"]
                        </MudText>
                    </MudItem>
                }

                @if (ShowAdminBlock)
                {
                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.h6">@Loc["TenantForm.Section.Admin"]</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Default">
                            @Loc["TenantForm.Admin.Caption"]
                        </MudText>
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="Model.AdminFirstName"
                                      For="@(() => Model.AdminFirstName)"
                                      Label="@Loc["TenantForm.Admin.FirstName"]"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      MaxLength="100"
                                      Immediate="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="Model.AdminLastName"
                                      For="@(() => Model.AdminLastName)"
                                      Label="@Loc["TenantForm.Admin.LastName"]"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      MaxLength="100"
                                      Immediate="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="Model.AdminEmail"
                                      For="@(() => Model.AdminEmail)"
                                      Label="@Loc["TenantForm.Admin.Email"]"
                                      InputType="InputType.Email"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      MaxLength="256"
                                      Immediate="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="Model.AdminPhone"
                                      @bind-Value:after="FormatAdminPhone"
                                      For="@(() => Model.AdminPhone)"
                                      Label="@Loc["TenantForm.Admin.Phone"]"
                                      Placeholder="0(5XX) XXX-XX-XX"
                                      MaxLength="17"
                                      InputMode="InputMode.tel"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      HelperText="@Loc["TenantForm.Admin.PhoneFormat"]"
                                      Immediate="true" />
                    </MudItem>
                }
            </MudGrid>
        </MudCardContent>

        <MudCardActions Class="d-flex justify-end pa-4">
            @if (!string.IsNullOrEmpty(CancelHref))
            {
                <MudButton Href="@CancelHref"
                           Variant="Variant.Text"
                           Class="mr-2"
                           Disabled="@IsSubmitting">
                    @Loc["Common.Cancel"]
                </MudButton>
            }
            <MudButton OnClick="@SubmitAsync"
                       Color="Color.Primary"
                       Variant="Variant.Filled"
                       Disabled="@IsSubmitting"
                       StartIcon="@(IsSubmitting ? null : Icons.Material.Filled.Save)">
                @if (IsSubmitting)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">@Loc["Common.Saving"]</MudText>
                }
                else
                {
                    @ResolvedSubmitButtonText
                }
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudForm>
