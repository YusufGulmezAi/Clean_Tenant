@using CleanTenant.Domain.Identity.Tenants
@using MudBlazor

@*
    v0.2.4.b.3 — Yönetim CRUD paylaşımlı form bileşeni. Üç modda da aynı
    markup; alanların görünür/read-only/gizli durumları code-behind property'leri
    üzerinden kontrol edilir.
*@

<MudForm @ref="_form" Model="@Model" Validation="@ValidateValue" ValidationDelay="0">
    <MudCard Elevation="0" Outlined="true">
        <MudCardContent>
            <MudGrid>
                <MudItem xs="12">
                    <MudText Typo="Typo.h6">Yönetim Bilgileri</MudText>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Name"
                                  For="@(() => Model.Name)"
                                  Label="Yönetim Adı *"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  MaxLength="256"
                                  Immediate="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.LegalName"
                                  For="@(() => Model.LegalName)"
                                  Label="Yasal Ad"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  MaxLength="512"
                                  Immediate="true" />
                </MudItem>

                <MudItem xs="12" sm="4">
                    <MudSelect T="LegalIdentityType"
                               @bind-Value="Model.LegalIdentityType"
                               Label="Kimlik Tipi *"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               ReadOnly="@IdentityReadOnly">
                        <MudSelectItem Value="@LegalIdentityType.Vkn">VKN (Vergi Kimlik No)</MudSelectItem>
                        <MudSelectItem Value="@LegalIdentityType.Tckn">TCKN</MudSelectItem>
                        <MudSelectItem Value="@LegalIdentityType.Ykn">YKN (Yabancı Kimlik No)</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="8">
                    <MudTextField @bind-Value="Model.LegalIdentityNumber"
                                  For="@(() => Model.LegalIdentityNumber)"
                                  Label="@IdentityNumberLabel"
                                  HelperText="@IdentityNumberHelperText"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  MaxLength="11"
                                  ReadOnly="@IdentityReadOnly"
                                  Immediate="true" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="Model.Address"
                                  For="@(() => Model.Address)"
                                  Label="Adres"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Lines="2"
                                  MaxLength="512"
                                  Immediate="true" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudSelect T="BillingTier"
                               @bind-Value="Model.BillingTier"
                               Label="Faturalama Katmanı *"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               ReadOnly="@BillingReadOnly">
                        <MudSelectItem Value="@BillingTier.Free">Free</MudSelectItem>
                        <MudSelectItem Value="@BillingTier.Standard">Standard</MudSelectItem>
                        <MudSelectItem Value="@BillingTier.Enterprise">Enterprise</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" Class="d-flex align-center">
                    <MudSwitch T="bool"
                               @bind-Value="Model.HasDedicatedDatabase"
                               Color="Color.Primary"
                               Label="Dedicated DB"
                               ReadOnly="@DedicatedDbReadOnly" />
                </MudItem>

                @if (ShowSystemWriteAccess)
                {
                    <MudItem xs="12">
                        <MudSwitch T="bool"
                                   @bind-Value="Model.AllowSystemWriteAccess"
                                   Color="Color.Primary"
                                   Label="Sistem operatörünün yazma izni" />
                        <MudText Typo="Typo.caption" Color="Color.Default" Class="ml-12">
                            Açık: Sistem destek kullanıcıları bu Yönetim'de yazma yapabilir. Kapalı: yalnız okuma.
                        </MudText>
                    </MudItem>
                }

                @if (ShowAdminBlock)
                {
                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.h6">Sorumlu Yönetici (TenantAdmin)</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Default">
                            İlk admin kullanıcı otomatik oluşturulur. Welcome e-posta + şifre belirleme bağlantısı gönderilir.
                        </MudText>
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="Model.AdminFirstName"
                                      For="@(() => Model.AdminFirstName)"
                                      Label="Ad *"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      MaxLength="100"
                                      Immediate="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="Model.AdminLastName"
                                      For="@(() => Model.AdminLastName)"
                                      Label="Soyad *"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      MaxLength="100"
                                      Immediate="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="Model.AdminEmail"
                                      For="@(() => Model.AdminEmail)"
                                      Label="E-posta *"
                                      InputType="InputType.Email"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      MaxLength="256"
                                      Immediate="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="Model.AdminPhone"
                                      For="@(() => Model.AdminPhone)"
                                      Label="Cep Telefonu *"
                                      Mask="@(new PatternMask("0(5##) ###-##-##"))"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      HelperText="Format: 0(5XX) XXX-XX-XX" />
                    </MudItem>
                }
            </MudGrid>
        </MudCardContent>

        <MudCardActions Class="d-flex justify-end pa-4">
            @if (!string.IsNullOrEmpty(CancelHref))
            {
                <MudButton Href="@CancelHref"
                           Variant="Variant.Text"
                           Class="mr-2"
                           Disabled="@IsSubmitting">
                    İptal
                </MudButton>
            }
            <MudButton OnClick="@SubmitAsync"
                       Color="Color.Primary"
                       Variant="Variant.Filled"
                       Disabled="@IsSubmitting"
                       StartIcon="@(IsSubmitting ? null : Icons.Material.Filled.Save)">
                @if (IsSubmitting)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Kaydediliyor…</MudText>
                }
                else
                {
                    @SubmitButtonText
                }
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudForm>
