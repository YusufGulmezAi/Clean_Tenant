@using MudBlazor
@using CleanTenant.Domain.Tenant.Companies

@*
    Site CRUD paylaşımlı form bileşeni. Create/Edit modlarında aynı markup;
    alanların görünür/gizli durumları code-behind property'leri üzerinden kontrol edilir.

    v0.2.10.e.3 — CompanyForm.* anahtarları ile lokalize edildi.
*@

<MudForm @ref="_form" Model="@Model" Validation="@ValidateValue" ValidationDelay="0">
    <MudCard Elevation="0" Outlined="true">
        <MudCardContent Class="pa-3">
            <MudGrid Spacing="2">

                @* ── Site Bilgileri ───────────────────────────────────────── *@
                <MudItem xs="12">
                    <MudText Typo="Typo.h6">@Loc["CompanyForm.Section.Info"]</MudText>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Name"
                                  For="@(() => Model.Name)"
                                  Label="@Loc["CompanyForm.Name"]"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  MaxLength="256"
                                  Immediate="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.LegalName"
                                  For="@(() => Model.LegalName)"
                                  Label="@Loc["CompanyForm.LegalName"]"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  MaxLength="512"
                                  Immediate="true" />
                </MudItem>

                @* ── Kimlik ───────────────────────────────────────────────── *@
                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.h6">@Loc["CompanyForm.Section.Identity"]</MudText>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Vkn"
                                  For="@(() => Model.Vkn)"
                                  Label="@Loc["CompanyForm.Vkn"]"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  MaxLength="10"
                                  HelperText="@Loc["CompanyForm.Vkn.Help"]"
                                  Immediate="true" />
                </MudItem>

                @* ── İletişim ─────────────────────────────────────────────── *@
                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.h6">@Loc["CompanyForm.Section.Contact"]</MudText>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Email"
                                  For="@(() => Model.Email)"
                                  Label="@Loc["CompanyForm.Email"]"
                                  InputType="InputType.Email"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  MaxLength="256"
                                  Immediate="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Phone"
                                  For="@(() => Model.Phone)"
                                  Label="@Loc["CompanyForm.Phone"]"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  MaxLength="20"
                                  Immediate="true" />
                </MudItem>

                @* ── Site Yöneticisi (CompanyAdmin) — yalnız Create modu (v0.2.13.e) ── *@
                @if (Mode == CompanyFormMode.Create)
                {
                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.h6">@Loc["CompanyForm.Section.Admin"]</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Default">@Loc["CompanyForm.Admin.Hint"]</MudText>
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="Model.AdminFirstName"
                                      For="@(() => Model.AdminFirstName)"
                                      Label="@Loc["CompanyForm.AdminFirstName"]"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      MaxLength="128"
                                      Immediate="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="Model.AdminLastName"
                                      For="@(() => Model.AdminLastName)"
                                      Label="@Loc["CompanyForm.AdminLastName"]"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      MaxLength="128"
                                      Immediate="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="Model.AdminEmail"
                                      For="@(() => Model.AdminEmail)"
                                      Label="@Loc["CompanyForm.AdminEmail"]"
                                      InputType="InputType.Email"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      MaxLength="256"
                                      Immediate="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="Model.AdminPhone"
                                      For="@(() => Model.AdminPhone)"
                                      Label="@Loc["CompanyForm.AdminPhone"]"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      MaxLength="20"
                                      Immediate="true" />
                    </MudItem>
                }

                @* ── Durum ────────────────────────────────────────────────── *@
                @if (Mode == CompanyFormMode.Edit)
                {
                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.h6">@Loc["CompanyForm.Section.Status"]</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudSelect T="CompanyStatus"
                                   @bind-Value="Model.Status"
                                   Label="@Loc["CompanyForm.Status"]"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense">
                            <MudSelectItem Value="CompanyStatus.Active">@Loc["CompanyStatus.Active"]</MudSelectItem>
                            <MudSelectItem Value="CompanyStatus.Suspended">@Loc["CompanyStatus.Suspended"]</MudSelectItem>
                            <MudSelectItem Value="CompanyStatus.Closed">@Loc["CompanyStatus.Closed"]</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                }

            </MudGrid>
        </MudCardContent>

        @if (!HideActions)
        {
            <MudCardActions Class="d-flex justify-end pa-3">
                @if (!string.IsNullOrEmpty(CancelHref))
                {
                    <MudButton Href="@CancelHref"
                               Variant="Variant.Text"
                               Class="mr-2"
                               Disabled="@IsSubmitting">
                        @Loc["Common.Cancel"]
                    </MudButton>
                }
                <MudButton OnClick="@SubmitAsync"
                           Color="Color.Primary"
                           Variant="Variant.Filled"
                           Disabled="@IsSubmitting"
                           StartIcon="@(IsSubmitting ? null : Icons.Material.Filled.Save)">
                    @if (IsSubmitting)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                        <MudText Class="ms-2">@Loc["Common.Saving"]</MudText>
                    }
                    else
                    {
                        @ResolvedSubmitButtonText
                    }
                </MudButton>
            </MudCardActions>
        }
    </MudCard>
</MudForm>
