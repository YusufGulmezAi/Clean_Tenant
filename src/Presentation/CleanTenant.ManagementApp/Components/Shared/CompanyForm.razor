@using MudBlazor

@*
    Site CRUD paylaşımlı form bileşeni. Create/Edit modlarında aynı markup;
    alanların görünür/gizli durumları code-behind property'leri üzerinden kontrol edilir.
*@

<MudForm @ref="_form" Model="@Model" Validation="@ValidateValue" ValidationDelay="0">
    <MudCard Elevation="0" Outlined="true">
        <MudCardContent>
            <MudGrid>
                <MudItem xs="12">
                    <MudText Typo="Typo.h6">Site Bilgileri</MudText>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Name"
                                  For="@(() => Model.Name)"
                                  Label="Site Adı *"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  MaxLength="256"
                                  Immediate="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.LegalName"
                                  For="@(() => Model.LegalName)"
                                  Label="Yasal Ad"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  MaxLength="512"
                                  Immediate="true" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Vkn"
                                  For="@(() => Model.Vkn)"
                                  Label="VKN"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  MaxLength="10"
                                  HelperText="10 haneli, ilk hane 1-9 arasında"
                                  Immediate="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Email"
                                  For="@(() => Model.Email)"
                                  Label="E-posta"
                                  InputType="InputType.Email"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  MaxLength="256"
                                  Immediate="true" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Phone"
                                  For="@(() => Model.Phone)"
                                  Label="Telefon"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  MaxLength="20"
                                  Immediate="true" />
                </MudItem>
            </MudGrid>
        </MudCardContent>

        <MudCardActions Class="d-flex justify-end pa-4">
            @if (!string.IsNullOrEmpty(CancelHref))
            {
                <MudButton Href="@CancelHref"
                           Variant="Variant.Text"
                           Class="mr-2"
                           Disabled="@IsSubmitting">
                    İptal
                </MudButton>
            }
            <MudButton OnClick="@SubmitAsync"
                       Color="Color.Primary"
                       Variant="Variant.Filled"
                       Disabled="@IsSubmitting"
                       StartIcon="@(IsSubmitting ? null : Icons.Material.Filled.Save)">
                @if (IsSubmitting)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Kaydediliyor…</MudText>
                }
                else
                {
                    @SubmitButtonText
                }
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudForm>
