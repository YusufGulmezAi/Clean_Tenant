@* Bütçe şablonu önizleme dialog'u — şablon kalemlerini (yapı-only) gösterir;
   "Bundan Oluştur" ile galeriye instantiate sinyali döner. *@
@inject MediatR.IMediator Mediator
@inject IStringLocalizer Loc
@using CleanTenant.Application.Features.Main.Budgeting.Templates

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Preview" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@(_detail?.Name ?? Loc["Budget.Preview.Title"].Value)</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <div style="min-width: 620px;">
            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" Class="my-3" />
            }
            else if (_detail is null)
            {
                <MudAlert Severity="Severity.Error">@Loc["Budget.Preview.NotFound"]</MudAlert>
            }
            else
            {
                <div class="d-flex align-center gap-2 mb-2">
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">@_detail.Type</MudChip>
                    <MudChip T="string" Size="Size.Small">@Loc["Budget.Preview.LineCount", _detail.Lines.Count]</MudChip>
                </div>
                @if (!string.IsNullOrWhiteSpace(_detail.Description))
                {
                    <MudText Typo="Typo.body2" Class="mb-3 mud-text-secondary">@_detail.Description</MudText>
                }

                <MudSimpleTable Dense="true" Hover="true" Bordered="true" Style="overflow-x:auto;">
                    <thead>
                        <tr>
                            <th>@Loc["Budget.Preview.Category"]</th>
                            <th>@Loc["Budget.Preview.Line"]</th>
                            <th>@Loc["Budget.Field.PaymentSchedule"]</th>
                            <th>@Loc["Budget.Field.Distribution"]</th>
                            <th style="text-align:center">@Loc["Budget.Field.DueDay"]</th>
                            <th>@Loc["Budget.Field.ParticipationGroup"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in _detail.Lines)
                        {
                            <tr>
                                <td>@line.CategoryName <span class="mud-text-secondary">(@line.CategoryCode)</span></td>
                                <td>@line.LineName <span class="mud-text-secondary">(@line.LineCode)</span></td>
                                <td>@line.PaymentSchedule</td>
                                <td>@line.DistributionModel</td>
                                <td style="text-align:center">@line.DueDayOfMonth</td>
                                <td>@(string.IsNullOrWhiteSpace(line.ParticipationGroupName) ? Loc["Budget.Field.AllUnits"].Value : line.ParticipationGroupName)</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
                <MudText Typo="Typo.caption" Class="mt-2 mud-text-secondary">@Loc["Budget.Preview.AmountsNote"]</MudText>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">@Loc["Common.Close"]</MudButton>
        @if (CanCreate && _detail is not null)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="Create">@Loc["Budget.Gallery.Use"]</MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public Guid TemplateId { get; set; }
    /// <summary>Kullanıcı "Bundan Oluştur" görebilsin mi (tenant.budget.edit).</summary>
    [Parameter] public bool CanCreate { get; set; }

    private bool _loading = true;
    private BudgetTemplateDetail? _detail;

    protected override async Task OnInitializedAsync()
    {
        var result = await Mediator.Send(new GetBudgetTemplateDetailQuery(TemplateId));
        _detail = result.IsSuccess ? result.Value : null;
        _loading = false;
    }

    private void Create() => MudDialog.Close(DialogResult.Ok(true));
    private void Cancel() => MudDialog.Cancel();
}
