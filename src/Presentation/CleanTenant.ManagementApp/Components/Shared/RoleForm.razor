@using MudBlazor

@*
    v0.2.10.e.3 — Roles.Form.* + Scope.* + Common.* anahtarlarıyla lokalize edildi.
*@

<MudForm @ref="_form" Model="@Model" Validation="@ValidateValue" ValidationDelay="0">
    <MudCard Elevation="0" Outlined="true">
        <MudCardContent>
            <MudGrid>
                <MudItem xs="12">
                    <MudText Typo="Typo.h6">@Loc["Roles.Form.Section.Info"]</MudText>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Name"
                                  For="@(() => Model.Name)"
                                  Label="@Loc["Roles.Form.Name"]"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  MaxLength="256"
                                  Immediate="true" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudSelect T="int"
                               @bind-Value="Model.Scope"
                               Label="@Loc["Roles.Form.Scope"]"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               ReadOnly="@ScopeReadOnly">
                        @if (!HideSystemScope)
                        {
                            <MudSelectItem Value="1">@Loc["Scope.System"]</MudSelectItem>
                        }
                        <MudSelectItem Value="2">@Loc["Scope.Tenant"]</MudSelectItem>
                        <MudSelectItem Value="3">@Loc["Scope.Company"]</MudSelectItem>
                        <MudSelectItem Value="4">@Loc["Scope.Unit"]</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="Model.Description"
                                  For="@(() => Model.Description)"
                                  Label="@Loc["Roles.Form.Description"]"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Lines="2"
                                  MaxLength="1024"
                                  Immediate="true" />
                </MudItem>
            </MudGrid>
        </MudCardContent>

        <MudCardActions Class="d-flex justify-end pa-4">
            @if (!string.IsNullOrEmpty(CancelHref))
            {
                <MudButton Href="@CancelHref"
                           Variant="Variant.Text"
                           Class="mr-2"
                           Disabled="@IsSubmitting">
                    @Loc["Common.Cancel"]
                </MudButton>
            }
            <MudButton OnClick="@SubmitAsync"
                       Color="Color.Primary"
                       Variant="Variant.Filled"
                       Disabled="@IsSubmitting"
                       StartIcon="@(IsSubmitting ? null : Icons.Material.Filled.Save)">
                @if (IsSubmitting)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">@Loc["Common.Saving"]</MudText>
                }
                else
                {
                    @ResolvedSubmitButtonText
                }
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudForm>
