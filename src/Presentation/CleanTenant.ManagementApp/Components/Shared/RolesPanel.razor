@inject IAuthorizationCatalogReader RoleReader
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject IStringLocalizer Loc
@using CleanTenant.Application.Features.Catalog.Readers
@using CleanTenant.Application.Features.Catalog.Roles
@using CleanTenant.SharedKernel.Context

@*
    Rol & izin yönetim paneli — Erişim Yönetimi sayfasının "Roller & İzinler"
    sekmesi (v0.2.13.b).

    Rol listesi (DataTable) + "Yeni Rol" / "Düzenle" için geniş RoleDialog modalı.
    Tenant scope'ta üstte scope filtre dropdown'ı (Yönetim/Site/Birim) gösterilir;
    System scope'ta scope sabit Sistem (1).

    Bu panel yalnız System ve Tenant scope'larda gösterilir; Company scope'ta rol
    tanımlama yoktur (AccessManagementPage sekmeyi gizler).
*@

@if (!_initialized)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <div class="d-flex justify-space-between align-center mb-3">
        <div style="min-width: 200px;">
            @if (EffectiveScope == ScopeLevel.Tenant)
            {
                @* Tenant scope: rol kapsam filtresi (Sistem seçeneği yok). *@
                <MudSelect T="int"
                           @bind-Value="_scopeLevel"
                           @bind-Value:after="LoadRolesAsync"
                           Label="@Loc["Roles.List.ScopeFilter"]"
                           Variant="Variant.Outlined"
                           Size="Size.Small">
                    <MudSelectItem Value="2">@Loc["Scope.Tenant"]</MudSelectItem>
                    <MudSelectItem Value="3">@Loc["Scope.Company"]</MudSelectItem>
                    <MudSelectItem Value="4">@Loc["Scope.Unit"]</MudSelectItem>
                </MudSelect>
            }
        </div>
        <MudButton StartIcon="@Icons.Material.Filled.Add"
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="OpenCreateDialog">
            @Loc["Roles.List.NewButton"]
        </MudButton>
    </div>

    <DataTable TItem="RoleListItem"
               Items="@_items"
               SearchPlaceholder="@Loc["Roles.List.Search"]"
               SearchableFields="@(row => new[] { row.Name, row.Description ?? "" })"
               ExportTitle="@Loc["NavMenu.RolesAndPermissions"].Value"
               Filterable="true">
        <Columns>
            <PropertyColumn T="RoleListItem" TProperty="string" Property="@(r => r.Name)" Title="@Loc["Roles.List.Col.Name"].Value" />
            <PropertyColumn T="RoleListItem" TProperty="string" Property="@(r => r.Description)" Title="@Loc["Roles.List.Col.Description"].Value" />
            <TemplateColumn T="RoleListItem" Title="@Loc["Roles.List.Col.Source"].Value" Filterable="false" Sortable="false">
                <CellTemplate>
                    @if (context.Item.IsBuiltIn)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                            <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Class="mr-1" />
                            @Loc["Roles.List.Tag.BuiltIn"]
                        </MudChip>
                    }
                    else if (context.Item.TenantId is null)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">
                            @Loc["Roles.List.Tag.Global"]
                        </MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">
                            @Loc["Roles.List.Tag.OwnTenant"]
                        </MudChip>
                    }
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn T="RoleListItem" TProperty="int" Property="@(r => r.PermissionCount)" Title="@Loc["Roles.List.Col.PermCount"].Value" />
            <TemplateColumn T="RoleListItem" CellClass="d-flex justify-end" Filterable="false" Sortable="false">
                <CellTemplate>
                    @{
                        // System assigner her rolü düzenleyebilir; Tenant assigner yalnız
                        // kendi tenant'ının (built-in/global olmayan) rolünü silebilir.
                        // Salt-görüntülenebilir roller için Edit yine açılır (dialog ReadOnly).
                        var editable = EffectiveScope == ScopeLevel.System
                                       || (!context.Item.IsBuiltIn && context.Item.TenantId == TenantId);
                    }
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   Color="@(editable ? Color.Default : Color.Inherit)"
                                   title="@(editable ? Loc["Common.Edit"].Value : Loc["Roles.TenantList.Action.ViewReadOnly"].Value)"
                                   OnClick="@(() => OpenEditDialog(context.Item.UrlCode))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   title="@Loc["Common.Delete"]"
                                   OnClick="@(() => DeleteAsync(context.Item))"
                                   Disabled="@(!editable)" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </DataTable>
}

@code {
    /// <summary>Açan kullanıcının etkin scope'u (System / Tenant).</summary>
    [Parameter] public ScopeLevel EffectiveScope { get; set; }

    [Parameter] public Guid? TenantId { get; set; }
    [Parameter] public Guid? CompanyId { get; set; }

    private bool _initialized;
    private int _scopeLevel = 2;   // Tenant scope varsayılan filtre: Yönetim
    private IReadOnlyList<RoleListItem>? _items;

    protected override async Task OnInitializedAsync()
    {
        // System scope sabit Sistem (1); Tenant scope dropdown ile Yönetim (2) başlar.
        _scopeLevel = EffectiveScope == ScopeLevel.System ? 1 : 2;

        await LoadRolesAsync();
        _initialized = true;
    }

    private async Task LoadRolesAsync()
    {
        try
        {
            if (EffectiveScope == ScopeLevel.System)
            {
                _items = await RoleReader.GetRolesByScopeAsync(_scopeLevel);
            }
            else if (TenantId.HasValue)
            {
                _items = await RoleReader.GetRolesByScopeForTenantAsync(_scopeLevel, TenantId.Value);
            }
            else
            {
                _items = [];
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(Loc["Roles.List.LoadError", ex.Message].Value, Severity.Error);
        }
    }

    private Task OpenCreateDialog() => ShowDialogAsync(null);

    private Task OpenEditDialog(string urlCode) => ShowDialogAsync(urlCode);

    private async Task ShowDialogAsync(string? roleUrlCode)
    {
        var parameters = new DialogParameters<RoleDialog>
        {
            { x => x.RoleUrlCode, roleUrlCode },
            { x => x.EffectiveScope, EffectiveScope },
            { x => x.TenantId, TenantId },
            { x => x.CompanyId, CompanyId },
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraLarge,
            FullWidth = true,
            CloseOnEscapeKey = true,
        };

        var dialog = await DialogService.ShowAsync<RoleDialog>(
            roleUrlCode is null ? Loc["Roles.New.Title"].Value : Loc["Roles.Edit.Title"].Value,
            parameters,
            options);

        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await LoadRolesAsync();
        }
    }

    private async Task DeleteAsync(RoleListItem role)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", Loc["Roles.List.DeleteConfirm", role.Name].Value);
        if (!confirmed) return;

        try
        {
            await Mediator.Send(new DeleteRoleCommand(role.Id));
            Snackbar.Add(Loc["Roles.List.DeleteSuccess"].Value, Severity.Success);
            await LoadRolesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(Loc["Lookup.ErrorPrefix", ex.Message].Value, Severity.Error);
        }
    }
}
