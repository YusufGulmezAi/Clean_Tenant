@*
    v0.2.2 — AuthorizeRouteView, sayfa erişiminde kimlik doğrulanmamış kullanıcıyı
    /login'e yönlendirir. Login + 2FA Challenge sayfaları [AllowAnonymous]
    (Login.razor'da @attribute eklenirse override edilebilir) — şu an default
    layout EmptyLayout olduğu için zaten erişilebilir.
*@
<Router AppAssembly="typeof(Program).Assembly" NotFoundPage="typeof(Pages.NotFound)">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)">
            <NotAuthorized>
                @{
                    var redirectTo = "/login";
                    NavigationManager.NavigateTo(redirectTo, forceLoad: true);
                }
            </NotAuthorized>
            <Authorizing>
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
            </Authorizing>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>

@code {
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
}
