@inherits LayoutComponentBase
@implements IDisposable
@inject IThemeService ThemeService
@inject AuthenticationStateProvider AuthProvider
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IStringLocalizer Loc
@using CleanTenant.ManagementApp.Services
@using System.Globalization

@*
    AdminLTE+ pateni MudBlazor ile (v0.2.2.c — Routes seviyesinde InteractiveServer
    olduğu için layout state'i tam reaktif):
    - MudAppBar üstte (hamburger + logo + dark toggle + tema + 2FA + kullanıcı menüsü)
    - MudDrawer solda — Mini + hover; toggle butonu hep açık <-> mini arası geçirir
    - NavMenu içinde arama kutusu (üstte) — linkleri canlı filtreler
    - MudMainContent ortada
*@

<MudRTLProvider RightToLeft="@_isRtl">
    <MudThemeProvider Theme="@_currentTheme" IsDarkMode="@_isDark" />
    <MudPopoverProvider />
    <MudDialogProvider />
    <MudSnackbarProvider />
</MudRTLProvider>

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@DrawerToggle"
                       title="@Loc["Layout.AppBar.MenuToggle"]" />

        <MudIcon Icon="@Icons.Material.Filled.Domain" Class="mr-2" />
        <MudText Typo="Typo.h6">@Loc["Layout.AppBar.Brand"]</MudText>

        <TenantSwitcher ActiveTenantId="@_activeTenantId"
                        ActiveTenantName="@_activeTenantName"
                        ActiveCompanyId="@_activeCompanyId"
                        ActiveCompanyName="@_activeCompanyName" />

        <MudSpacer />

        <MudIconButton Icon="@(_isDark ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="@OnDarkToggle"
                       title="@(_isDark ? Loc["Layout.AppBar.LightMode"].Value : Loc["Layout.AppBar.DarkMode"].Value)" />

        <MudIconButton Icon="@Icons.Material.Filled.Palette"
                       Color="Color.Inherit"
                       Href="/settings/theme"
                       title="@Loc["Layout.AppBar.ThemeSettings"]" />

        <MudIconButton Icon="@Icons.Material.Filled.Notifications"
                       Color="Color.Inherit"
                       title="@Loc["Layout.AppBar.Notifications"]" />

        @* ── Dil seçici ────────────────────────────────────────────── *@
        <MudMenu Dense="true"
                 AnchorOrigin="Origin.BottomRight"
                 TransformOrigin="Origin.TopRight">
            <ActivatorContent>
                <MudButton Color="Color.Inherit" Variant="Variant.Text"
                           Class="px-2 min-width-0"
                           Style="font-size: 1.35rem; min-width: auto; line-height: 1;"
                           title="@Loc["Layout.AppBar.Language"]">
                    @_currentLang.Flag
                </MudButton>
            </ActivatorContent>
            <ChildContent>
                @foreach (var lang in LanguageService.Supported)
                {
                    <MudMenuItem OnClick="@(() => ChangeLanguageAsync(lang.Code))">
                        <div class="d-flex align-center gap-2">
                            <span style="font-size: 1.2rem;">@lang.Flag</span>
                            <MudText>@lang.Name</MudText>
                            @if (string.Equals(lang.Code, _currentLang.Code, StringComparison.OrdinalIgnoreCase))
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Check"
                                         Size="Size.Small" Color="Color.Primary" Class="ml-1" />
                            }
                        </div>
                    </MudMenuItem>
                }
            </ChildContent>
        </MudMenu>

        <MudMenu Icon="@Icons.Material.Filled.AccountCircle"
                 Color="Color.Inherit"
                 AnchorOrigin="Origin.BottomRight"
                 TransformOrigin="Origin.TopRight">
            <MudMenuItem Icon="@Icons.Material.Filled.Person" Href="/profile">@Loc["Layout.AppBar.Profile"]</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.Security" Href="/settings/2fa/enroll">@Loc["Layout.AppBar.TwoFactor"]</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.Settings" Href="/settings/theme">@Loc["Layout.AppBar.Settings"]</MudMenuItem>
            <MudDivider />
            <MudMenuItem Icon="@Icons.Material.Filled.Logout" Href="/auth/sign-out" ForceLoad="true">@Loc["Layout.AppBar.SignOut"]</MudMenuItem>
        </MudMenu>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="1" Variant="@DrawerVariant.Persistent">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="pt-16 px-4">
        <MudContainer MaxWidth="MaxWidth.False" Class="mt-4">
            @Body
        </MudContainer>

        <MudPaper Elevation="0" Class="mt-8 pa-3 d-flex justify-center" Square="true">
            <MudText Typo="Typo.caption" Color="Color.Default">
                @Loc["Layout.Footer.Copyright"] · v0.2.2.c · @Loc["NavMenu.Tenant"]
            </MudText>
        </MudPaper>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    @Loc["Layout.Error.Unexpected"]
    <a href="." class="reload">@Loc["Layout.Error.Reload"]</a>
    <span class="dismiss">×</span>
</div>

@code {
    private bool _drawerOpen = true;
    private bool _isDark;
    private bool _isRtl;
    private MudTheme _currentTheme = CleanTenantThemes.KurumsalMavi;
    private Guid? _activeTenantId;
    private string? _activeTenantName;
    private Guid? _activeCompanyId;
    private string? _activeCompanyName;
    private LanguageOption _currentLang = LanguageService.Supported[0];

    protected override void OnInitialized()
    {
        ThemeService.ThemeChanged += OnThemeChanged;
        ApplyTheme();
        _currentLang = LanguageService.Resolve(CultureInfo.CurrentUICulture.Name);
        _isRtl = _currentLang.IsRtl;
    }

    protected override async Task OnInitializedAsync()
    {
        // Aktif bağlamı cookie claim'lerinden oku. ICurrentSessionAccessor.Current
        // SignalR circuit'inde null olabilir (HttpUserContext HTTP scope'unda set'leniyor);
        // claim'ler ise hem prerender hem interactive render'da AuthenticationState
        // üzerinden erişilebilir, daha güvenilir.
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true)
        {
            return;
        }

        if (user.FindFirst("tenant_id") is { Value: var tid } && Guid.TryParseExact(tid, "N", out var tenantGuid))
        {
            _activeTenantId = tenantGuid;
        }
        _activeTenantName = user.FindFirst("tenant_name")?.Value;

        if (user.FindFirst("company_id") is { Value: var cid } && Guid.TryParseExact(cid, "N", out var companyGuid))
        {
            _activeCompanyId = companyGuid;
        }
        _activeCompanyName = user.FindFirst("company_name")?.Value;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Routes interactive — ilk render'da JSRuntime hazır; localStorage'dan
        // tercihi oku ve tema'yı uygula (ThemeChanged event'i StateHasChanged
        // tetikler, paletler anında değişir).
        if (firstRender)
        {
            // v0.2.10.f — <html dir="..."> + <body dir="..."> RTL attribute'larını
            // set et. Aktif kültür AR ise rtl, değilse ltr. Cookie-driven culture
            // değişimi tam reload tetiklediği için her load'da idempotent çalışır.
            await JS.InvokeVoidAsync("cleantenant.setBodyDirection", _isRtl ? "rtl" : "ltr");

            await ThemeService.InitializeAsync();
        }
    }

    private void OnThemeChanged()
    {
        ApplyTheme();
        InvokeAsync(StateHasChanged);
    }

    private void ApplyTheme()
    {
        _currentTheme = CleanTenantThemes.Resolve(ThemeService.CurrentPreset);
        _isDark = ThemeService.IsDarkMode;
    }

    private async Task ChangeLanguageAsync(string code)
    {
        // v0.2.10.d — Form-post via /auth/change-culture: cookie set + (giriş
        // yapmışsa) User.PreferredCulture DB persist + returnUrl'e redirect.
        var returnUrl = "/" + Nav.ToBaseRelativePath(Nav.Uri);
        await JS.InvokeVoidAsync("cleantenant.submitCultureChange", code, returnUrl);
    }

    private void DrawerToggle() => _drawerOpen = !_drawerOpen;

    private Task OnDarkToggle() => ThemeService.ToggleDarkModeAsync();

    public void Dispose()
    {
        ThemeService.ThemeChanged -= OnThemeChanged;
    }
}
