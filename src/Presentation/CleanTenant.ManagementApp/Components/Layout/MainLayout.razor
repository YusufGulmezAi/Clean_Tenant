@inherits LayoutComponentBase
@implements IDisposable
@inject IThemeService ThemeService

@*
    AdminLTE+ pateni MudBlazor ile:
    - MudAppBar üstte (logo + sayfa başlığı + dark toggle + tema + bildirim + kullanıcı)
    - MudDrawer solda (NavMenu) — Mini variant, hover'da açılır
    - MudMainContent ortada
    - Footer altta
*@

<MudThemeProvider Theme="@_currentTheme" IsDarkMode="@_isDark" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIcon Icon="@Icons.Material.Filled.Domain" Class="mr-2" />
        <MudText Typo="Typo.h6">Toplu Yapı Yönetimi</MudText>

        <MudSpacer />

        @* Dark toggle ve drawer toggle interactive state ister; layout statik SSR'da
           kalıyor (Body parameter serialize edilemez sorunu). Dark mode için
           /settings/theme aktif; drawer hover-on-mini ile açılır. *@

        <MudIconButton Icon="@Icons.Material.Filled.Palette"
                       Color="Color.Inherit"
                       Href="/settings/theme"
                       title="Tema ayarları" />

        <MudIconButton Icon="@Icons.Material.Filled.Security"
                       Color="Color.Inherit"
                       Href="/settings/2fa/enroll"
                       title="2FA Yönetimi" />

        <MudIconButton Icon="@Icons.Material.Filled.Logout"
                       Color="Color.Inherit"
                       Href="/auth/sign-out"
                       title="Çıkış" />
    </MudAppBar>

    <MudDrawer Open="true" ClipMode="DrawerClipMode.Always" Elevation="1" Variant="@DrawerVariant.Persistent">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="pt-16 px-4">
        <MudContainer MaxWidth="MaxWidth.False" Class="mt-4">
            @Body
        </MudContainer>

        <MudPaper Elevation="0" Class="mt-8 pa-3 d-flex justify-center" Square="true">
            <MudText Typo="Typo.caption" Color="Color.Default">
                © 2026 CleanTenant · v0.2.1 (Faz 1 başlangıç) · Yönetim
            </MudText>
        </MudPaper>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    Beklenmedik bir hata oluştu.
    <a href="." class="reload">Yeniden yükle</a>
    <span class="dismiss">×</span>
</div>

@code {
    private bool _isDark;
    private MudTheme _currentTheme = CleanTenantThemes.KurumsalMavi;

    protected override void OnInitialized()
    {
        // Layout statik SSR render edilir (Body parameter RenderFragment'ı
        // interactive mode'da serialize edilemez). Default tema gösterilir;
        // kullanıcı /settings/theme'den tercihi günceller ve sonraki sayfa
        // yüklemesinde ThemeService.InitializeAsync (sayfa interactive ise)
        // localStorage'dan değeri okur.
        ThemeService.ThemeChanged += OnThemeChanged;
        ApplyTheme();
    }

    private void OnThemeChanged()
    {
        ApplyTheme();
        InvokeAsync(StateHasChanged);
    }

    private void ApplyTheme()
    {
        _currentTheme = CleanTenantThemes.Resolve(ThemeService.CurrentPreset);
        _isDark = ThemeService.IsDarkMode;
    }

    public void Dispose()
    {
        ThemeService.ThemeChanged -= OnThemeChanged;
    }
}
