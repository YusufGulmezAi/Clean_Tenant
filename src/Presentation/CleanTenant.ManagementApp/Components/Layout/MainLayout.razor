@inherits LayoutComponentBase
@implements IDisposable
@inject IThemeService ThemeService
@inject CleanTenant.Application.Common.Auth.ICurrentSessionAccessor SessionAccessor

@*
    AdminLTE+ pateni MudBlazor ile (v0.2.2.c — Routes seviyesinde InteractiveServer
    olduğu için layout state'i tam reaktif):
    - MudAppBar üstte (hamburger + logo + dark toggle + tema + 2FA + kullanıcı menüsü)
    - MudDrawer solda — Mini + hover; toggle butonu hep açık <-> mini arası geçirir
    - NavMenu içinde arama kutusu (üstte) — linkleri canlı filtreler
    - MudMainContent ortada
*@

<MudThemeProvider Theme="@_currentTheme" IsDarkMode="@_isDark" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@DrawerToggle"
                       title="Menüyü aç/kapa" />

        <MudIcon Icon="@Icons.Material.Filled.Domain" Class="mr-2" />
        <MudText Typo="Typo.h6">Toplu Yapı Yönetimi</MudText>

        <TenantSwitcher ActiveTenantId="@_activeTenantId" ActiveTenantName="@_activeTenantName" />

        <MudSpacer />

        <MudIconButton Icon="@(_isDark ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="@OnDarkToggle"
                       title="@(_isDark ? "Açık mod" : "Koyu mod")" />

        <MudIconButton Icon="@Icons.Material.Filled.Palette"
                       Color="Color.Inherit"
                       Href="/settings/theme"
                       title="Tema ayarları" />

        <MudIconButton Icon="@Icons.Material.Filled.Notifications"
                       Color="Color.Inherit"
                       title="Bildirimler (Faz 1+)" />

        <MudMenu Icon="@Icons.Material.Filled.AccountCircle"
                 Color="Color.Inherit"
                 AnchorOrigin="Origin.BottomRight"
                 TransformOrigin="Origin.TopRight">
            <MudMenuItem Icon="@Icons.Material.Filled.Person" Href="/profile">Profilim (Faz 1.2)</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.Security" Href="/settings/2fa/enroll">2FA Yönetimi</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.Settings" Href="/settings/theme">Ayarlar</MudMenuItem>
            <MudDivider />
            <MudMenuItem Icon="@Icons.Material.Filled.Logout" Href="/auth/sign-out" ForceLoad="true">Çıkış</MudMenuItem>
        </MudMenu>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="1" Variant="@DrawerVariant.Persistent">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="pt-16 px-4">
        <MudContainer MaxWidth="MaxWidth.False" Class="mt-4">
            @Body
        </MudContainer>

        <MudPaper Elevation="0" Class="mt-8 pa-3 d-flex justify-center" Square="true">
            <MudText Typo="Typo.caption" Color="Color.Default">
                © 2026 CleanTenant · v0.2.2.c · Yönetim
            </MudText>
        </MudPaper>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    Beklenmedik bir hata oluştu.
    <a href="." class="reload">Yeniden yükle</a>
    <span class="dismiss">×</span>
</div>

@code {
    private bool _drawerOpen = true;
    private bool _isDark;
    private MudTheme _currentTheme = CleanTenantThemes.KurumsalMavi;
    private Guid? _activeTenantId;
    private string? _activeTenantName;

    protected override void OnInitialized()
    {
        ThemeService.ThemeChanged += OnThemeChanged;
        ApplyTheme();

        // Aktif tenant bilgisini AuthSession'dan oku (SessionLookupMiddleware
        // her HTTP isteğinde set eder). Tenant scope kullanıcı için TenantId
        // login akışında set'lendi; System scope kullanıcı için null (kullanıcı
        // henüz tenant seçmediyse) veya seçtikten sonra dolu.
        var session = SessionAccessor.Current;
        _activeTenantId = session?.TenantId;
        _activeTenantName = session?.TenantName;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Routes interactive — ilk render'da JSRuntime hazır; localStorage'dan
        // tercihi oku ve tema'yı uygula (ThemeChanged event'i StateHasChanged
        // tetikler, paletler anında değişir).
        if (firstRender)
        {
            await ThemeService.InitializeAsync();
        }
    }

    private void OnThemeChanged()
    {
        ApplyTheme();
        InvokeAsync(StateHasChanged);
    }

    private void ApplyTheme()
    {
        _currentTheme = CleanTenantThemes.Resolve(ThemeService.CurrentPreset);
        _isDark = ThemeService.IsDarkMode;
    }

    private void DrawerToggle() => _drawerOpen = !_drawerOpen;

    private Task OnDarkToggle() => ThemeService.ToggleDarkModeAsync();

    public void Dispose()
    {
        ThemeService.ThemeChanged -= OnThemeChanged;
    }
}
