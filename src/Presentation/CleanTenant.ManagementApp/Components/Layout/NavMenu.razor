@using CleanTenant.Application.Common.Auth
@inject AuthenticationStateProvider AuthProvider
@inject IStringLocalizer Loc
@inject ICurrentSessionAccessor SessionAccessor

@*
    v0.2.3.c — Scope-aware sol drawer.

    Bağlama göre menü tamamen değişir:
      - Sistem        → Yönetimler (link) + Siteler (link) + Sistem Yönetimi
      - Yönetim       → Siteler (link) + Yönetim admin (Kullanıcılar/Roller/Audit/...)
      - Site          → Birimler + Site Ayarları

    "Yönetimler" / "Siteler" liste sayfalarına navigate eder; bağlam değişimi
    o sayfada satıra tıklayarak yapılır (NavMenu liste yapısı v0.2.3.c.2'de kaldırıldı).

    Üstte canlı arama kutusu (link'leri filtreler); eşleşmeyen NavLink'ler gizlenir.
    Tüm scope'larda altta "Ayarlar" grubu (Tema, Dil, Hakkında).

    v0.2.10.e.2 — NavMenu.* anahtarları ile lokalize edildi. Matches() filter
    artık localize edilmiş başlık üzerinde çalışır → kullanıcı aktif UI dilinde
    aratabilir.
*@

<div class="pa-2">
    <MudTextField T="string"
                  Value="@_search"
                  ValueChanged="@OnSearchChanged"
                  DebounceInterval="120"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Placeholder="@Loc["NavMenu.Search"]"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Clearable="true"
                  Immediate="true" />
</div>

<MudNavMenu Color="Color.Primary" Bordered="true">
    @{
        var dashboardLabel = Loc["NavMenu.Dashboard"].Value;
    }
    @if (Matches(dashboardLabel))
    {
        <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
            @dashboardLabel
        </MudNavLink>
    }

    @* ─── SİSTEM BAĞLAMI ─────────────────────────────────────────────── *@
    @if (_effectiveScope == "System")
    {
        var systemTenantsLabel = Loc["NavMenu.Tenants"].Value;
        var systemCompaniesLabel = Loc["NavMenu.Companies"].Value;

        @if (Matches(systemTenantsLabel))
        {
            <MudNavLink Href="/system/tenants" Icon="@Icons.Material.Filled.Domain">
                @systemTenantsLabel
            </MudNavLink>
        }
        @if (Matches(systemCompaniesLabel))
        {
            <MudNavLink Href="/system/companies" Icon="@Icons.Material.Filled.Apartment">
                @systemCompaniesLabel
            </MudNavLink>
        }

        var systemAdminChildren = new[]
        {
            (Loc["NavMenu.SystemUsers"].Value, "/users", Icons.Material.Filled.ManageAccounts, "", false),
            (Loc["NavMenu.LookUpTables"].Value, "/system/lookup-tables", Icons.Material.Filled.DataObject, "", false),
            (Loc["NavMenu.Banks"].Value, "/system/banks", Icons.Material.Filled.AccountBalance, "", false),
            (Loc["NavMenu.AuditExplorer"].Value, "/system/audit", Icons.Material.Filled.History, "", false),
            (Loc["NavMenu.Localization"].Value, "/system/localization", Icons.Material.Filled.Translate, "", false),
            (Loc["NavMenu.LogViewer"].Value, "/logs", Icons.Material.Filled.Article, "Faz 1.6", true),
            (Loc["NavMenu.Roles"].Value, "/system/roles", Icons.Material.Filled.Shield, "", false),
            (Loc["NavMenu.PermissionCatalog"].Value, "/permissions", Icons.Material.Filled.Security, "Faz 1.5", true),
            (Loc["NavMenu.SystemSettings"].Value, "/system/settings", Icons.Material.Filled.Tune, "Faz 1.4", true),
        };
        var systemAdminVisible = AnyMatch(systemAdminChildren.Select(c => c.Item1));
        @if (systemAdminVisible)
        {
            <MudNavGroup Title="@Loc["NavMenu.SystemAdmin"]" Icon="@Icons.Material.Filled.AdminPanelSettings" Expanded="@IsSearching">
                @foreach (var (title, href, icon, phase, disabled) in systemAdminChildren)
                {
                    if (Matches(title))
                    {
                        <MudNavLink Href="@href" Icon="@icon" Disabled="@disabled">
                            @title
                            @if (!string.IsNullOrEmpty(phase))
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Class="ml-2">@phase</MudChip>
                            }
                        </MudNavLink>
                    }
                }
            </MudNavGroup>
        }
    }

    @* ─── YÖNETİM (TENANT) BAĞLAMI ─────────────────────────────────── *@
    @if (_effectiveScope == "Tenant")
    {
        var tenantCompaniesLabel = Loc["NavMenu.Companies"].Value;
        var tenantBudgetLabel = Loc["NavMenu.Budget"].Value;
        var tenantUsersLabel = Loc["NavMenu.Users"].Value;
        var tenantRolesLabel = Loc["NavMenu.RolesAndPermissions"].Value;
        var tenantRolesUsersLabel = Loc["NavMenu.RolesAndUsers"].Value;

        @if (Matches(tenantCompaniesLabel))
        {
            <MudNavLink Href="/tenant/companies" Icon="@Icons.Material.Filled.Apartment">
                @tenantCompaniesLabel
            </MudNavLink>
        }

        @* v0.2.13.a — Bütçe Tenant scope (permission-gated, izinli kullanıcı görür) *@
        @if (_canViewBudget && Matches(tenantBudgetLabel))
        {
            <MudNavLink Href="/tenant/budget" Icon="@Icons.Material.Filled.AccountBalanceWallet">
                @tenantBudgetLabel
            </MudNavLink>
        }

        @if (AnyMatch(_canManageUsers ? new[] { tenantUsersLabel, tenantRolesLabel } : new[] { tenantRolesLabel }))
        {
            <MudNavGroup Title="@tenantRolesUsersLabel" Icon="@Icons.Material.Filled.ManageAccounts" Expanded="@IsSearching">
                @if (_canManageUsers && Matches(tenantUsersLabel))
                {
                    <MudNavLink Href="/users" Icon="@Icons.Material.Filled.People">
                        @tenantUsersLabel
                    </MudNavLink>
                }
                @if (Matches(tenantRolesLabel))
                {
                    <MudNavLink Href="/tenant/roles" Icon="@Icons.Material.Filled.Security">
                        @tenantRolesLabel
                    </MudNavLink>
                }
            </MudNavGroup>
        }

        var tenantAdminChildren = new[]
        {
            (Loc["NavMenu.AuditHistory"].Value, "/tenant/audit", Icons.Material.Filled.History, "Faz 1.6", true),
            (Loc["NavMenu.SupportAccess"].Value, "/tenant/support-access", Icons.Material.Filled.Support, "Faz 1.6", true),
            (Loc["NavMenu.TenantSettings"].Value, "/tenant/settings", Icons.Material.Filled.Settings, string.Empty, false),
        };
        var tenantAdminVisible = AnyMatch(tenantAdminChildren.Select(c => c.Item1));
        @if (tenantAdminVisible)
        {
            <MudNavGroup Title="@Loc["NavMenu.Tenant"]" Icon="@Icons.Material.Filled.AdminPanelSettings" Expanded="@IsSearching">
                @foreach (var (title, href, icon, phase, disabled) in tenantAdminChildren)
                {
                    if (Matches(title))
                    {
                        <MudNavLink Href="@href" Icon="@icon" Disabled="@disabled">
                            @title
                            @if (disabled)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Class="ml-2">@phase</MudChip>
                            }
                        </MudNavLink>
                    }
                }
            </MudNavGroup>
        }
    }

    @* ─── SİTE (COMPANY) BAĞLAMI ─────────────────────────────────── *@
    @if (_effectiveScope == "Company")
    {
        @* Kullanıcılar — Company scope kullanıcı yönetimi (permission-gated). /users
           etkin bağlamı company_id'den çözer; tek route, scope-aware panel. *@
        var companyUsersLabel = Loc["NavMenu.Users"].Value;
        @if (_canManageCompanyUsers && Matches(companyUsersLabel))
        {
            <MudNavGroup Title="@Loc["NavMenu.RolesAndUsers"]" Icon="@Icons.Material.Filled.ManageAccounts" Expanded="@IsSearching">
                <MudNavLink Href="/users" Icon="@Icons.Material.Filled.People">
                    @companyUsersLabel
                </MudNavLink>
            </MudNavGroup>
        }

        var companyChildren = new[]
        {
            (Loc["NavMenu.Units"].Value, "/company/units", Icons.Material.Filled.HomeWork, "Faz 1.6"),
            (Loc["NavMenu.Residents"].Value, "/company/residents", Icons.Material.Filled.People, "Faz 1.7"),
            (Loc["NavMenu.Invoices"].Value, "/company/invoices", Icons.Material.Filled.Receipt, "Faz 1.7"),
            (Loc["NavMenu.CompanySettings"].Value, "/company/settings", Icons.Material.Filled.Settings, "Faz 1.6"),
        };
        var companyVisible = AnyMatch(companyChildren.Select(c => c.Item1));
        @if (companyVisible)
        {
            <MudNavGroup Title="@Loc["NavMenu.Company"]" Icon="@Icons.Material.Filled.Apartment" Expanded="@(IsSearching || true)">
                @foreach (var (title, href, icon, phase) in companyChildren)
                {
                    if (Matches(title))
                    {
                        <MudNavLink Href="@href" Icon="@icon" Disabled="true">
                            @title
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Class="ml-2">@phase</MudChip>
                        </MudNavLink>
                    }
                }
            </MudNavGroup>
        }

        @* ── Muhasebe Grubu ─────────────────────────────────────────── *@
        var accountingChildren = new[]
        {
            (Loc["NavMenu.Accounting.ChartOfAccounts"].Value, "/company/accounting/chart-of-accounts", Icons.Material.Filled.AccountTree),
            (Loc["NavMenu.Accounting.Journal"].Value,         "/company/accounting/journal",             Icons.Material.Filled.EditNote),
            (Loc["NavMenu.Accounting.FiscalYears"].Value,     "/company/accounting/fiscal-years",        Icons.Material.Filled.CalendarMonth),
            (Loc["NavMenu.Accounting.Banks"].Value,            "/company/accounting/bank-accounts",       Icons.Material.Filled.AccountBalance),
            (Loc["NavMenu.Accounting.Invoices"].Value,         "/company/accounting/invoices",            Icons.Material.Filled.ReceiptLong),
            // v0.2.13.a — Bütçe Site scope'tan çıkarıldı (Tenant scope'a taşındı, tenant.budget.* permission).
            (Loc["NavMenu.Accounting.Reports"].Value,          "/company/accounting/reports/trial-balance", Icons.Material.Filled.TableChart),
            (Loc["NavMenu.Accounting.Settings"].Value,         "/company/accounting/settings",            Icons.Material.Filled.Tune),
        };
        var accountingVisible = AnyMatch(accountingChildren.Select(c => c.Item1));
        @if (accountingVisible)
        {
            <MudNavGroup Title="@Loc["NavMenu.Accounting"]" Icon="@Icons.Material.Filled.Calculate" Expanded="@IsSearching">
                @foreach (var (title, href, icon) in accountingChildren)
                {
                    if (Matches(title))
                    {
                        <MudNavLink Href="@href" Icon="@icon">@title</MudNavLink>
                    }
                }
            </MudNavGroup>
        }
    }

    <MudDivider Class="my-2" />

    @{
        var settingsChildren = new[]
        {
            (Loc["NavMenu.Theme"].Value, "/settings/theme", Icons.Material.Filled.Palette),
            (Loc["NavMenu.Language"].Value, "/settings/language", Icons.Material.Filled.Language),
            (Loc["NavMenu.About"].Value, "/about", Icons.Material.Filled.Info),
        };
        var settingsVisible = AnyMatch(settingsChildren.Select(c => c.Item1));
    }
    @if (settingsVisible)
    {
        <MudNavGroup Title="@Loc["NavMenu.Settings"]" Icon="@Icons.Material.Filled.Settings" Expanded="@IsSearching">
            @foreach (var (title, href, icon) in settingsChildren)
            {
                if (Matches(title))
                {
                    <MudNavLink Href="@href" Icon="@icon">@title</MudNavLink>
                }
            }
        </MudNavGroup>
    }
</MudNavMenu>

<div class="pa-3 d-flex justify-center">
    <MudText Typo="Typo.caption" Color="Color.Default">
        @Loc["Layout.Footer.Copyright"]
    </MudText>
</div>

@code {
    private string _search = string.Empty;
    private string? _scope;
    /// <summary>Etkin bağlam: System operatörü bir tenant/company'ye geçince scope
    /// "System" kalsa da tenant_id/company_id doluysa o alt bağlamın menüsü gösterilir.</summary>
    private string? _effectiveScope;
    private Guid? _activeTenantId;
    private Guid? _activeCompanyId;
    private bool _canManageUsers;
    private bool _canViewBudget;
    private bool _canManageCompanyUsers;

    private bool IsSearching => !string.IsNullOrWhiteSpace(_search);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true)
        {
            return;
        }

        _scope = user.FindFirst("scope")?.Value;

        if (user.FindFirst("tenant_id") is { Value: var tid } && Guid.TryParseExact(tid, "N", out var tenantGuid))
        {
            _activeTenantId = tenantGuid;
        }
        if (user.FindFirst("company_id") is { Value: var cid } && Guid.TryParseExact(cid, "N", out var companyGuid))
        {
            _activeCompanyId = companyGuid;
        }

        // System scope tüm yetkilere sahiptir; Tenant scope için session permission'ı kontrol et.
        if (string.Equals(_scope, "System", StringComparison.OrdinalIgnoreCase))
        {
            _canManageUsers = true;
            _canViewBudget = true;
            _canManageCompanyUsers = true;
        }
        else
        {
            var session = SessionAccessor.Current;
            _canManageUsers = session is not null && session.Permissions.Contains("Tenant.Users.Manage");
            _canViewBudget = session is not null && session.Permissions.Contains("tenant.budget.view");
            _canManageCompanyUsers = session is not null && session.Permissions.Contains("Company.Users.Manage");
        }

        // Etkin bağlam: tenant_id/company_id doluysa (System operatörü destek bağlamına
        // geçmiş olsa bile) alt bağlamın menüsü gösterilir; saf System'de Sistem menüsü.
        _effectiveScope = _activeCompanyId.HasValue ? "Company"
                        : _activeTenantId.HasValue ? "Tenant"
                        : "System";
    }

    private void OnSearchChanged(string value)
    {
        _search = value ?? string.Empty;
        StateHasChanged();
    }

    private static readonly System.Globalization.CultureInfo _trCulture =
        System.Globalization.CultureInfo.GetCultureInfo("tr-TR");

    private bool Matches(string title)
    {
        if (!IsSearching) return true;
        return _trCulture.CompareInfo.IndexOf(title, _search,
            System.Globalization.CompareOptions.IgnoreCase) >= 0;
    }

    private bool AnyMatch(IEnumerable<string> titles)
    {
        if (!IsSearching) return true;
        return titles.Any(t => _trCulture.CompareInfo.IndexOf(t, _search,
            System.Globalization.CompareOptions.IgnoreCase) >= 0);
    }
}
