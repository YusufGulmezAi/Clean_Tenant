@inject IDbContextFactory<CleanTenant.Infrastructure.Persistence.Catalog.CatalogDbContext> CatalogFactory
@inject CleanTenant.Application.Common.Caching.ICacheStore Cache
@inject CleanTenant.Application.Features.Catalog.Readers.ITenantCatalogReader TenantReader
@inject CleanTenant.Application.Features.Main.Readers.IMainCatalogReader CompanyReader
@inject AuthenticationStateProvider AuthProvider
@inject PersistentComponentState PersistentState
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable
@using Microsoft.EntityFrameworkCore
@using CleanTenant.SharedKernel.Context
@using CleanTenant.Application.Common.Caching

@*
    v0.2.3.d — AppBar bağlam (context) seçici. Generic hybrid cache + reader pattern
    + PersistentComponentState ile yeniden yapılandırıldı:

    - Atanmış Yönetim/Site listesi: ICacheStore key `user:contexts:{userId}` — 5 dk TTL.
    - Tenant adları: ITenantCatalogReader cache'inden lookup (cascade hit).
    - Company adları: IMainCatalogReader cache'inden lookup.
    - PersistentComponentState ile prerender → interactive double-render önlendi.

    Sadece kullanıcının **gerçek rol atamaları** listelenir (UserRoleAssignments).
    Sistem operatörü tüm Yönetim/Site listesini sol menü üzerinden /system/* sayfalarına
    erişir; bu dropdown'da değil.
*@

@if (_canShow)
{
    <MudMenu Color="Color.Inherit"
             ActivationEvent="@MouseEvent.LeftClick"
             AnchorOrigin="Origin.BottomLeft"
             TransformOrigin="Origin.TopLeft"
             Class="ml-3">
        <ActivatorContent>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Secondary"
                       StartIcon="@CurrentIcon"
                       EndIcon="@Icons.Material.Filled.ArrowDropDown"
                       Class="text-transform-none">
                <span style="white-space: nowrap; display: inline-flex; align-items: baseline;">
                    <MudText Typo="Typo.body2"><b>@CurrentLabel</b></MudText>
                </span>
            </MudButton>
        </ActivatorContent>
        <ChildContent>
            <div class="px-3 pt-3 pb-2" style="min-width: 360px;">
                <MudTextField T="string"
                              Value="@_searchText"
                              ValueChanged="@OnSearchChanged"
                              Placeholder="Bağlam ara…"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Immediate="true"
                              Clearable="true"
                              DebounceInterval="100" />
            </div>
            <MudDivider />

            @if (_view?.HasSystemAssignment == true && SystemMatchesFilter())
            {
                <div class="px-4 pt-2 pb-1">
                    <MudText Typo="Typo.caption" Color="Color.Default"
                             Style="font-weight:600; letter-spacing:.5px;">SİSTEM</MudText>
                </div>
                var systemActive = ActiveTenantId is null;
                <MudMenuItem Icon="@Icons.Material.Filled.AdminPanelSettings"
                             IconColor="@(systemActive ? Color.Success : Color.Warning)"
                             OnClick="@SubmitSwitchToSystemAsync">
                    <span style="white-space: nowrap;">
                        <b>Sistem</b>
                        @if (systemActive)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Success" Class="ml-2">aktif</MudText>
                        }
                    </span>
                </MudMenuItem>
                <MudDivider />
            }

            @if (_view is { Contexts.Count: 0, HasSystemAssignment: false })
            {
                <div class="px-4 py-3 d-flex justify-center">
                    <MudText Typo="Typo.body2" Color="Color.Default">Atanmış bağlam yok</MudText>
                </div>
            }
            else if (_view is not null && VisibleTenantCount > 0)
            {
                <div class="px-4 pt-2 pb-1">
                    <MudText Typo="Typo.caption" Color="Color.Default"
                             Style="font-weight:600; letter-spacing:.5px;">YÖNETİMLER (@VisibleTenantCount)</MudText>
                </div>
                @foreach (var ctx in _view.Contexts)
                {
                    var tenantNameMatches = TenantMatchesFilter(ctx);
                    var anyCompanyMatches = ctx.Companies.Any(CompanyMatchesFilter);

                    if (!tenantNameMatches && !anyCompanyMatches)
                    {
                        continue;
                    }

                    var tenantActive = ActiveTenantId == ctx.TenantId && ActiveCompanyId is null;
                    <MudMenuItem Icon="@Icons.Material.Filled.Domain"
                                 IconColor="@(tenantActive ? Color.Success : Color.Info)"
                                 OnClick="@(() => SubmitSwitchAsync(ctx.TenantId, null))">
                        <span style="white-space: nowrap;">
                            <b>@ctx.Name</b>
                            @if (tenantActive)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Success" Class="ml-2">aktif</MudText>
                            }
                        </span>
                    </MudMenuItem>

                    @foreach (var company in ctx.Companies)
                    {
                        if (!tenantNameMatches && !CompanyMatchesFilter(company))
                        {
                            continue;
                        }

                        var companyActive = ActiveTenantId == ctx.TenantId && ActiveCompanyId == company.CompanyId;
                        <MudMenuItem Icon="@Icons.Material.Filled.Apartment"
                                     IconColor="@(companyActive ? Color.Success : Color.Tertiary)"
                                     Class="pl-8"
                                     OnClick="@(() => SubmitSwitchAsync(ctx.TenantId, company.CompanyId))">
                            <span style="white-space: nowrap;">
                                @company.Name
                                @if (companyActive)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Success" Class="ml-2">aktif</MudText>
                                }
                            </span>
                        </MudMenuItem>
                    }
                }
            }
        </ChildContent>
    </MudMenu>
}

@code {
    [Parameter] public Guid? ActiveTenantId { get; set; }
    [Parameter] public string? ActiveTenantName { get; set; }
    [Parameter] public Guid? ActiveCompanyId { get; set; }
    [Parameter] public string? ActiveCompanyName { get; set; }

    private const string PersistKeyPrefix = "tenantswitcher.contexts.";

    private string _searchText = string.Empty;
    private bool _canShow;
    private Guid _userId;
    private UserContextView? _view;
    private PersistingComponentStateSubscription _persistSubscription;

    /// <summary>Serialize edilebilir + cache'lenebilir model — TenantSwitcher dropdown'unun
    /// ihtiyacı olan bilginin tamamını taşır.</summary>
    public sealed record UserContextView(
        bool HasSystemAssignment,
        IReadOnlyList<TenantContextRow> Contexts);

    public sealed record TenantContextRow(Guid TenantId, string UrlCode, string Name, IReadOnlyList<CompanyRow> Companies);

    public sealed record CompanyRow(Guid CompanyId, string UrlCode, string Name);

    private string CurrentLabel
    {
        get
        {
            if (ActiveCompanyId is not null && !string.IsNullOrWhiteSpace(ActiveCompanyName))
            {
                return $"{ActiveTenantName} → {ActiveCompanyName}";
            }
            if (ActiveTenantId is not null && !string.IsNullOrWhiteSpace(ActiveTenantName))
            {
                return ActiveTenantName!;
            }
            return _view?.HasSystemAssignment == true ? "Sistem" : "Bağlam seç";
        }
    }

    private string CurrentIcon
    {
        get
        {
            if (ActiveCompanyId is not null) return Icons.Material.Filled.Apartment;
            if (ActiveTenantId is not null) return Icons.Material.Filled.Domain;
            return Icons.Material.Filled.AdminPanelSettings;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true) return;

        var userIdStr = user.FindFirst("user_id")?.Value
                     ?? user.FindFirst("sub")?.Value
                     ?? user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (!Guid.TryParse(userIdStr, out _userId))
        {
            _canShow = false;
            return;
        }

        var persistKey = PersistKeyPrefix + _userId.ToString("N");

        // Prerender → interactive transfer
        if (PersistentState.TryTakeFromJson<UserContextView>(persistKey, out var cached) && cached is not null)
        {
            _view = cached;
            _canShow = _view.HasSystemAssignment || _view.Contexts.Count > 0;
            return;
        }

        _view = await Cache.GetOrCreateAsync(
            CacheKeys.User.Contexts(_userId),
            LoadContextsAsync,
            CacheOptions.ListShortLived);

        _canShow = _view.HasSystemAssignment || _view.Contexts.Count > 0;

        _persistSubscription = PersistentState.RegisterOnPersisting(() =>
        {
            PersistentState.PersistAsJson(persistKey, _view);
            return Task.CompletedTask;
        });
    }

    private async Task<UserContextView> LoadContextsAsync(CancellationToken ct)
    {
        await using var db = await CatalogFactory.CreateDbContextAsync(ct);
        var assignments = await db.UserRoleAssignments
            .AsNoTracking()
            .Where(a => a.UserId == _userId && a.IsActive)
            .Select(a => new { a.ScopeLevel, a.TenantId, a.CompanyId })
            .ToListAsync(ct);

        var hasSystem = assignments.Any(a => a.ScopeLevel == ScopeLevel.System);

        // Reader'lar — cache hit'lerden faydalan (tüm aktif Yönetim + tüm Site).
        var allTenants = await TenantReader.GetAllActiveAsync(ct);
        var allCompanies = await CompanyReader.GetAllGlobalAsync(ct);

        // ── System operatörü: tüm aktif Yönetim + tüm Site'lere erişir ─────────
        // Gerçek rol ataması gerekmez; SwitchTenantCommandHandler System scope'u
        // korur ve geçişte (KVKK/audit için) otomatik SupportSession açar
        // (yazma yetkisi tenant.AllowSystemWriteAccess'e göre WriteEnabled/ReadOnly).
        // Dropdown bu yüzden System kullanıcıya tam katalogu gösterir.
        if (hasSystem)
        {
            var activeTenantIds = allTenants.Select(t => t.Id).ToHashSet();
            var companiesByTenant = allCompanies
                .Where(c => activeTenantIds.Contains(c.TenantId))
                .GroupBy(c => c.TenantId)
                .ToDictionary(
                    g => g.Key,
                    g => (IReadOnlyList<CompanyRow>)g
                        .OrderBy(c => c.Name)
                        .Select(c => new CompanyRow(c.Id, c.UrlCode, c.Name)).ToList());

            var allContexts = allTenants
                .OrderBy(t => t.Name)
                .Select(t => new TenantContextRow(
                    t.Id, t.UrlCode, t.Name,
                    companiesByTenant.TryGetValue(t.Id, out var sysCs) ? sysCs : []))
                .ToList();

            return new UserContextView(true, allContexts);
        }

        // ── Alt scope kullanıcı: yalnız gerçek rol atamaları ───────────────────
        var assignedTenantIds = assignments
            .Where(a => a.TenantId.HasValue)
            .Select(a => a.TenantId!.Value)
            .Distinct()
            .ToHashSet();

        if (assignedTenantIds.Count == 0)
        {
            return new UserContextView(false, []);
        }

        var assignedTenants = allTenants
            .Where(t => assignedTenantIds.Contains(t.Id))
            .ToList();

        var tenantLevelTenantIds = assignments
            .Where(a => a.ScopeLevel == ScopeLevel.Tenant && a.TenantId.HasValue)
            .Select(a => a.TenantId!.Value)
            .Distinct()
            .ToHashSet();

        var assignedCompanyIds = assignments
            .Where(a => a.ScopeLevel == ScopeLevel.Company && a.CompanyId.HasValue)
            .Select(a => a.CompanyId!.Value)
            .Distinct()
            .ToHashSet();

        // Company listesi: tenant-level ataması olan Yönetim'lerin tüm site'leri +
        // company-level ataması olan tek site'ler. Reader cache'ten global hit
        // çekilir, local filter.
        var visibleCompanies = allCompanies
            .Where(c => assignedTenantIds.Contains(c.TenantId)
                     && (tenantLevelTenantIds.Contains(c.TenantId) || assignedCompanyIds.Contains(c.Id)))
            .ToList();

        var byTenant = visibleCompanies
            .GroupBy(c => c.TenantId)
            .ToDictionary(
                g => g.Key,
                g => (IReadOnlyList<CompanyRow>)g.Select(c => new CompanyRow(c.Id, c.UrlCode, c.Name)).ToList());

        var contexts = assignedTenants
            .Select(t => new TenantContextRow(
                t.Id, t.UrlCode, t.Name,
                byTenant.TryGetValue(t.Id, out var cs) ? cs : []))
            .ToList();

        return new UserContextView(false, contexts);
    }

    /// <summary>Aktif arama filtresine göre görünen Yönetim sayısı — başlık rozeti
    /// (YÖNETİMLER (N)) ve grup görünürlüğü bunu kullanır.</summary>
    private int VisibleTenantCount =>
        _view?.Contexts.Count(ctx => TenantMatchesFilter(ctx) || ctx.Companies.Any(CompanyMatchesFilter)) ?? 0;

    private bool SystemMatchesFilter() =>
        string.IsNullOrWhiteSpace(_searchText)
        || "sistem".Contains(_searchText, StringComparison.OrdinalIgnoreCase);

    private bool TenantMatchesFilter(TenantContextRow tenant)
    {
        if (string.IsNullOrWhiteSpace(_searchText)) return true;
        return tenant.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || tenant.UrlCode.Contains(_searchText, StringComparison.OrdinalIgnoreCase);
    }

    private bool CompanyMatchesFilter(CompanyRow company)
    {
        if (string.IsNullOrWhiteSpace(_searchText)) return true;
        return company.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || company.UrlCode.Contains(_searchText, StringComparison.OrdinalIgnoreCase);
    }

    private void OnSearchChanged(string value)
    {
        _searchText = value ?? string.Empty;
        StateHasChanged();
    }

    private async Task SubmitSwitchAsync(Guid tenantId, Guid? companyId)
    {
        var returnUrl = "/" + Nav.ToBaseRelativePath(Nav.Uri);
        await JS.InvokeVoidAsync(
            "cleantenant.submitTenantSwitch",
            tenantId.ToString(),
            returnUrl,
            companyId?.ToString() ?? string.Empty);
    }

    private async Task SubmitSwitchToSystemAsync()
    {
        var returnUrl = "/" + Nav.ToBaseRelativePath(Nav.Uri);
        await JS.InvokeVoidAsync("cleantenant.submitSwitchToSystem", returnUrl);
    }

    public void Dispose() => _persistSubscription.Dispose();
}
