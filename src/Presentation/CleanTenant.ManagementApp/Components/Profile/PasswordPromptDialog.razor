@using MudBlazor
@inject IStringLocalizer Loc

@*
    Şifre doğrulama diyaloğu (v0.2.13). Hassas işlemler öncesi (örn. System dışı
    kullanıcının 2FA'yı pasife alması) hesap şifresini ister. Onayda girilen
    şifreyi DialogResult.Ok(string) ile döner; iptalde Cancel.
*@

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Size="Size.Medium" />
            <MudText Typo="Typo.h6">@MudDialog.Title</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @if (!string.IsNullOrEmpty(Message))
        {
            <MudText Typo="Typo.body2" Class="mb-3">@Message</MudText>
        }
        <MudTextField @bind-Value="_password"
                      Label="@Loc["Profile.TwoFactor.PasswordLabel"]"
                      Variant="Variant.Outlined"
                      InputType="InputType.Password"
                      Immediate="true"
                      OnKeyDown="OnKeyDown"
                      AutoFocus="true" />
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">@Loc["Common.Cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="Submit" Disabled="@string.IsNullOrEmpty(_password)">
            @ConfirmText
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>Diyalog gövdesinde gösterilecek açıklama (opsiyonel).</summary>
    [Parameter] public string? Message { get; set; }

    /// <summary>Onayla butonu metni.</summary>
    [Parameter] public string ConfirmText { get; set; } = "Onayla";

    private string _password = string.Empty;

    private void Submit()
    {
        if (!string.IsNullOrEmpty(_password))
        {
            MudDialog.Close(DialogResult.Ok(_password));
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or "NumpadEnter")
        {
            Submit();
        }
    }
}
