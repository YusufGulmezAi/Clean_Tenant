# CleanTenant — Production Ortamı Sır ve Konfigürasyon Şablonu
#
# UYARI: Production'da bu dosyanın yerini ZAMANLA VAULT alacaktır
# (HashiCorp Vault / Azure Key Vault / AWS Secrets Manager).
# İlk deploy için köprü modu olarak host'ta .env.production dosyası
# 600 iznindeyse kabul edilebilir; tüm sırlar mutlaka rotation politikasına
# bağlı tutulur.
#
# Bu dosya yalnız placeholder. Asla gerçek prod değerlerini repo'ya yazmayın.

COMPOSE_PROJECT_NAME=cleantenant-production
ASPNETCORE_ENVIRONMENT=Production

# PostgreSQL — prod'da dış port yok; sadece internal network
POSTGRES_PORT=5732
POSTGRES_USER=cleantenant
POSTGRES_PASSWORD=__VAULTTAN_GELECEK__

# Connection string'ler prod'da Docker network içinden çözümlenir; host=postgres
ConnectionStrings__Catalog=Host=postgres;Port=5432;Database=cleantenant_catalog;Username=cleantenant;Password=__VAULTTAN_GELECEK__;SSL Mode=Require;Trust Server Certificate=false
ConnectionStrings__Main=Host=postgres;Port=5432;Database=cleantenant_main;Username=cleantenant;Password=__VAULTTAN_GELECEK__;SSL Mode=Require;Trust Server Certificate=false
ConnectionStrings__Log=Host=postgres;Port=5432;Database=cleantenant_log;Username=cleantenant;Password=__VAULTTAN_GELECEK__;SSL Mode=Require;Trust Server Certificate=false
ConnectionStrings__Audit=Host=postgres;Port=5432;Database=cleantenant_audit;Username=cleantenant;Password=__VAULTTAN_GELECEK__;SSL Mode=Require;Trust Server Certificate=false

# Redis
REDIS_PORT=6679
REDIS_PASSWORD=__VAULTTAN_GELECEK__
ConnectionStrings__Redis=redis:6379,password=__VAULTTAN_GELECEK__,ssl=true,abortConnect=false

# MinIO / S3 — object storage (profil fotoğrafı, dosya ekleri)
# Prod'da erişim anahtarları vault'tan gelir; UseSsl=true; bucket önceden
# altyapı tarafından oluşturulur (CreateBucketIfMissing=false önerilir).
MINIO_ROOT_USER=__VAULTTAN_GELECEK__
MINIO_ROOT_PASSWORD=__VAULTTAN_GELECEK__
ObjectStorage__Endpoint=minio:9000
ObjectStorage__AccessKey=__VAULTTAN_GELECEK__
ObjectStorage__SecretKey=__VAULTTAN_GELECEK__
ObjectStorage__UseSsl=true
ObjectStorage__Bucket=cleantenant-files
ObjectStorage__CreateBucketIfMissing=false

# JWT — prod key rotation 90 günde bir
JWT_ISSUER=cleantenant.com
JWT_AUDIENCE=cleantenant.clients
JWT_SIGNING_KEY=__VAULTTAN_GELECEK_256BIT__
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
