# CleanTenant — Development Ortamı Sır ve Konfigürasyon Şablonu
#
# KULLANIM:
#   1) Bu dosyayı .env.development olarak kopyalayın.
#   2) __DEGISTIR__ ile başlayan tüm değerleri gerçek değerlerle değiştirin.
#   3) .env.development dosyası gitignore'a dahildir; ASLA commit etmeyin.
#
# Yeni geliştirici için: scripts/setup-env.ps1 -Env Development komutu
# bu dosyayı otomatik kopyalayıp size rehberlik edecektir (Faz v0.1.10).

# -------------------------------------------------------------------
# Docker Compose
# -------------------------------------------------------------------
COMPOSE_PROJECT_NAME=cleantenant-development

# -------------------------------------------------------------------
# .NET Runtime
# -------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development

# -------------------------------------------------------------------
# PostgreSQL — Catalog / Main / Log / Audit (tek instance, 4 DB)
# -------------------------------------------------------------------
POSTGRES_PORT=5432
POSTGRES_USER=cleantenant
POSTGRES_PASSWORD=__DEGISTIR_GUCLU_SIFRE__

# Uygulamanın okuyacağı connection string'ler (4 ayrı DB).
# .NET'in ConnectionStrings:Catalog formatına __ ile çift alt çizgi mapping.
ConnectionStrings__Catalog=Host=localhost;Port=5432;Database=cleantenant_catalog;Username=cleantenant;Password=__DEGISTIR_GUCLU_SIFRE__;Include Error Detail=true
ConnectionStrings__Main=Host=localhost;Port=5432;Database=cleantenant_main;Username=cleantenant;Password=__DEGISTIR_GUCLU_SIFRE__;Include Error Detail=true
ConnectionStrings__Log=Host=localhost;Port=5432;Database=cleantenant_log;Username=cleantenant;Password=__DEGISTIR_GUCLU_SIFRE__;Include Error Detail=true
ConnectionStrings__Audit=Host=localhost;Port=5432;Database=cleantenant_audit;Username=cleantenant;Password=__DEGISTIR_GUCLU_SIFRE__;Include Error Detail=true

# -------------------------------------------------------------------
# Redis — Cache, idempotency keys, refresh token store
# -------------------------------------------------------------------
REDIS_PORT=6379
REDIS_PASSWORD=__DEGISTIR_GUCLU_SIFRE__
ConnectionStrings__Redis=localhost:6379,password=__DEGISTIR_GUCLU_SIFRE__,abortConnect=false

# -------------------------------------------------------------------
# MinIO — S3-uyumlu object storage (profil fotoğrafı, dosya ekleri)
# -------------------------------------------------------------------
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=cleantenant
MINIO_ROOT_PASSWORD=__DEGISTIR_GUCLU_SIFRE_MIN_8__

# Uygulamanın okuyacağı object storage ayarları (ObjectStorage:* section'a __ mapping).
# Endpoint şema içermez; UseSsl=false (dev). Bucket startup'ta otomatik oluşturulur.
ObjectStorage__Endpoint=localhost:9000
ObjectStorage__AccessKey=cleantenant
ObjectStorage__SecretKey=__DEGISTIR_GUCLU_SIFRE_MIN_8__
ObjectStorage__UseSsl=false
ObjectStorage__Bucket=cleantenant-files

# -------------------------------------------------------------------
# Seq — Yerel log inceleme UI (sadece Dev/Demo)
# -------------------------------------------------------------------
SEQ_PORT=5341
# Aşağıdaki hash bir örnek değerdir; KENDI hash'inizi üretin:
#   docker run --rm -it datalust/seq config hash 'MySecretPassword'
# Komutu çalıştırıp çıktıyı buraya yapıştırın.
SEQ_ADMIN_PASSWORD_HASH=__DEGISTIR_SEQ_HASH__

# -------------------------------------------------------------------
# JWT — Identity (v0.1.5'te aktif kullanım)
# -------------------------------------------------------------------
JWT_ISSUER=cleantenant.dev
JWT_AUDIENCE=cleantenant.dev.clients
# En az 256-bit (32 karakter) rastgele bir anahtar. Üretim için:
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
JWT_SIGNING_KEY=__DEGISTIR_256BIT_RASGELE_ANAHTAR__
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

# -------------------------------------------------------------------
# Seed Admin (Dev/Demo seed sırasında oluşturulan kullanıcı için)
# -------------------------------------------------------------------
# Şifre policy: min 8 karakter + en az 1 büyük + 1 küçük + 1 rakam + 1 özel karakter.
# Aksi takdirde Identity validation hata verir ve seed başarısız olur.
SEED_ADMIN_PASSWORD=__DEGISTIR_GUCLU_SIFRE_MIN_8__
