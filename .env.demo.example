# CleanTenant — Demo Ortamı Sır ve Konfigürasyon Şablonu
#
# Demo host'unda .env.demo dosyası 600 izniyle (chmod 600) tutulur.
# Demo şifreleri çeyrek bazlı rotate edilir; rotation runbook'u ops takımında.

COMPOSE_PROJECT_NAME=cleantenant-demo
ASPNETCORE_ENVIRONMENT=Demo

# PostgreSQL
POSTGRES_PORT=5632
POSTGRES_USER=cleantenant
POSTGRES_PASSWORD=__DEGISTIR_DEMO_SIFRE__

ConnectionStrings__Catalog=Host=localhost;Port=5632;Database=cleantenant_catalog;Username=cleantenant;Password=__DEGISTIR_DEMO_SIFRE__
ConnectionStrings__Main=Host=localhost;Port=5632;Database=cleantenant_main;Username=cleantenant;Password=__DEGISTIR_DEMO_SIFRE__
ConnectionStrings__Log=Host=localhost;Port=5632;Database=cleantenant_log;Username=cleantenant;Password=__DEGISTIR_DEMO_SIFRE__
ConnectionStrings__Audit=Host=localhost;Port=5632;Database=cleantenant_audit;Username=cleantenant;Password=__DEGISTIR_DEMO_SIFRE__

# Redis
REDIS_PORT=6579
REDIS_PASSWORD=__DEGISTIR_DEMO_SIFRE__
ConnectionStrings__Redis=localhost:6579,password=__DEGISTIR_DEMO_SIFRE__,abortConnect=false

# Seq
SEQ_PORT=5541
SEQ_ADMIN_PASSWORD_HASH=__DEGISTIR_SEQ_HASH__

# JWT
JWT_ISSUER=cleantenant.demo
JWT_AUDIENCE=cleantenant.demo.clients
JWT_SIGNING_KEY=__DEGISTIR_256BIT_RASGELE_ANAHTAR__
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
